      // タイムデータ
      if (data.timeData) {
        html += '<div style="margin-bottom: 1rem;">';
        html += '<h4 style="margin-bottom: 0.5rem;">⏱️ タイムデータ</h4>';
        html += '<div style="display: flex; gap: 1rem; flex-wrap: wrap; font-size: 0.875rem;">';

        if (data.timeData.last3F) {
          html += `<div style="padding: 0.5rem 1rem; background: var(--bg-secondary); border-radius: 4px;"><strong>上がり3F:</strong> ${data.timeData.last3F}秒</div>`;
