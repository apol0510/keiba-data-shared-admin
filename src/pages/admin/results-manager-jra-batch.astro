    // JSON全コピー
    function copyAllJSON() {
      const successResults = batchResults.filter(r => r.success);
      if (successResults.length === 0) {
        alert('コピーできるデータがありません');
        return;
      }

      const date = successResults[0].date;
      const venue = successResults[0].venue;

      const jsonData = {
        raceDate: date,
        lastUpdated: new Date().toISOString(),
        track: venue,
        totalRaces: successResults.length,
        races: successResults.map(r => r.data),
      };

      navigator.clipboard.writeText(JSON.stringify(jsonData, null, 2)).then(() => {
        alert('JSONをコピーしました！');
      });
    }

    // 一括保存
    async function saveAllRacesToGit(forceOverwrite = false) {
      const successResults = batchResults.filter(r => r.success);
      if (successResults.length === 0) {
        alert('保存できるデータがありません');
        return;
      }

      const btn = document.getElementById('saveAllBtn');
      const statusDiv = document.getElementById('saveStatus');

      btn.disabled = true;
      btn.textContent = '⏳ 保存中...';

      statusDiv.style.display = 'block';
      statusDiv.className = 'save-status loading';
      statusDiv.textContent = forceOverwrite
        ? `🔥 ${successResults.length}レース分を完全上書き中...`
        : `🚀 ${successResults.length}レース分を保存中...`;

      try {
        const date = successResults[0].date;
        const venue = successResults[0].venue;

        // 競馬場コードマッピング（共通定数から取得）
        // ⚠️ src/lib/constants/venue-codes.ts で一元管理
        const venueCodeMap = {
          '東京': 'TOK',
          '中山': 'NAK',
          '京都': 'KYO',
          '阪神': 'HAN',
          '中京': 'CHU',
          '新潟': 'NII',
          '福島': 'FKS',
          '小倉': 'KOK',
          '札幌': 'SAP',
          '函館': 'HKD'
        };

        const jsonData = {
          date: date,  // ✅ 正しいフィールド名
          venue: venue,  // ✅ 正しいフィールド名
          venueCode: venueCodeMap[venue] || 'TOK',  // ✅ 競馬場コード追加（デフォルト: 東京）
          races: successResults.map(r => r.data),
        };

        const response = await fetch('/.netlify/functions/save-results-jra', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            resultsJSON: JSON.stringify(jsonData),
            forceOverwrite: forceOverwrite
          })
        });

        const result = await response.json();

        if (response.ok && result.success) {
          statusDiv.className = 'save-status success';
          statusDiv.innerHTML = `
            ✅ ${successResults.length}レース分の保存成功！<br>
            <strong>ファイル:</strong> ${result.filePath || result.fileName || '-'}<br>
            <strong>コミット:</strong> ${result.commitSha?.substring(0, 7) || '-'}<br>
            ${result.commitUrl ? `<a href="${result.commitUrl}" target="_blank" style="color: var(--primary-end);">📝 コミットを確認</a><br>` : ''}
            ${result.rawUrl ? `<a href="${result.rawUrl}" target="_blank" style="color: var(--primary-end);">📄 JSONファイルを確認</a>` : ''}
            <br><span style="color: var(--text-secondary);">🔄 1.5秒後に自動リセットします...</span>
          `;
          btn.textContent = '✅ 保存完了';

          // フォームを自動クリア（次の入力に備える）
          setTimeout(() => {
            document.getElementById('batchInput').value = '';
            document.getElementById('commonDate').value = new Date().toISOString().split('T')[0];
            document.getElementById('fallbackVenue').value = '';
            document.getElementById('parseStatus').style.display = 'none';
            document.getElementById('previewSection').style.display = 'none';
            batchResults = [];
            btn.disabled = false;
            btn.textContent = '🚀 12レース一括保存してGit Push';
            statusDiv.innerHTML = '';
            console.log('[Auto Reset] フォームをリセットしました。次のデータを貼り付けてください。');
          }, 1500);
        } else {
          statusDiv.className = 'save-status error';
          statusDiv.innerHTML = `❌ エラー: ${result.error || '保存に失敗しました'}`;
          btn.disabled = false;
          btn.textContent = '🚀 12レース一括保存してGit Push';
        }
      } catch (error) {
        statusDiv.className = 'save-status error';
        statusDiv.innerHTML = `❌ ネットワークエラー: ${error.message}`;
        btn.disabled = false;
        btn.textContent = '🚀 12レース一括保存してGit Push';
      }
    }
  </script>
</BaseLayout>
