          html += `<td style="padding: 0.5rem; border: 1px solid var(--border-color); text-align: center;">${r.bracket}</td>`;
          html += `<td style="padding: 0.5rem; border: 1px solid var(--border-color); text-align: center;">${r.number}</td>`;
