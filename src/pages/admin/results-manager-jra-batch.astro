            <div style="color: var(--text-secondary);">合計</div>
          </div>
        </div>
      `;

      // 各レースの詳細
      let detailsHTML = '';
      results.forEach(result => {
        const statusClass = result.success ? 'success' : 'error';
        const statusText = result.success ? '✅ 成功' : '❌ エラー';

        detailsHTML += `
          <details class="race-detail-card ${statusClass}">
            <summary class="race-detail-header">
              <span class="race-number-badge">第${result.raceNumber}R</span>
              <span class="race-status-badge ${statusClass}">${statusText}</span>
            </summary>
