---
/**
 * 競馬結果データ管理画面（12レース一括入力版）
 * results-managerとは完全に別のファイル
 *
 * 機能:
 * - 12レース分の結果HTMLを一括貼り付け
 * - レース境界を自動検出して分割
 * - 各レースを個別に抽出・バリデーション
 * - 12レース分を1つのJSONファイルに保存
 */
import BaseLayout from "../../layouts/BaseLayout.astro";

export const prerender = false;
---

<BaseLayout
  title="結果管理画面（一括入力）"
  description="12レース分の結果HTMLを一括で解析してデータ化します"
>
  <section class="admin-section">
    <div class="container">
      <h1 class="page-title">⚡ 南関競馬 結果管理（12レース一括）</h1>
      <p class="page-description">
        <strong>12レース分の結果を一度に貼り付けて一括処理できます</strong><br>
        南関公式サイトの結果ページをコピー＆貼り付けするだけ！<br>
        ※ 個別入力が必要な場合は <a href="/admin/results-manager" style="color: var(--primary-end); text-decoration: underline;">結果管理（個別入力）</a> をご利用ください
      </p>

      <!-- 共通情報入力 -->
      <div class="card common-info-card">
        <h2>📅 開催情報（全レース共通）</h2>
        <div style="padding: var(--spacing-md); background: rgba(16, 185, 129, 0.1); border-left: 4px solid #10b981; border-radius: 4px; margin-bottom: var(--spacing-lg);">
          <strong style="color: #10b981;">✅ 自動検出機能</strong>
          <ul style="margin: var(--spacing-sm) 0 0 var(--spacing-lg); color: var(--text-secondary);">
            <li>解析時にテキストから日付・競馬場を自動検出します</li>
            <li>入力フォームの値は自動的に上書きされます</li>
            <li>保存前のプレビューで日付・競馬場を確認してください</li>
          </ul>
        </div>
        <div class="common-info-grid">
          <div class="form-group">
            <label for="commonDate">開催日</label>
            <input
              type="date"
              id="commonDate"
              class="form-input"
              value={new Date().toISOString().split('T')[0]}
            />
            <small style="color: var(--text-secondary); display: block; margin-top: 0.25rem;">
              ※ テキストから自動検出された場合は上書きされます
            </small>
          </div>
          <div class="form-group">
            <label for="commonVenue">競馬場</label>
            <select id="commonVenue" class="form-select">
              <option value="船橋">船橋</option>
              <option value="大井">大井</option>
              <option value="川崎">川崎</option>
              <option value="浦和">浦和</option>
            </select>
            <small style="color: var(--text-secondary); display: block; margin-top: 0.25rem;">
              ※ テキストから自動検出された場合は上書きされます
            </small>
          </div>
        </div>
      </div>

      <!-- 一括入力エリア -->
      <div class="card input-card">
        <h2>📋 12レース分の結果テキスト貼り付け</h2>
        <p style="color: var(--text-secondary); margin-bottom: var(--spacing-md);">
          南関公式サイトの結果ページで<strong>第1R〜第12R</strong>までの表示内容を全て選択してコピーし、下のテキストエリアに貼り付けてください。<br>
          自動的にレースごとに分割・解析します。（HTMLタグは不要です）
        </p>

        <textarea
          id="batchInput"
          class="batch-textarea"
          rows="20"
          placeholder="12レース分の結果テキストを貼り付けてください

※ 南関公式サイトの結果ページで、第1R〜第12Rまでの
  表示されている内容を全て選択してコピー＆貼り付けしてください。

例:
1R2026年1月26日 大井競馬 第1日
ダ1,800m（外）（15頭）発走時刻17:15
白富士賞 Ｂ２(三)Ｂ３(一) 選抜特別
...
着    枠    馬番    馬名...
1    3    5    ブルマリン...
...
払戻金
単勝    複勝...

2R2026年1月26日 大井競馬 第1日
...
(第12Rまで)"
        ></textarea>

        <div class="action-buttons" style="margin-top: var(--spacing-lg);">
          <button
            type="button"
            class="btn btn-primary btn-large"
            onclick="parseBatchRaces()"
          >
            🔍 12レース一括解析
          </button>
        </div>

        <div id="parseStatus" class="parse-status" style="display: none;"></div>
      </div>

      <!-- プレビューエリア -->
      <div id="previewSection" class="preview-section" style="display: none;">
        <div class="card">
          <h2>✅ 解析結果プレビュー</h2>
          <div id="raceSummary" class="race-summary"></div>

          <!-- 各レースの詳細プレビュー -->
          <div id="raceDetails" class="race-details"></div>

          <!-- 一括保存ボタン -->
          <div class="action-buttons" style="margin-top: var(--spacing-2xl);">
            <button
              type="button"
              class="btn btn-secondary"
              onclick="copyAllJSON()"
            >
              📋 JSON全コピー
            </button>
            <button
              type="button"
              id="saveAllBtn"
              class="btn btn-success btn-large"
              onclick="saveAllRacesToGit(false)"
            >
              🚀 12レース一括保存してGit Push
            </button>
            <button
              type="button"
              class="btn btn-warning"
              onclick="if(confirm('この日付の既存データを完全に上書きします。よろしいですか？')) saveAllRacesToGit(true)"
            >
              🔥 完全上書き保存
            </button>
          </div>
          <div id="saveStatus" class="save-status" style="display: none;"></div>
        </div>
      </div>

      <!-- 使用方法 -->
      <div class="card info-card">
        <h2>📖 使用方法</h2>
        <ol>
          <li><strong>開催日・競馬場</strong>を上部で選択</li>
          <li>南関公式サイトの結果ページを開く</li>
          <li><strong>第1R〜第12R全ての表示内容</strong>をブラウザで選択してコピー
            <ul style="margin-top: 0.5rem; font-size: 0.9rem;">
              <li>ページ全体を選択（Ctrl+A / Cmd+A）</li>
              <li>または、第1Rの「1R2026年」から第12Rの払戻金まで選択</li>
            </ul>
          </li>
          <li>上のテキストエリアに貼り付け（Ctrl+V / Cmd+V）</li>
          <li>「12レース一括解析」ボタンをクリック</li>
          <li>プレビューで各レースの抽出結果を確認</li>
          <li>「12レース一括保存してGit Push」で keiba-data-shared に保存</li>
          <li>自動的に各サイトに反映されます 🎉</li>
        </ol>

        <h3>💡 ポイント</h3>
        <ul>
          <li>12レース分を一度に処理できます（効率重視）</li>
          <li>HTMLタグは不要です（表示されているテキストをそのままコピー）</li>
          <li>エラーが出たレースは赤色で表示されます</li>
          <li>慎重に確認したい場合は <a href="/admin/results-manager" style="color: var(--primary-end);">個別入力</a> をご利用ください</li>
          <li>既存データは自動的にマージされます（上書きされません）</li>
        </ul>
      </div>
    </div>
  </section>

  <style>
    .admin-section {
      padding: var(--spacing-2xl) 0;
      min-height: 100vh;
    }

    .page-title {
      font-size: 2rem;
      margin-bottom: var(--spacing-md);
      text-align: center;
    }

    .page-description {
      text-align: center;
      color: var(--text-secondary);
      margin-bottom: var(--spacing-2xl);
      line-height: 1.6;
    }

    .common-info-card {
      max-width: 800px;
      margin: 0 auto var(--spacing-2xl);
    }

    .common-info-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--spacing-lg);
      margin-top: var(--spacing-md);
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-sm);
    }

    .form-group label {
      font-weight: 600;
      color: var(--text-primary);
    }

    .form-input,
    .form-select {
      padding: var(--spacing-sm) var(--spacing-md);
      border: 1px solid var(--border-color);
      border-radius: var(--radius-md);
      background: var(--bg-secondary);
      color: var(--text-primary);
      font-size: 1rem;
    }

    .input-card {
      max-width: 1200px;
      margin: 0 auto var(--spacing-2xl);
    }

    .batch-textarea {
      width: 100%;
      padding: var(--spacing-md);
      border: 1px solid var(--border-color);
      border-radius: var(--radius-md);
      background: var(--bg-secondary);
      color: var(--text-primary);
      font-family: 'Courier New', monospace;
      font-size: 0.875rem;
      resize: vertical;
      min-height: 400px;
    }

    .action-buttons {
      display: flex;
      gap: var(--spacing-md);
      flex-wrap: wrap;
    }

    .btn-large {
      flex: 1;
      min-width: 200px;
    }

    .parse-status,
    .save-status {
      margin-top: var(--spacing-md);
      padding: var(--spacing-md);
      border-radius: var(--radius-md);
      font-weight: 600;
      display: none;
    }

    .parse-status.success,
    .save-status.success {
      background: rgba(16, 185, 129, 0.1);
      border-left: 4px solid var(--success);
      color: var(--success);
    }

    .parse-status.error,
    .save-status.error {
      background: rgba(239, 68, 68, 0.1);
      border-left: 4px solid var(--error);
      color: var(--error);
    }

    .parse-status.loading,
    .save-status.loading {
      background: rgba(59, 130, 246, 0.1);
      border-left: 4px solid var(--primary-end);
      color: var(--primary-end);
    }

    .preview-section {
      max-width: 1200px;
      margin: 0 auto var(--spacing-2xl);
    }

    .race-summary {
      margin-bottom: var(--spacing-xl);
      padding: var(--spacing-lg);
      background: var(--bg-secondary);
      border-radius: var(--radius-md);
    }

    .race-details {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-md);
    }

    .race-detail-card {
      border: 2px solid var(--border-color);
      border-radius: var(--radius-md);
      overflow: hidden;
    }

    .race-detail-card.success {
      border-color: var(--success);
    }

    .race-detail-card.error {
      border-color: var(--error);
    }

    .race-detail-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: var(--spacing-lg);
      cursor: pointer;
      font-weight: 600;
      font-size: 1.25rem;
      user-select: none;
      background: var(--bg-secondary);
    }

    .race-detail-header:hover {
      background: var(--bg-tertiary);
    }

    .race-number-badge {
      color: var(--primary-end);
      font-size: 1.5rem;
    }

    .race-status-badge {
      font-size: 0.875rem;
      padding: 4px 12px;
      border-radius: var(--radius-sm);
      font-weight: 600;
    }

    .race-status-badge.success {
      background: rgba(16, 185, 129, 0.2);
      color: var(--success);
    }

    .race-status-badge.error {
      background: rgba(239, 68, 68, 0.2);
      color: var(--error);
    }

    .race-detail-content {
      padding: var(--spacing-lg);
      border-top: 1px solid var(--border-color);
    }

    .info-card {
      max-width: 1200px;
      margin: var(--spacing-2xl) auto 0;
    }

    .info-card ol,
    .info-card ul {
      margin-left: var(--spacing-lg);
      color: var(--text-secondary);
    }

    .info-card li {
      margin-bottom: var(--spacing-sm);
    }

    @media (max-width: 768px) {
      .common-info-grid {
        grid-template-columns: 1fr;
      }

      .action-buttons {
        flex-direction: column;
      }

      .btn-large {
        width: 100%;
      }
    }
  </style>

  <script is:inline>
    // グローバル変数
    let batchResults = [];

    // 一括解析メイン関数
    function parseBatchRaces() {
      const textarea = document.getElementById('batchInput');
      const html = textarea.value;

      if (!html.trim()) {
        alert('12レース分の結果HTMLを入力してください');
        return;
      }

      const statusDiv = document.getElementById('parseStatus');
      statusDiv.style.display = 'block';
      statusDiv.className = 'parse-status loading';
      statusDiv.textContent = '🔍 12レース分を解析中...';

      try {
        // レース境界で分割
        const raceHTMLs = splitRacesHTML(html);
        console.log(`[parseBatchRaces] 検出したレース数: ${raceHTMLs.length}`);

        if (raceHTMLs.length === 0) {
          statusDiv.className = 'parse-status error';
          statusDiv.textContent = '❌ レースが検出できませんでした。HTMLの形式を確認してください。';
          return;
        }

        // 【新規】テキストから日付・競馬場を自動抽出
        const firstRaceText = raceHTMLs[0];
        const detectedDate = extractDateFromText(firstRaceText); // "2026年3月12日"
        const detectedVenue = extractVenueFromText(firstRaceText); // "船橋" or "大井" etc

        console.log(`[parseBatchRaces] 自動検出: 日付=${detectedDate}, 競馬場=${detectedVenue}`);

        // 共通情報取得
        const commonDate = document.getElementById('commonDate').value;
        const commonVenue = document.getElementById('commonVenue').value;

        // 【新規】日付・競馬場の一致チェック
        let finalDate = commonDate;
        let finalVenue = commonVenue;
        let hasDateMismatch = false;
        let hasVenueMismatch = false;

        // 日付チェック（YYYY-MM-DD形式に変換して比較）
        if (detectedDate) {
          const detectedDateISO = convertJapaneseDateToISO(detectedDate);
          if (detectedDateISO && detectedDateISO !== commonDate) {
            hasDateMismatch = true;
            console.warn(`[parseBatchRaces] 日付不一致: 入力フォーム=${commonDate}, テキスト=${detectedDateISO}`);
          }
        }

        // 競馬場チェック
        if (detectedVenue && detectedVenue !== commonVenue) {
          hasVenueMismatch = true;
          console.warn(`[parseBatchRaces] 競馬場不一致: 入力フォーム=${commonVenue}, テキスト=${detectedVenue}`);
        }

        // 【修正】不一致がある場合、自動的にテキストの情報を使用（確認ダイアログなし）
        if (hasDateMismatch || hasVenueMismatch) {
          // テキストの情報を自動的に使用
          if (hasDateMismatch) {
            finalDate = convertJapaneseDateToISO(detectedDate);
            document.getElementById('commonDate').value = finalDate;
            console.log(`[parseBatchRaces] 日付をテキストから自動設定: ${finalDate} (フォーム: ${commonDate})`);
          }
          if (hasVenueMismatch) {
            finalVenue = detectedVenue;
            document.getElementById('commonVenue').value = finalVenue;
            console.log(`[parseBatchRaces] 競馬場をテキストから自動設定: ${finalVenue} (フォーム: ${commonVenue})`);
          }
        }

        const date = finalDate;
        const venue = finalVenue;

        // 各レースを解析
        batchResults = [];
        let successCount = 0;
        let errorCount = 0;

        raceHTMLs.forEach((raceHTML, index) => {
          const raceNum = index + 1;
          try {
            // レース情報抽出
            const raceInfo = extractRaceInfo(raceHTML, raceNum);

            // 結果データ抽出
            const results = extractResults(raceHTML);
            const payouts = extractPayouts(raceHTML);
            const timeData = extractTimeData(raceHTML);
            const cornerData = extractCornerData(raceHTML);

            // レースオブジェクトを構築（generateRaceCommentary用）
            const race = {
              raceNumber: raceNum,
              raceName: raceInfo.raceName,
              surface: raceInfo.surface,
              distance: raceInfo.distance,
              horses: results.length,
              results: results,
              payouts: payouts,
              cornerData: cornerData,
              timeData: timeData
            };

            const comment = generateRaceCommentary(race, date, venue);

            const data = {
              date: date,
              venue: venue,
              raceNumber: raceNum,
              raceName: raceInfo.raceName,
              raceSubtitle: raceInfo.raceSubtitle,
              raceType: raceInfo.raceType,
              distance: raceInfo.distance,
              surface: raceInfo.surface,
              horses: raceInfo.horses || results.length, // 🔧 FIX: 出走頭数を追加
              startTime: raceInfo.startTime,
              weather: raceInfo.weather,
              trackCondition: raceInfo.trackCondition,
              results: results,
              payouts: payouts,
              timeData: timeData,
              cornerData: cornerData,
              comment: comment,
            };

            batchResults.push({
              raceNumber: raceNum,
              success: true,
              data,
              date,
              venue,
            });
            successCount++;

          } catch (error) {
            console.error(`第${raceNum}R解析エラー:`, error);
            batchResults.push({
              raceNumber: raceNum,
              success: false,
              errors: [error.message],
            });
            errorCount++;
          }
        });

        // ステータス更新
        statusDiv.className = errorCount > 0 ? 'parse-status error' : 'parse-status success';
        statusDiv.innerHTML = `
          ✅ 解析完了: 成功 ${successCount}レース / エラー ${errorCount}レース<br>
          ${errorCount > 0 ? '⚠️ エラーが出たレースは下で確認してください' : ''}
        `;

        // プレビュー表示
        displayBatchPreview(batchResults, date, venue);

      } catch (error) {
        statusDiv.className = 'parse-status error';
        statusDiv.innerHTML = `❌ エラー: ${error.message}`;
        console.error(error);
      }
    }

    // レーステキストを分割（結果用・プレーンテキスト対応）
    function splitRacesHTML(text) {
      const races = [];

      console.log(`[splitRacesHTML] 入力テキスト長: ${text.length}文字`);
      console.log(`[splitRacesHTML] 最初の500文字:`, text.substring(0, 500));

      // 結果はプレーンテキスト形式（HTMLタグなし）
      // パターン: 「1R 2026年」「2R 2026年」...「12R 2026年」のような形式（スペースあり/なし両対応）
      const racePattern = /(\d{1,2}R)\s*(\d{4})年/g;

      const raceMatches = [];
      let match;

      while ((match = racePattern.exec(text)) !== null) {
        raceMatches.push({
          index: match.index,
          raceNum: parseInt(match[1].replace('R', ''), 10),
          fullMatch: match[0]
        });
      }

      console.log(`[splitRacesHTML] ○R○年パターン検出数: ${raceMatches.length}個`);

      // レース番号の重複を除去（念のため）
      const seenRaceNumbers = new Set();
      const uniqueRaceMatches = raceMatches.filter(rm => {
        if (seenRaceNumbers.has(rm.raceNum)) {
          console.warn(`[splitRacesHTML] 重複検出: 第${rm.raceNum}R（スキップ）`);
          return false;
        }
        seenRaceNumbers.add(rm.raceNum);
        return true;
      });

      console.log(`[splitRacesHTML] 重複除去後のレース数: ${uniqueRaceMatches.length}個`);

      if (uniqueRaceMatches.length > 0) {
        // 各レースのテキストを抽出
        for (let i = 0; i < uniqueRaceMatches.length; i++) {
          const startIndex = uniqueRaceMatches[i].index;
          const endIndex = i < uniqueRaceMatches.length - 1 ? uniqueRaceMatches[i + 1].index : text.length;
          const raceText = text.substring(startIndex, endIndex);

          if (raceText.length > 100) {
            races.push(raceText);
            console.log(`[splitRacesHTML] 第${uniqueRaceMatches[i].raceNum}R: ${raceText.length}文字`);
            console.log(`[splitRacesHTML] 第${uniqueRaceMatches[i].raceNum}R 最初の200文字:`, raceText.substring(0, 200));
          } else {
            console.warn(`[splitRacesHTML] 第${uniqueRaceMatches[i].raceNum}R: データが短すぎる（${raceText.length}文字）`);
          }
        }
      } else {
        console.error('[splitRacesHTML] レース境界を検出できませんでした');
        console.log('[splitRacesHTML] テキストサンプル（最初の1000文字）:', text.substring(0, 1000));
      }

      console.log(`[splitRacesHTML] 最終的に検出したレース数: ${races.length}`);
      return races;
    }

    // ===== results-manager.astroから統合した抽出関数 =====

    function extractRaceInfo(text, raceNumber) {
      let raceName = '';
      const lines = text.split('\n').map(l => l.trim()).filter(l => l);

      console.log('[extractRaceInfo] レース番号:', raceNumber);
      console.log('[extractRaceInfo] テキスト行数:', lines.length);

      // 払戻金セクションより前の行のみを対象にする（賞金データの混入を防止）
      const payoutStartIdx = lines.findIndex(l => l.includes('払戻金'));
      const targetLines = payoutStartIdx !== -1 ? lines.slice(0, payoutStartIdx) : lines;

      console.log('[extractRaceInfo] 払戻金セクション開始:', payoutStartIdx);
      console.log('[extractRaceInfo] レース名検索対象行数:', targetLines.length);

      // 優先順位1: 重賞レース名
      for (let line of targetLines) {
        const trimmedLine = line.trim();
        const hasKaisuu = trimmedLine.match(/第\d+回/);
        const isDateOrVenue = trimmedLine.match(/競馬|月|日|年/);
        const hasGrade = trimmedLine.match(/[（(][ＳＧＪ][ＩIｐｎ]/);

        if ((hasKaisuu && !isDateOrVenue) || hasGrade) {
          raceName = trimmedLine;
          console.log('[extractRaceInfo] 重賞レース名抽出:', raceName);
          break;
        }
      }

      // 優先順位2: 地方競馬グレード
      if (!raceName) {
        for (let line of targetLines) {
          const trimmedLine = line.trim();
          if (trimmedLine.match(/[ＡＢＣ][１２３０]/)) {
            raceName = trimmedLine;
            console.log('[extractRaceInfo] グレードレース名抽出:', raceName);
            break;
          }
        }
      }

      // 🔧 優先順位3（変更）: カタカナ主体のレース名
      // 「スプリングヒロインカップ」や「ブルートシュタインチャレンジ」など
      // 括弧付き（例: スプリングヒロインカップ（エンプレス杯ＴＲ））にも対応
      if (!raceName) {
        for (let line of targetLines) {
          const trimmedLine = line.trim();
          // 払戻金・賞金関連のキーワードを含む行はスキップ
          const isPayoutRelated = trimmedLine.match(/単勝|複勝|馬連|馬単|枠連|枠単|ワイド|三連|組番|払戻|人気|円|賞金|番組ポイント|サラブレッド系|アラブ系|普通競走/);
          if (isPayoutRelated) {
            continue;
          }

          // 付帯情報行を除外
          const isSupplementaryInfo = trimmedLine.match(/^(準重賞|重賞|ＪＲＡ交流|特別競走|一般|サラブレッド系|指定|別定|馬齢|定量|ハンデ)[\s\u3000]/);
          if (isSupplementaryInfo) {
            continue;
          }

          // 付帯情報の単独行も除外（例: 「準重賞」のみの行）
          const isSupplementaryInfoOnly = trimmedLine.match(/^(準重賞|重賞|ＪＲＡ交流|特別競走|一般競走|サラブレッド系|指定|別定|馬齢|定量|ハンデ)$/);
          if (isSupplementaryInfoOnly) {
            continue;
          }

          // カタカナが5文字以上含まれ、適切な長さ（5-50文字）の行を抽出
          const katakanaCount = (trimmedLine.match(/[ァ-ヴ]/g) || []).length;
          if (katakanaCount >= 5 && trimmedLine.length >= 5 && trimmedLine.length <= 50) {
            raceName = trimmedLine;
            console.log('[extractRaceInfo] カタカナレース名抽出:', raceName);
            break;
          }
        }
      }

      // 🔧 優先順位4（変更）: 「特別」「賞」「杯」
      // ⚠️ 払戻金キーワード（「単勝」「複勝」「馬連」など）と賞金キーワードを除外
      if (!raceName) {
        for (let line of targetLines) {
          const trimmedLine = line.trim();
          // 払戻金・賞金関連のキーワードを含む行はスキップ
          const isPayoutRelated = trimmedLine.match(/単勝|複勝|馬連|馬単|枠連|枠単|ワイド|三連|組番|払戻|人気|円|賞金|番組ポイント/);
          if (isPayoutRelated) {
            continue; // この行はスキップ
          }

          // 「準重賞」「ＪＲＡ交流」などの付帯情報行を除外
          const isSupplementaryInfo = trimmedLine.match(/^(準重賞|重賞|ＪＲＡ交流|特別競走|一般|サラブレッド系|指定|別定|馬齢|定量|ハンデ)[\s\u3000]/);
          if (isSupplementaryInfo) {
            continue; // この行はスキップ
          }

          // 付帯情報の単独行も除外（例: 「準重賞」のみの行）
          const isSupplementaryInfoOnly = trimmedLine.match(/^(準重賞|重賞|ＪＲＡ交流|特別競走|一般競走|サラブレッド系|指定|別定|馬齢|定量|ハンデ)$/);
          if (isSupplementaryInfoOnly) {
            console.log('[extractRaceInfo] 付帯情報単独行をスキップ:', trimmedLine);
            continue; // この行はスキップ
          }

          if (trimmedLine.match(/特別|賞|杯|盃/)) {
            raceName = trimmedLine;
            console.log('[extractRaceInfo] 一般レース名抽出:', raceName);
            break;
          }
        }
      }

      // 優先順位5: クラス名（「３歳」「２歳」など）
      // 特別名がない一般レースの場合
      if (!raceName) {
        for (let line of targetLines) {
          const trimmedLine = line.trim();
          // 払戻金・賞金関連のキーワードを含む行はスキップ
          const isPayoutRelated = trimmedLine.match(/単勝|複勝|馬連|馬単|枠連|枠単|ワイド|三連|組番|払戻|人気|円|賞金|番組ポイント|サラブレッド系|アラブ系|普通競走/);
          if (isPayoutRelated) {
            continue; // この行はスキップ
          }

          // ３歳(三)、２歳、４歳以上 などのパターン
          if (trimmedLine.match(/^[２３４]歳(\(.*\))?$/) || trimmedLine.match(/^\d歳以上/)) {
            raceName = trimmedLine;
            console.log('[extractRaceInfo] クラス名抽出:', raceName);
            break;
          }
        }
      }

      // 距離パターン: "ダ1,800m" または "ダ900m" の両方に対応
      const distanceMatch = text.match(/[ダ芝][\s\u3000]*(?:(\d{1}),?(\d{3})|(\d{3}))m/);
      let distance = null;
      if (distanceMatch) {
        if (distanceMatch[1] && distanceMatch[2]) {
          // 1,800形式（1桁+カンマ+3桁）
          distance = parseInt(distanceMatch[1] + distanceMatch[2], 10);
        } else if (distanceMatch[3]) {
          // 900形式（3桁のみ）
          distance = parseInt(distanceMatch[3], 10);
        }
      }

      console.log('[extractRaceInfo] 距離抽出:', distance, 'from:', distanceMatch);

      const surface = text.includes('ダ') ? 'ダート' : '芝';

      const track = null;

      const horsesMatch = text.match(/（(\d+)頭）/);
      const horses = horsesMatch ? parseInt(horsesMatch[1], 10) : null;

      const startTimeMatch = text.match(/発走時刻(\d{1,2}):(\d{2})/);
      const startTime = startTimeMatch ? `${startTimeMatch[1]}:${startTimeMatch[2]}` : null;

      // 天候抽出（改善版）
      const weatherMatch = text.match(/天候[:：]\s*([^\s\n]+)/);
      const weather = weatherMatch ? weatherMatch[1] : null;

      // 馬場状態抽出（改善版）
      const trackConditionMatch = text.match(/馬場[:：]\s*(?:ダート|芝)?\s*([^\s\n]+)/);
      const trackCondition = trackConditionMatch ? trackConditionMatch[1] : null;

      console.log('[extractRaceInfo] 天候:', weather);
      console.log('[extractRaceInfo] 馬場状態:', trackCondition);

      return { raceNumber, raceName, distance, surface, track, horses, startTime, weather, trackCondition };
    }

    function extractResults(text) {
      const results = [];
      const lines = text.split('\n');

      console.log('[extractResults] テキスト行数:', lines.length);

      // 「着    枠    馬番」で始まるヘッダー行を探す
      const headerIdx = lines.findIndex(l => l.includes('着') && l.includes('枠') && l.includes('馬番'));
      console.log('[extractResults] ヘッダー行インデックス:', headerIdx);

      // 払戻金セクションの開始位置を見つける（着順データ抽出を停止するため）
      const payoutStartIdx = lines.findIndex(l => l.includes('払戻金'));
      console.log('[extractResults] 払戻金セクション開始:', payoutStartIdx);

      for (let i = 0; i < lines.length; i++) {
        // 払戻金セクションに到達したら着順データ抽出を終了
        if (payoutStartIdx !== -1 && i >= payoutStartIdx) {
          console.log('[extractResults] 払戻金セクション到達 - 抽出終了');
          break;
        }

        const line = lines[i];

        // 着順データ行のパターン（タブまたは複数スペース区切り）
        // 1    3    5    ブルマリンシェール    牡6    56.0    504kg    ＋11    ☆谷内貫太    佐野謙二    1:55.7    -    38.7    10-10-9-7    4
        const parts = line.split(/[\s\t]+/).filter(p => p);

        // 🔧 FIX: 最小フィールド数を14から10に緩和（13頭対応）
        // コーナー通過順が「-」の場合でも抽出できるようにする
        if (parts.length >= 10 && /^\d+$/.test(parts[0])) {
          const rank = parseInt(parts[0], 10);
          const bracket = parseInt(parts[1], 10);
          const number = parseInt(parts[2], 10);

          // 馬名
          const name = parts[3];

          // 性齢（牡6など）はスキップ（parts[4]）
          // 負担（56.0など）はスキップ（parts[5]）
          // 馬体重（504kgなど）はスキップ（parts[6]）
          // 増減（＋11など）はスキップ（parts[7]）

          // 騎手（☆谷内貫太）
          const jockey = parts[8];

          // 調教師（佐野謙二）
          const trainer = parts[9];

          // タイム
          const time = parts[10] || '-';

          // 🔧 FIX: 人気は最後のフィールドから逆算（着差が「２ 1/2」のようにスペース区切りの場合に対応）
          // フィールド構成: ... タイム(10) 着差(11-?) 上がり3F(?-2) コーナー通過順(?-1) 人気(last)
          let popularity = 99;
          let lastFurlong = '-';
          let margin = '-';

          const lastIdx = parts.length - 1;

          // 最後が数字なら人気
          if (parts[lastIdx] && /^\d+$/.test(parts[lastIdx])) {
            popularity = parseInt(parts[lastIdx], 10);

            // 上がり3Fは最後から2番目（コーナー通過順の前）
            const last3FIdx = lastIdx - 2;
            if (last3FIdx >= 11 && parts[last3FIdx] && /^[\d.]+$/.test(parts[last3FIdx])) {
              lastFurlong = parts[last3FIdx];

              // 着差はタイム（parts[10]）の次から上がり3Fの前まで
              const marginParts = parts.slice(11, last3FIdx);
              margin = marginParts.join(' ') || '-';
            }
          }

          // 🔧 DEBUG: フィールド数と内容をログ出力
          console.log(`[extractResults] 行解析: parts.length=${parts.length}, 着順=${rank}, 馬番=${number}, 馬名=${name}, 人気=${popularity}, 着差="${margin}"`);

          if (!isNaN(rank) && !isNaN(number)) {
            results.push({
              rank,
              bracket,
              number,
              name,
              jockey,
              trainer,
              time,
              margin,
              lastFurlong,
              popularity
            });

            console.log(`[extractResults] ✅ 第${rank}着: ${number}番 ${name} (${jockey} / ${trainer}) - 人気: ${popularity}`);
          } else {
            console.warn(`[extractResults] ⚠️ スキップ: 着順=${rank}, 馬番=${number}がNaN`);
          }
        } else if (parts.length > 0 && /^\d+$/.test(parts[0])) {
          // 🔧 DEBUG: 着順っぽいけどフィールド数が足りない行をログ
          console.warn(`[extractResults] ⚠️ フィールド数不足: parts.length=${parts.length}, 行内容: ${line.substring(0, 100)}`);
        }
      }

      console.log('[extractResults] 抽出した頭数:', results.length);

      if (results.length === 0) throw new Error('着順データが見つかりません');
      return results;
    }

    function extractPayouts(text) {
      const payouts = {};

      const payoutMatch = text.match(/払戻金[\s\S]*$/);
      if (!payoutMatch) return payouts;

      const payoutSection = payoutMatch[0];
      const lines = payoutSection.split('\n').filter(l => l.trim());

      // テーブル1
      const table1HeaderIdx = lines.findIndex(l =>
        l.includes('単勝') && l.includes('複勝') && l.includes('馬単')
      );

      if (table1HeaderIdx > -1) {
        const dataRows = [];
        for (let i = table1HeaderIdx + 1; i < lines.length; i++) {
          const line = lines[i];
          if (line.includes('組番')) continue;
          if (line.includes('ワイド') || line.includes('三連')) break;
          if (/^[\d-]/.test(line)) {
            dataRows.push(line);
          } else if (dataRows.length > 0) {
            break;
          }
        }

        const ticketTypes = [
          { key: 'tansho', offset: 0, hasNumber: true, maxEntries: 1 },
          { key: 'fukusho', offset: 3, hasNumber: true, maxEntries: 3 }, // 複勝は2-3着まで
          { key: 'wakuren', offset: 6, hasNumber: false, maxEntries: 1 },
          { key: 'umaren', offset: 9, hasNumber: false, maxEntries: 1 },
          { key: 'wakutan', offset: 12, hasNumber: false, maxEntries: 1 },
          { key: 'umatan', offset: 15, hasNumber: false, maxEntries: 1 }
        ];

        for (const type of ticketTypes) {
          const items = [];
          for (const row of dataRows) {
            const values = row.split(/[\s\u3000]+/).filter(v => v);

            // 複勝の場合は2-3エントリーを抽出
            if (type.key === 'fukusho') {
              // 複勝は同一行に2-3個並んでいる可能性がある
              // offset 3,4,5 / 6,7,8 / 9,10,11 のように配置されている
              const fukushoOffsets = [3]; // 最初の複勝は offset 3

              // 2つ目の複勝をチェック（次の空白区切りで3つ先）
              if (values[3] && values[4] && values[5] &&
                  values[3] !== '-' && values[4] !== '-' && values[5] !== '-') {
                // 1つ目の複勝
                items.push({
                  number: values[3],
                  payout: parseInt(values[4].replace(/,/g, ''), 10),
                  popularity: parseInt(values[5], 10)
                });
              }

              // 2つ目と3つ目の複勝を探す（dataRowsの中の次の行に分かれている可能性も考慮）
              // ただし、通常は同じ行に並んでいるので、ここでは別行を確認
            } else {
              const numOrCombo = values[type.offset];
              const payout = values[type.offset + 1];
              const popularity = values[type.offset + 2];

              if (numOrCombo && numOrCombo !== '-' && payout && payout !== '-' && popularity && popularity !== '-') {
                items.push({
                  [type.hasNumber ? 'number' : 'combination']: numOrCombo,
                  payout: parseInt(payout.replace(/,/g, ''), 10),
                  popularity: parseInt(popularity, 10)
                });
              }
            }
          }

          // 複勝の場合、dataRowsから複数行取得（1行目=1着、2行目=2着、3行目=3着）
          if (type.key === 'fukusho') {
            items.length = 0; // 一旦クリア
            for (let i = 0; i < Math.min(dataRows.length, 3); i++) {
              const values = dataRows[i].split(/[\s\u3000]+/).filter(v => v);
              const numOrCombo = values[type.offset];
              const payout = values[type.offset + 1];
              const popularity = values[type.offset + 2];

              if (numOrCombo && numOrCombo !== '-' && payout && payout !== '-' && popularity && popularity !== '-') {
                items.push({
                  number: numOrCombo,
                  payout: parseInt(payout.replace(/,/g, ''), 10),
                  popularity: parseInt(popularity, 10)
                });
              }
            }
          }

          if (items.length > 0) {
            payouts[type.key] = items;
          }
        }
      }

      // テーブル2
      const table2HeaderIdx = lines.findIndex(l =>
        l.includes('ワイド') && l.includes('三連')
      );

      if (table2HeaderIdx > -1) {
        const dataRows = [];
        for (let i = table2HeaderIdx + 1; i < lines.length; i++) {
          const line = lines[i];
          if (line.includes('組番')) continue;
          if (line.includes('備考')) break;
          if (/^[\d-]/.test(line)) {
            dataRows.push(line);
          } else if (dataRows.length > 0) {
            break;
          }
        }

        const ticketTypes = [
          { key: 'wide', offset: 0 },
          { key: 'sanrenpuku', offset: 3 },
          { key: 'sanrentan', offset: 6 }
        ];

        for (const type of ticketTypes) {
          const items = [];
          for (const row of dataRows) {
            const values = row.split(/[\s\u3000]+/).filter(v => v);
            const combo = values[type.offset];
            const payout = values[type.offset + 1];
            const popularity = values[type.offset + 2];

            if (combo && combo !== '-' && payout && payout !== '-' && popularity && popularity !== '-') {
              items.push({
                combination: combo,
                payout: parseInt(payout.replace(/,/g, ''), 10),
                popularity: parseInt(popularity, 10)
              });
            }
          }
          if (items.length > 0) {
            payouts[type.key] = items;
          }
        }
      }

      return payouts;
    }

    function extractTimeData(text) {
      const timeData = {};

      const lines = text.split('\n').map(l => l.trim());

      const headerIdx = lines.findIndex(l =>
        l.includes('上がり3F') &&
        l.includes('上がり4F') &&
        l.includes('ハロンタイム')
      );

      if (headerIdx === -1) {
        return null;
      }

      if (!lines[headerIdx + 1]) {
        return null;
      }

      const dataLine = lines[headerIdx + 1];
      const values = dataLine.split(/[\s\t]+/).filter(v => v);
      const headers = lines[headerIdx].split(/[\s\t]+/).filter(v => v);

      const last3FIdx = headers.indexOf('上がり3F');
      const last4FIdx = headers.indexOf('上がり4F');
      const furlongIdx = headers.indexOf('ハロンタイム');

      if (last3FIdx > -1 && values[last3FIdx]) {
        timeData.last3F = parseFloat(values[last3FIdx]);
      }

      if (last4FIdx > -1 && values[last4FIdx]) {
        timeData.last4F = parseFloat(values[last4FIdx]);
      }

      if (furlongIdx > -1 && values[furlongIdx]) {
        const furlongStr = values[furlongIdx];
        const furlongs = furlongStr.split('-').map(f => parseFloat(f.trim())).filter(f => !isNaN(f));
        if (furlongs.length > 0) {
          timeData.furlongTimes = furlongs;
        }
      }

      return Object.keys(timeData).length > 0 ? timeData : null;
    }

    function extractCornerData(text) {
      const corners = [];

      const cornerSection = text.match(/(通過順|コーナー通過順)[\s\S]*?(?=払戻金|$)/);
      if (!cornerSection) {
        return null;
      }

      const cornerSectionText = cornerSection[0];

      const cornerRegex = /([１２]周)?([１２３４])角[\s\t\u3000]+([\d,()]+)/g;

      let match;
      let hasFirstLap = false;

      while ((match = cornerRegex.exec(cornerSectionText)) !== null) {
        let lapPrefix = match[1] || '';
        const cornerNumber = match[2];
        const orderStr = match[3];

        if (!lapPrefix) {
          if (hasFirstLap) {
            lapPrefix = '２周';
          }
        } else if (lapPrefix === '１周') {
          hasFirstLap = true;
        }

        const cleanedStr = orderStr.replace(/[()]/g, '');
        const order = cleanedStr.split(',').map(n => parseInt(n.trim(), 10)).filter(n => !isNaN(n));

        if (order.length > 0) {
          const cornerName = lapPrefix ? `${lapPrefix}${cornerNumber}角` : `${cornerNumber}角`;
          corners.push({
            corner: cornerName,
            order
          });
        }
      }

      return corners.length > 0 ? corners : null;
    }

    function generateRaceCommentary(race, date, venue) {
      if (!race.results || race.results.length === 0) return '';

      const winner = race.results[0];
      const second = race.results[1];
      const third = race.results[2];
      const fourth = race.results[3];
      const favorite = race.results.find(h => h.popularity === 1);

      // 逃げ馬を特定（最初のコーナーで先頭にいた馬）
      let pacemaker = null;
      if (race.cornerData && race.cornerData.length > 0) {
        const firstCorner = race.cornerData[0];
        const leadHorseNum = firstCorner.order[0];
        pacemaker = race.results.find(h => h.number === leadHorseNum);
      }

      // 各馬の位置取りを判定する関数（序盤・中盤・終盤）
      const getPosition = (horseNum, timing = 'last') => {
        if (!race.cornerData || race.cornerData.length === 0) return null;

        let corner;
        if (timing === 'early') {
          // 序盤：最初のコーナー
          corner = race.cornerData[0];
        } else if (timing === 'mid') {
          // 中盤：中間のコーナー
          const midIndex = Math.floor(race.cornerData.length / 2);
          corner = race.cornerData[midIndex];
        } else {
          // 終盤：最終コーナー
          corner = race.cornerData[race.cornerData.length - 1];
        }

        const position = corner.order.indexOf(horseNum) + 1;
        if (position === 1) return { pos: position, label: '先頭' };
        if (position === 2) return { pos: position, label: '2番手' };
        if (position === 3) return { pos: position, label: '3番手' };
        if (position <= 5) return { pos: position, label: `${position}番手` };
        if (position <= 8) return { pos: position, label: '中団' };
        return { pos: position, label: '後方' };
      };

      // 全コーナーでの平均位置と一貫性を取得
      const getPositionConsistency = (horseNum) => {
        if (!race.cornerData || race.cornerData.length === 0) return null;

        const positions = [];
        for (const corner of race.cornerData) {
          const pos = corner.order.indexOf(horseNum) + 1;
          if (pos > 0) positions.push(pos);
        }

        if (positions.length === 0) return null;

        const avg = positions.reduce((a, b) => a + b, 0) / positions.length;
        const maxPos = Math.max(...positions);
        const minPos = Math.min(...positions);
        const range = maxPos - minPos;

        return {
          avgPos: avg,
          minPos: minPos,
          maxPos: maxPos,
          range: range,
          isConsistent: range <= 1 // 位置のばらつきが1以下なら一貫
        };
      };

      const winnerPosEarly = getPosition(winner.number, 'early');
      const winnerPosMid = getPosition(winner.number, 'mid');
      const winnerPosLast = getPosition(winner.number, 'last');
      const secondPosEarly = second ? getPosition(second.number, 'early') : null;
      const secondPosMid = second ? getPosition(second.number, 'mid') : null;
      const secondPosLast = second ? getPosition(second.number, 'last') : null;
      const thirdPosLast = third ? getPosition(third.number, 'last') : null;

      let commentary = '';

      // 冒頭：日付・競馬場・レース番号・条件（SEO対策）
      if (date && venue) {
        const [year, month, day] = date.split('-');
        const formattedDate = `${year}年${parseInt(month)}月${parseInt(day)}日`;
        const surfaceLabel = race.surface === 'ダート' ? 'ダ' : '芝';
        commentary += `${formattedDate}${venue}競馬${race.raceNumber}レース（${race.raceName || 'C3'} ${surfaceLabel}${race.distance}m・${race.horses}頭立）は、`;
      }

      // パターン1: 逃げ切り勝ち
      if (pacemaker && pacemaker.number === winner.number) {
        // 勝ち馬の逃げ
        commentary += `${winner.number}番${winner.name}（`;
        if (winner.popularity === 1) {
          commentary += `1番人気`;
        } else {
          commentary += `${winner.popularity}番人気`;
        }
        commentary += `）が`;
        commentary += `スタートからハナを切って主導権を握る展開。`;

        // 直線での粘り
        commentary += `直線でも粘り強く脚を使い、勝ちタイム${winner.time}で1着。`;

        // 2着馬
        if (second && secondPosLast) {
          commentary += `2着には${secondPosLast.label}から追い込んだ${second.number}番${second.name}（${second.popularity}番人気）、`;
        } else if (second) {
          commentary += `2着には${second.number}番${second.name}（${second.popularity}番人気）、`;
        }

        // 3着馬
        if (third) {
          commentary += `3着には${third.number}番${third.name}（${third.popularity}番人気）が入線。`;
        }

        // 三連単配当情報を追加（SEO対策）
        if (race.payouts?.sanrentan && race.payouts.sanrentan.length > 0) {
          const sanrentanPayout = race.payouts.sanrentan[0].payout;
          const sanrentanPop = race.payouts.sanrentan[0].popularity;
          const sanrentanCombo = race.payouts.sanrentan[0].combination;
          commentary += `三連単${sanrentanCombo}は${sanrentanPayout.toLocaleString()}円（${sanrentanPop}番人気）で決着した。`;
        }

        // 騎手・厩舎情報を追加（簡潔に、必ず句点で閉じる）
        commentary += `鞍上は${winner.jockey}騎手と${winner.trainer}厩舎のコンビだった。`;
      }
      // パターン2: 逃げ馬がいて、差し切りパターン
      else if (pacemaker && pacemaker.number !== winner.number) {
        // 逃げ馬の動き（人気も表示）
        commentary += `${pacemaker.number}番${pacemaker.name}（${pacemaker.popularity}番人気）がハナを切る展開の中、`;

        // 勝ち馬の追い込み
        commentary += `${winner.number}番${winner.name}（`;
        if (winner.popularity === 1) {
          commentary += `1番人気`;
        } else {
          commentary += `${winner.popularity}番人気`;
        }
        commentary += `）が`;

        // 全コーナーでの位置取りを分析
        const winnerConsistency = getPositionConsistency(winner.number);
        if (winnerConsistency) {
          const avgPos = winnerConsistency.avgPos;
          const isConsistent = winnerConsistency.isConsistent;
          const earlyPos = winnerPosEarly ? winnerPosEarly.pos : null;
          const lastPos = winnerPosLast ? winnerPosLast.pos : null;

          // 序盤と終盤で位置が変化したか判定
          if (earlyPos && lastPos && earlyPos >= 4 && lastPos <= 2) {
            // 序盤4番手以降 → 終盤2番手以内 = 先行
            commentary += `先行して脚を溜め`;
          } else if (isConsistent && avgPos <= 2.5) {
            // 一貫して2番手以内
            if (Math.round(avgPos) === 2) {
              commentary += `2番手で折り合い`;
            } else {
              commentary += `逃げ馬の直後で折り合い`;
            }
          } else if (avgPos >= 2 && avgPos <= 5) {
            // 2番手〜5番手（変動あり）
            commentary += `好位で脚を溜め`;
          } else if (avgPos > 5 && avgPos <= 8) {
            // 中団
            commentary += `中団で脚を溜め`;
          } else {
            // 後方
            commentary += `後方で追走待機し`;
          }
        } else if (winnerPosLast) {
          // コーナーデータなしの場合は最終コーナー
          if (winnerPosLast.pos >= 2 && winnerPosLast.pos <= 5) {
            commentary += `好位で脚を溜め`;
          } else {
            commentary += `${winnerPosLast.label}を追走し`;
          }
        }

        // 末脚と決着方法（4角位置で判断）
        // 4角位置で適切な動詞を選択
        if (winnerPosLast && winnerPosLast.pos <= 2) {
          // 4角1〜2位：抜け出し
          commentary += `直線で抜け出し、勝ちタイム${winner.time}で1着となった`;
        } else if (winnerPosLast && winnerPosLast.pos <= 5) {
          // 4角3〜5位：差し切り（動作は最大2つ）
          commentary += `直線では`;
          if (winner.lastFurlong && parseFloat(winner.lastFurlong) < 39.5) {
            // 上がり39.5秒未満：上がりをマーク
            commentary += `上がり${winner.lastFurlong}秒をマークして`;
          } else if (winner.lastFurlong) {
            // 上がり39.5秒以上：粘り強く
            commentary += `しぶとく`;
          }
          commentary += `差し切り、勝ちタイム${winner.time}で1着となった`;
        } else {
          // 4角6位以下：追い込んで差し切り（動作は最大2つ）
          commentary += `直線では`;
          if (winner.lastFurlong && parseFloat(winner.lastFurlong) < 39.5) {
            // 上がり39.5秒未満：上がりをマーク（「追い込んで」は省略して2連鎖に抑える）
            commentary += `上がり${winner.lastFurlong}秒をマークして差し切り`;
          } else if (winner.lastFurlong) {
            // 上がりあるが遅い：追い込んで差し切り
            commentary += `追い込んで差し切り`;
          } else {
            // 上がりデータなし：追い込んで差し切り
            commentary += `追い込んで差し切り`;
          }
          commentary += `、勝ちタイム${winner.time}で1着となった`;
        }

        // 騎手・厩舎情報を追加（簡潔に、必ず句点で閉じる）
        commentary += `。鞍上は${winner.jockey}騎手と${winner.trainer}厩舎のコンビ。`;

        // 2着・3着
        if (second && third) {
          // 2着馬の表現：逃げ馬かどうかで変更
          if (pacemaker && second.number === pacemaker.number) {
            // 逃げ馬が2着に粘った場合
            commentary += `2着には粘り込んだ${second.number}番${second.name}（${second.popularity}番人気）、`;
          } else if (secondPosLast && secondPosLast.pos === 1) {
            // その他の先行馬が2着
            commentary += `2着には先行した${second.number}番${second.name}（${second.popularity}番人気）、`;
          } else if (secondPosLast) {
            // その他（位置取りあり）
            commentary += `2着には${secondPosLast.label}から伸びた${second.number}番${second.name}（${second.popularity}番人気）、`;
          } else {
            // 位置取りなし
            commentary += `2着には${second.number}番${second.name}（${second.popularity}番人気）、`;
          }

          // 3着馬の表現：逃げ馬かどうかで変更
          if (pacemaker && third.number === pacemaker.number) {
            commentary += `3着には逃げた${third.number}番${third.name}（${third.popularity}番人気）が入線。`;
          } else {
            commentary += `3着には${third.number}番${third.name}（${third.popularity}番人気）が入線。`;
          }
        } else if (second) {
          if (pacemaker && second.number === pacemaker.number) {
            commentary += `2着には粘り込んだ${second.number}番${second.name}（${second.popularity}番人気）が続いた。`;
          } else if (secondPosLast && secondPosLast.pos === 1) {
            commentary += `2着には先行した${second.number}番${second.name}（${second.popularity}番人気）が続いた。`;
          } else {
            commentary += `2着には${second.number}番${second.name}（${second.popularity}番人気）が続いた。`;
          }
        }

        // 三連単配当情報を追加（SEO対策）
        if (race.payouts?.sanrentan && race.payouts.sanrentan.length > 0) {
          const sanrentanPayout = race.payouts.sanrentan[0].payout;
          const sanrentanPop = race.payouts.sanrentan[0].popularity;
          const sanrentanCombo = race.payouts.sanrentan[0].combination;
          commentary += `三連単${sanrentanCombo}は${sanrentanPayout.toLocaleString()}円（${sanrentanPop}番人気）で決着した。`;
        }
      }
      // パターン3: 逃げ馬情報なし
      else {
        // 勝ち馬
        commentary += `${winner.number}番${winner.name}（`;
        if (winner.popularity === 1) {
          commentary += `1番人気`;
        } else {
          commentary += `${winner.popularity}番人気`;
        }
        commentary += `）が`;

        if (winnerPosLast) {
          commentary += `${winnerPosLast.label}から抜け出し、`;
        }

        if (winner.lastFurlong) {
          commentary += `上がり${winner.lastFurlong}秒の末脚で`;
        }
        commentary += `勝ちタイム${winner.time}で1着`;

        // 騎手・厩舎情報を追加（簡潔に、必ず句点で閉じる）
        commentary += `。鞍上は${winner.jockey}騎手と${winner.trainer}厩舎のコンビ。`;

        if (second && third) {
          commentary += `2着に${second.number}番${second.name}（${second.popularity}番人気）、3着に${third.number}番${third.name}（${third.popularity}番人気）が入線。`;
        } else if (second) {
          commentary += `2着には${second.number}番${second.name}（${second.popularity}番人気）が続いた。`;
        }

        // 三連単配当情報を追加（SEO対策）
        if (race.payouts?.sanrentan && race.payouts.sanrentan.length > 0) {
          const sanrentanPayout = race.payouts.sanrentan[0].payout;
          const sanrentanPop = race.payouts.sanrentan[0].popularity;
          const sanrentanCombo = race.payouts.sanrentan[0].combination;
          commentary += `三連単${sanrentanCombo}は${sanrentanPayout.toLocaleString()}円（${sanrentanPop}番人気）で決着した。`;
        }
      }

      // 高配当の場合は馬単も追加
      if (race.payouts?.umatan && race.payouts.umatan.length > 0) {
        const umatanPayout = race.payouts.umatan[0].payout;
        if (umatanPayout >= 10000) {
          commentary += `馬単は${umatanPayout.toLocaleString()}円の高配当となった。`;
        }
      }

      // 250文字を超える場合はトリミング（最後の句点で切る）
      if (commentary.length > 260) {
        const trimmed = commentary.substring(0, 250);
        const lastPeriod = trimmed.lastIndexOf('。');
        if (lastPeriod > 200) {
          commentary = trimmed.substring(0, lastPeriod + 1);
        }
      }

      return commentary;
    }

    // プレビュー表示
    function displayBatchPreview(results, date, venue) {
      const previewSection = document.getElementById('previewSection');
      const raceSummary = document.getElementById('raceSummary');
      const raceDetails = document.getElementById('raceDetails');

      const successResults = results.filter(r => r.success);
      const errorResults = results.filter(r => !r.success);

      // サマリー表示
      raceSummary.innerHTML = `
        <h3 style="margin-bottom: var(--spacing-md);">📊 解析サマリー</h3>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: var(--spacing-md);">
          <div style="padding: var(--spacing-md); background: rgba(16, 185, 129, 0.1); border-radius: var(--radius-md);">
            <div style="font-size: 2rem; font-weight: 700; color: var(--success);">${successResults.length}</div>
            <div style="color: var(--text-secondary);">成功</div>
          </div>
          <div style="padding: var(--spacing-md); background: rgba(239, 68, 68, 0.1); border-radius: var(--radius-md);">
            <div style="font-size: 2rem; font-weight: 700; color: var(--error);">${errorResults.length}</div>
            <div style="color: var(--text-secondary);">エラー</div>
          </div>
          <div style="padding: var(--spacing-md); background: rgba(59, 130, 246, 0.1); border-radius: var(--radius-md);">
            <div style="font-size: 2rem; font-weight: 700; color: var(--primary-end);">${results.length}</div>
            <div style="color: var(--text-secondary);">合計</div>
          </div>
        </div>
      `;

      // 各レースの詳細
      let detailsHTML = '';
      results.forEach(result => {
        const statusClass = result.success ? 'success' : 'error';
        const statusText = result.success ? '✅ 成功' : '❌ エラー';

        detailsHTML += `
          <details class="race-detail-card ${statusClass}">
            <summary class="race-detail-header">
              <span class="race-number-badge">第${result.raceNumber}R</span>
              <span class="race-status-badge ${statusClass}">${statusText}</span>
            </summary>
            <div class="race-detail-content">
              ${result.success ? generateRacePreviewHTML(result) : generateErrorHTML(result)}
            </div>
          </details>
        `;
      });

      raceDetails.innerHTML = detailsHTML;
      previewSection.style.display = 'block';
    }

