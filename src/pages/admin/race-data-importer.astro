---
import BaseLayout from "../../layouts/BaseLayout.astro";
export const prerender = false;
---

<BaseLayout title="レースデータ取込">
  <section class="admin-section">
    <h1>📊 レースデータ取込</h1>
    <p class="lead">pdftohtml -xml の出力XMLを貼り付けて解析・保存</p>

    <!-- 入力エリア -->
    <div class="input-block">
      <div class="form-row">
        <label for="raceDate">開催日</label>
        <input type="date" id="raceDate" />
      </div>
      <div class="form-row">
        <label for="trackName">競馬場（自動検出）</label>
        <input type="text" id="trackName" readonly placeholder="XMLから自動検出" />
      </div>
      <div class="form-row">
        <label for="xmlInput">データ貼り付け（XML / テキスト自動判定）</label>
        <textarea id="xmlInput" rows="8" placeholder="XML（pdftohtml出力）またはテキスト形式データを貼り付け"></textarea>
      </div>
      <button class="btn-primary" id="parseBtn" type="button">🔍 解析</button>
    </div>

    <!-- ステータス -->
    <div id="statusMessage" class="status-message" style="display:none"></div>

    <!-- プレビュー -->
    <div id="previewSection" style="display:none">
      <h2 id="raceTitle"></h2>
      <div id="raceAccordion"></div>
      <details style="margin-top:1rem">
        <summary>JSON出力</summary>
        <pre id="jsonPreview" class="json-pre"></pre>
      </details>
      <button class="btn-save" id="saveBtn" type="button">🚀 保存してGit Push</button>
    </div>
  </section>

  <style is:global>
    .admin-section { max-width: 1200px; margin: 2rem auto; padding: 0 1rem; color: #e2e8f0; }
    .admin-section h1 { text-align: center; margin-bottom: 0.25rem; color: #f1f5f9; }
    .lead { text-align: center; color: #94a3b8; margin-bottom: 2rem; }
    .input-block { background: #1e293b; border-radius: 8px; padding: 1.5rem; margin-bottom: 1.5rem; border: 1px solid #334155; }
    .form-row { margin-bottom: 1rem; }
    .form-row label { display: block; font-weight: 600; margin-bottom: 0.25rem; font-size: 0.9rem; color: #cbd5e1; }
    .form-row input[type="date"],
    .form-row input[type="text"] { padding: 0.5rem; border: 1px solid #475569; border-radius: 4px; font-size: 1rem; width: 250px; background: #0f172a; color: #f1f5f9; }
    .form-row textarea { width: 100%; padding: 0.5rem; border: 1px solid #475569; border-radius: 4px; font-family: monospace; font-size: 0.85rem; resize: vertical; background: #0f172a; color: #f1f5f9; }
    .btn-primary { background: #2563eb; color: #fff; border: none; padding: 0.75rem 2rem; border-radius: 6px; font-size: 1rem; font-weight: 600; cursor: pointer; }
    .btn-primary:hover { background: #1d4ed8; }
    .btn-save { background: #16a34a; color: #fff; border: none; padding: 0.75rem 2rem; border-radius: 6px; font-size: 1rem; font-weight: 600; cursor: pointer; margin-top: 1rem; }
    .btn-save:hover { background: #15803d; }
    .status-message { padding: 0.75rem 1rem; border-radius: 6px; margin-bottom: 1rem; font-weight: 500; }
    .status-success { background: rgba(22, 163, 74, 0.15); color: #4ade80; border: 1px solid #166534; }
    .status-error { background: rgba(220, 38, 38, 0.15); color: #f87171; border: 1px solid #991b1b; }
    .status-info { background: rgba(37, 99, 235, 0.15); color: #60a5fa; border: 1px solid #1e40af; }
    .table-wrap { overflow-x: auto; }
    .btn-save:disabled { background: #9ca3af; cursor: not-allowed; }
    .json-pre { background: #1e293b; color: #e2e8f0; padding: 1rem; border-radius: 6px; overflow-x: auto; font-size: 0.8rem; max-height: 400px; }
    #raceTitle { margin-top: 0; }
    /* アコーディオン */
    .race-accordion { border: 1px solid #334155; border-radius: 8px; margin-bottom: 0.75rem; overflow: hidden; }
    .race-accordion-header { background: #1e293b; color: #fff; padding: 0.6rem 1rem; cursor: pointer; font-weight: 600; display: flex; justify-content: space-between; align-items: center; }
    .race-accordion-header:hover { background: #334155; }
    .race-accordion-body { display: none; padding: 0; background: #0f172a; }
    .race-accordion-body.open { display: block; }
    /* レース情報カード */
    .race-info-card { background: #1e293b; padding: 0.8rem 1rem; margin: 0.5rem; border-radius: 6px; display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 0.5rem; font-size: 0.85rem; color: #cbd5e1; }
    .race-info-card dt { font-weight: 600; color: #94a3b8; font-size: 0.75rem; }
    .race-info-card dd { margin: 0; color: #f1f5f9; }
    /* 振り分けカード */
    .assign-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 0.5rem; padding: 0.5rem; }
    .assign-card { border-radius: 6px; padding: 0.5rem 0.75rem; }
    .assign-card .assign-label { font-weight: 700; font-size: 0.8rem; margin-bottom: 0.25rem; }
    .assign-card .assign-horse { font-size: 0.85rem; color: #e2e8f0; }
    .assign-list { list-style: none; padding: 0; margin: 0; font-size: 0.85rem; color: #e2e8f0; }
    .assign-list li { margin: 0.15rem 0; }
    .assign-honmei { background: linear-gradient(135deg, #dc2626 0%, #991b1b 100%); border-left: 3px solid #ef4444; }
    .assign-taikou { background: linear-gradient(135deg, #2563eb 0%, #1e40af 100%); border-left: 3px solid #3b82f6; }
    .assign-tanana { background: linear-gradient(135deg, #d97706 0%, #92400e 100%); border-left: 3px solid #f59e0b; }
    .assign-renkatop { background: linear-gradient(135deg, #0d9488 0%, #115e59 100%); border-left: 3px solid #14b8a6; }
    .assign-renka { background: #1e293b; border-left: 3px solid #64748b; }
    .assign-hoseki { background: #1e293b; border-left: 3px solid #475569; color: #94a3b8; }
    .assign-none { background: #0f172a; border-left: 3px solid #334155; color: #64748b; }
    /* 馬テーブル */
    .horse-table { width: 100%; border-collapse: collapse; font-size: 0.8rem; }
    .horse-table th { background: #1e293b; color: #94a3b8; padding: 0.35rem 0.5rem; text-align: left; font-weight: 600; font-size: 0.7rem; white-space: nowrap; position: sticky; top: 0; }
    .horse-table td { padding: 0.3rem 0.5rem; border-bottom: 1px solid #1e293b; color: #e2e8f0; white-space: nowrap; }
    .horse-table tbody tr:hover { background: #1e293b; }
    .horse-table .mark-cell span { display: inline-block; min-width: 1.2em; text-align: center; margin: 0 1px; font-size: 0.9em; }
    .assign-badge { display: inline-block; padding: 1px 6px; border-radius: 3px; font-size: 0.7rem; font-weight: 600; }
    .badge-honmei { background: #dc2626; color: #fff; }
    .badge-taikou { background: #2563eb; color: #fff; }
    .badge-tanana { background: #d97706; color: #fff; }
    .badge-renka { background: #475569; color: #e2e8f0; }
    .badge-hoseki { background: #334155; color: #94a3b8; }
    .badge-none { background: transparent; color: #64748b; }
    .badge-fuyo { background: #1c1917; color: #78716c; text-decoration: line-through; }
    .past-race { display: inline-block; font-size: 0.7rem; background: #1e293b; border-radius: 3px; padding: 1px 4px; margin: 1px 2px; white-space: nowrap; color: #94a3b8; }
    /* 馬カード */
    .horse-cards { padding: 0.5rem; display: flex; flex-direction: column; gap: 0.4rem; }
    .horse-card { background: #0f172a; border: 1px solid #1e293b; border-radius: 6px; padding: 0.5rem 0.75rem; }
    .horse-card.hcard-honmei { border-left: 3px solid #ef4444; background: rgba(239, 68, 68, 0.05); }
    .horse-card.hcard-taikou { border-left: 3px solid #3b82f6; background: rgba(59, 130, 246, 0.05); }
    .horse-card.hcard-tanana { border-left: 3px solid #f59e0b; background: rgba(245, 158, 11, 0.05); }
    .horse-card.hcard-renka { border-left: 3px solid #64748b; }
    .hcard-header { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.3rem; }
    .hcard-number { font-size: 1.1rem; font-weight: 800; color: #f1f5f9; min-width: 1.8rem; text-align: center; }
    .hcard-name { font-weight: 700; color: #f1f5f9; font-size: 0.95rem; flex: 1; }
    .hcard-score { font-size: 0.75rem; color: #94a3b8; font-weight: 600; }
    .hcard-details { display: flex; flex-wrap: wrap; gap: 0.5rem; font-size: 0.78rem; color: #94a3b8; margin-bottom: 0.25rem; }
    .hcard-marks { display: flex; gap: 2px; margin-bottom: 0.2rem; }
    .hcard-mark { display: inline-block; min-width: 1.3em; text-align: center; font-size: 0.9rem; color: #e2e8f0; }
    .hcard-past { margin-top: 0.2rem; }
  </style>

  <script is:inline>
    const DEBUG = false;

    const JRA_VENUE_CODES = {
      '東京':'TOK','中山':'NAK','京都':'KYO','阪神':'HAN',
      '中京':'CHU','新潟':'NII','福島':'FKS','小倉':'KOK',
      '札幌':'SAP','函館':'HKD'
    };

    const NANKAN_VENUE_CODES = {
      '大井':'OOI','川崎':'KAW','船橋':'FUN','浦和':'URA'
    };

    const LOCAL_VENUE_CODES = {
      '門別':'MON','盛岡':'MOR','水沢':'MIZ','金沢':'KNZ',
      '笠松':'KSM','名古屋':'NGY','園田':'SON','姫路':'HIM',
      '高知':'KOC','佐賀':'SAG','帯広':'OBI','ばんえい':'OBI'
    };

    const ALL_VENUE_CODES = { ...JRA_VENUE_CODES, ...NANKAN_VENUE_CODES, ...LOCAL_VENUE_CODES };

    let parsedData = null;

    document.getElementById('parseBtn').addEventListener('click', runParse);
    document.getElementById('saveBtn').addEventListener('click', saveData);

    // ========== メイン解析 ==========
    function runParse() {
      hideStatus();
      document.getElementById('previewSection').style.display = 'none';

      const inputText = document.getElementById('xmlInput').value.trim();
      if (!inputText) { showStatus('データを貼り付けてください', 'error'); return; }

      try {
        // 自動判定: XML or テキスト
        const isXml = /^<\?xml|^<pdf2xml/i.test(inputText);
        const results = isXml ? parseAllRaces(inputText) : parseTextFormat(inputText);
        if (!results || results.length === 0) { showStatus('レースデータを検出できませんでした', 'error'); return; }

        document.getElementById('trackName').value = results[0].raceInfo.track || '';

        // 日付自動セット: 最優先=XML/テキスト抽出 > 8桁日付 > 既存入力 > 今日(ローカル)
        // XML/テキストから検出した場合は既存入力を上書き
        if (results._headerDate) {
          document.getElementById('raceDate').value = results._headerDate;
          console.log(`[Import] 日付セット(データ検出): ${results._headerDate}`);
        } else {
          // フォールバック: 入力テキストからファイル名風8桁日付を抽出
          const inputText8 = document.getElementById('xmlInput').value;
          const fn8Match = inputText8.match(/(\d{4})(0[1-9]|1[0-2])(0[1-9]|[12]\d|3[01])/);
          if (fn8Match) {
            const fn8Date = `${fn8Match[1]}-${fn8Match[2]}-${fn8Match[3]}`;
            document.getElementById('raceDate').value = fn8Date;
            console.log(`[Import] 日付セット(8桁フォールバック): ${fn8Date}`);
          } else if (!document.getElementById('raceDate').value) {
            // 最終フォールバック: ローカル今日（UTCのtoISOStringは使わない）
            const now = new Date();
            const todayStr = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}-${String(now.getDate()).padStart(2,'0')}`;
            document.getElementById('raceDate').value = todayStr;
            console.log(`[Import] 日付セット(今日フォールバック): ${todayStr}`);
          }
        }

        const raceDateValue = document.getElementById('raceDate').value;
        console.log('[Import] 使用開催日:', raceDateValue);

        parsedData = buildJSON(results);
        renderPreview(results);
        document.getElementById('previewSection').style.display = 'block';
        document.getElementById('previewSection').scrollIntoView({ behavior: 'smooth' });
        const totalHorses = results.reduce((s, r) => s + r.horses.length, 0);
        console.log(`[Import] 解析完了: ${results.length}R ${totalHorses}頭`);
        showStatus(`✅ ${results.length}レース・${totalHorses}頭を検出`, 'success');

        // コンピ指数の自動補完を試行
        tryEnrichWithCompi(results);
      } catch (e) {
        console.error('[Import] 解析エラー:', e);
        showStatus('解析エラー: ' + e.message, 'error');
      }
    }

    // ========== XMLパーサー（全レース） ==========
    function parseAllRaces(xmlText) {
      const pageRegex = /<page\s+number="(\d+)"[^>]*>([\s\S]*?)<\/page>/g;
      const results = [];
      let match;

      while ((match = pageRegex.exec(xmlText)) !== null) {
        const pageNum = +match[1];
        const pageXml = match[2];

        try {
          const race = parseSinglePage(pageXml, pageNum);
          if (race) results.push(race);
        } catch (e) {
          console.warn(`[Import] ${pageNum}R スキップ:`, e.message);
        }
      }

      // XML内から日付を検出して付与
      if (results.length > 0) {
        const detectedDate = detectDateFromXml(xmlText);
        if (detectedDate) {
          results._headerDate = detectedDate;
          console.log(`[Import] XML日付検出: ${detectedDate}`);
        }
      }

      return results;
    }

    // XML全体から開催日を文字列ベースで抽出（Dateオブジェクト不使用）
    function detectDateFromXml(xmlText) {
      // 先頭ページのテキスト要素をtop順で抽出（日付はページ上部にある）
      const firstPageMatch = xmlText.match(/<page\s+number="1"[^>]*>([\s\S]*?)<\/page>/);
      const searchXml = firstPageMatch ? firstPageMatch[1] : xmlText;

      const elRe = /<text\s+top="(-?\d+)"\s+left="(\d+)"\s+width="(\d+)"\s+height="(\d+)"[^>]*>([\s\S]*?)<\/text>/g;
      let m;
      const topEls = [];
      while ((m = elRe.exec(searchXml)) !== null) {
        const top = +m[1];
        if (top <= 150) {
          topEls.push({
            top, left: +m[2], width: +m[3], height: +m[4],
            text: m[5].replace(/&lt;/g,'<').replace(/&gt;/g,'>').replace(/&amp;/g,'&')
          });
        }
      }
      topEls.sort((a, b) => a.top - b.top || a.left - b.left);

      // デバッグ: 上部テキスト要素を全出力
      console.log('[Import] XML日付候補(上部テキスト):', topEls.map(e => `[top=${e.top},left=${e.left}] "${e.text}"`).join(' / '));

      // PDF由来XMLではテキストが1文字ずつ分割されることがある
      // 近接する要素を結合してからパターンマッチ
      const merged = mergeNearbyTexts(topEls);
      console.log('[Import] XML日付候補(結合後):', merged.map(e => `[top=${e.top}] "${e.text}"`).join(' / '));

      const now = new Date();
      const currentYear = now.getFullYear();

      for (const t of merged.map(e => e.text)) {
        // パターン1: 「2026年4月11日」「2026年04月11日」
        const ym = t.match(/(\d{4})\s*年\s*(\d{1,2})\s*月\s*(\d{1,2})\s*日/);
        if (ym) return `${ym[1]}-${String(ym[2]).padStart(2,'0')}-${String(ym[3]).padStart(2,'0')}`;

        // パターン2: 「4月11日」「04月11日」（年なし）
        const md = t.match(/(\d{1,2})\s*月\s*(\d{1,2})\s*日/);
        if (md) return `${currentYear}-${String(md[1]).padStart(2,'0')}-${String(md[2]).padStart(2,'0')}`;

        // パターン3: 「2026/4/11」「2026-04-11」
        const full = t.match(/(\d{4})[\/\-](\d{1,2})[\/\-](\d{1,2})/);
        if (full) return `${full[1]}-${String(full[2]).padStart(2,'0')}-${String(full[3]).padStart(2,'0')}`;

        // パターン4: 「4/11」「04/11」（月/日のみ、文字列中でもOK）
        const sd = t.match(/(\d{1,2})\/(\d{1,2})/);
        if (sd) return `${currentYear}-${String(sd[1]).padStart(2,'0')}-${String(sd[2]).padStart(2,'0')}`;
      }

      // パターン5: 入力テキスト全体からファイル名風8桁日付を検出
      const fnMatch = xmlText.match(/(\d{4})(0[1-9]|1[0-2])(0[1-9]|[12]\d|3[01])/);
      if (fnMatch) {
        const candidate = `${fnMatch[1]}-${fnMatch[2]}-${fnMatch[3]}`;
        console.log(`[Import] XML日付: ファイル名風8桁から検出: ${candidate}`);
        return candidate;
      }

      return null;
    }

    // 近接テキスト要素を結合（PDF由来XMLの1文字分割対策）
    function mergeNearbyTexts(els) {
      if (els.length === 0) return [];
      const result = [];
      let current = { top: els[0].top, text: els[0].text };

      for (let i = 1; i < els.length; i++) {
        const el = els[i];
        // 同一行（top差5以内）なら結合
        if (Math.abs(el.top - current.top) <= 5) {
          current.text += el.text;
        } else {
          result.push(current);
          current = { top: el.top, text: el.text };
        }
      }
      result.push(current);
      return result;
    }

    function parseSinglePage(pageXml, raceNumber) {
      const elements = extractTextElements(pageXml);
      if (elements.length < 20) return null;

      const labels = findLabels(elements);
      if (!labels) return null;

      const raceInfo = extractRaceInfo(elements, labels);
      console.log(`[Import] ${raceNumber}R: distance="${raceInfo.distance || '未取得'}", track="${raceInfo.track || '未取得'}", class="${raceInfo.raceClass || '未取得'}"`);

      const colBases = findHorseColumns(elements, labels);
      if (colBases.length === 0) return null;

      if (DEBUG) console.log(`[Import] ${raceNumber}R: ${colBases.length}頭`);

      const horses = [];
      for (let i = 0; i < colBases.length; i++) {
        const colLeft = colBases[i];
        const colRight = (i === 0) ? labels.labelLeft : colBases[i - 1];
        const horse = extractHorse(elements, labels, colLeft, colRight, i + 1);
        horses.push(horse);
      }

      return { raceNumber, raceInfo, horses, predictorNames: labels.predictors.map(p => p.name) };
    }

    function extractTextElements(xml) {
      const re = /<text\s+top="(-?\d+)"\s+left="(\d+)"\s+width="(\d+)"\s+height="(\d+)"\s+font="(\d+)">([\s\S]*?)<\/text>/g;
      const els = [];
      let m;
      while ((m = re.exec(xml)) !== null) {
        els.push({
          top: +m[1], left: +m[2], width: +m[3], height: +m[4], font: +m[5],
          text: m[6].replace(/&lt;/g,'<').replace(/&gt;/g,'>').replace(/&amp;/g,'&')
        });
      }
      return els;
    }

    // ========== ラベル検出 ==========
    function findLabels(elements) {
      const ninkiEl = elements.find(e => e.text.replace(/\s/g,'').includes('人気指数'));
      if (!ninkiEl) return null;
      const labelLeft = ninkiEl.left;

      const jockeyEl = elements.find(e => e.left >= labelLeft && e.text.replace(/\s/g,'').includes('重量騎手'));
      if (!jockeyEl) return null;

      const lab = {
        labelLeft,
        computerIndexTop: ninkiEl.top,
        weightJockeyTop: jockeyEl.top,
        trainerTop: null,
        ownerTop: null,
        breederTop: null,
        oddsTop: null,
        commentTop: null,
        predictors: []
      };

      for (const el of elements) {
        if (el.left < labelLeft) continue;
        const t = el.text.replace(/\s/g,'');
        if (t === '厩' && el.left === labelLeft) lab.trainerTop = el.top;
        if (t === '馬' && el.left === labelLeft && el.top > 300 && el.top < 320) lab.ownerTop = el.top;
        if (t.includes('生産者')) lab.breederTop = el.top;
        if (t.includes('単予想オッズ')) lab.oddsTop = el.top;
        if (t === '短' && el.left === labelLeft && el.top > 900) lab.commentTop = el.top;
      }

      for (const el of elements) {
        if (el.left !== labelLeft) continue;
        if (el.top > lab.computerIndexTop + 5 && el.top < lab.weightJockeyTop - 5 && el.height <= 12) {
          lab.predictors.push({ name: el.text.replace(/\s/g,''), top: el.top });
        }
      }
      lab.predictors.sort((a, b) => a.top - b.top);

      return lab;
    }

    // ========== 馬カラム検出 ==========
    function findHorseColumns(elements, labels) {
      const anchorRows = [labels.weightJockeyTop, labels.ownerTop, labels.breederTop].filter(Boolean);
      const allLefts = [];

      for (const rowTop of anchorRows) {
        const candidates = elements.filter(e =>
          Math.abs(e.top - rowTop) <= 3 &&
          e.left < labels.labelLeft - 5 &&
          e.width > 0 &&
          e.text.trim().length >= 2
        );
        for (const c of candidates) allLefts.push(c.left);
      }

      allLefts.sort((a, b) => b - a);
      const unique = [];
      for (const b of allLefts) {
        if (unique.length === 0 || unique[unique.length - 1] - b > 15) {
          unique.push(b);
        }
      }
      return unique;
    }

    // ========== レース情報 ==========
    function extractRaceInfo(elements, labels) {
      let track = '', distance = '', raceClass = '', conditions = '';

      const trackEl = elements.find(e => e.height >= 20 && e.height <= 30 && e.top >= 0 && e.top <= 15 && e.text.trim());
      if (trackEl) track = trackEl.text.trim();

      // 距離検出: レース条件欄（ページ上部 top<=120）に限定し、説明文を除外
      // 除外ワード: 標高・直線・中間・海抜など距離でない「㍍」表記
      const DIST_EXCLUDE_RE = /標高|直線|中間|海抜|地上|走路/;

      // 優先1: ページ上部で「㍍」を含み、除外ワードを含まないもの
      const distEl = elements.find(e =>
        e.top >= 0 && e.top <= 120 &&
        e.text.includes('㍍') &&
        !DIST_EXCLUDE_RE.test(e.text)
      );
      if (distEl) {
        distance = distEl.text.trim();
      } else {
        // フォールバック1: ページ上部の「1200m」「1600ｍ」等
        const distElAlt = elements.find(e =>
          e.top >= 0 && e.top <= 120 &&
          /\d{3,5}\s*[mｍ㍍]/.test(e.text) &&
          !DIST_EXCLUDE_RE.test(e.text)
        );
        if (distElAlt) {
          distance = distElAlt.text.trim();
        } else {
          // フォールバック2: 「ダート1400」「芝2000」「ダ1200」等
          const distElSurface = elements.find(e =>
            e.top >= 0 && e.top <= 120 &&
            /(?:ダート?|芝|障害?)\s*\d{3,5}/.test(normPUA(e.text))
          );
          if (distElSurface) {
            distance = normPUA(distElSurface.text).trim();
          } else {
            // フォールバック3: ページ全体から「㍍」を含み除外ワードなしの最初の要素
            const distElWide = elements.find(e =>
              e.text.includes('㍍') &&
              !DIST_EXCLUDE_RE.test(e.text) &&
              /\d{3,5}/.test(e.text)
            );
            if (distElWide) {
              distance = distElWide.text.trim();
            }
          }
        }
      }
      console.log(`[Import] distance抽出: "${distance}" (元テキスト: "${distEl ? distEl.text : '㍍要素なし'}")`);

      const classEls = elements.filter(e => e.height >= 30 && e.height <= 40 && e.width === 0 && e.text.trim());
      classEls.sort((a, b) => a.top - b.top);
      raceClass = classEls.map(e => e.text.trim()).join('');

      const condStart = elements.find(e => e.text.trim() === '(' && e.top > 300 && e.top < 420 && e.left >= labels.labelLeft - 60);
      if (condStart) {
        const condText = elements.filter(e =>
          e.top > condStart.top && e.top < condStart.top + 40 &&
          Math.abs(e.left - condStart.left) < 8 &&
          e.text.trim() !== '(' && e.text.trim() !== ')'
        );
        conditions = condText.map(e => e.text.trim()).join('');
      }

      return { track, distance, raceClass, conditions };
    }

    // ========== 馬データ抽出 ==========
    function extractHorse(elements, labels, colLeft, colRight, horseNum) {
      const inCol = (e) => e.left >= colLeft - 2 && e.left < colRight;

      // 馬名
      const nameEls = elements.filter(e =>
        inCol(e) && e.width === 0 && e.height >= 13 && e.top >= 5 && e.top < 90 && e.text.trim()
      );
      nameEls.sort((a, b) => b.height - a.height);
      const name = nameEls.length > 0 ? nameEls[0].text.trim() : '';

      // 父
      const sireEls = elements.filter(e =>
        inCol(e) && e.width === 0 && e.height >= 5 && e.height <= 10 && e.top >= 15 && e.top <= 35 && e.text.trim()
      );
      sireEls.sort((a, b) => b.left - a.left);
      const sire = sireEls.length > 0 ? sireEls[0].text.trim() : '';

      // 性齢
      const sexAgeEl = elements.find(e =>
        inCol(e) && e.width === 0 && e.top >= 80 && e.top <= 100 && e.text.trim()
      );
      let sexAge = sexAgeEl ? sexAgeEl.text.trim() : '';
      const sexAgeClean = sexAge.replace(/[□⬅→↑↓\s]/g, '').slice(0, 2);

      // 重量・騎手
      const jkEl = elements.find(e =>
        Math.abs(e.top - labels.weightJockeyTop) <= 3 &&
        inCol(e) && e.width > 0 &&
        /^\d{2}[^\d]/.test(e.text.trim())
      );
      let weight = '', jockey = '';
      if (jkEl) {
        const jkText = jkEl.text.trim().replace(/[△▲○◎☆×]/g, '');
        const wm = jkText.match(/^(\d{2})\s*([\u3000-\u9FFFa-zA-Z\s]+)/);
        if (wm) { weight = wm[1]; jockey = wm[2].replace(/\s+/g, '').trim(); }
      }

      // 厩舎
      let trainer = '';
      if (labels.trainerTop) {
        const trEls = elements.filter(e =>
          Math.abs(e.top - labels.trainerTop) <= 3 && inCol(e) &&
          e.width >= 25 && e.text.trim()
        );
        if (trEls.length > 0) {
          trainer = trEls[0].text.trim();
        } else {
          const trFallback = elements.filter(e =>
            Math.abs(e.top - labels.trainerTop) <= 3 && inCol(e) &&
            e.width >= 10 && e.text.trim().length >= 2
          );
          if (trFallback.length > 0) trainer = trFallback[0].text.trim();
        }
      }

      // 人気指数
      let computerIndex = '';
      const idxEls = elements.filter(e =>
        Math.abs(e.top - labels.computerIndexTop) <= 3 &&
        inCol(e) && e.width > 0 && e.width <= 25 && e.text.trim()
      );
      if (idxEls.length > 0) {
        let raw = idxEls[0].text.trim();
        raw = raw.replace(/[０-９]/g, c => String.fromCharCode(c.charCodeAt(0) - 0xFEE0));
        raw = raw.replace(/[\uE000-\uF8FF]/g, '');
        computerIndex = raw;
      }

      // 印
      const MARK_CHARS = /[◎○▲△☆★×✕注穴①②③④⑤⑥⑦⑧⑨⑩⑪⑫⑬⑭⑮⑯⑰⑱]/;
      const MARK_STD = /[◎○▲△☆★×✕注穴]/;
      // ========== PUA文字→印マッピング表 ==========
      // JRA競馬新聞PDF由来のフォント埋め込み印記号
      // ◎はPUAから直接生成せず、スコア1位+順位+コンピで後段生成
      //   EC9E: 出現頻度 低 → ○（対抗級）
      //   EC9D: 出現頻度 高 → △（連下級）
      // ☆(U+2606)はPUAではなく直接Unicode → MARK_STDで処理
      const PUA_MARK_MAP = {
        '\uEC9E': '○',  // 低頻度PUA → ○対抗級
        '\uEC9D': '△',  // 高頻度PUA → △連下級
      };
      // 罫線・装飾・ランキング用PUA（印ではない）
      const isBlankDecoPUA = (ch) => {
        const cp = ch.charCodeAt(0);
        return cp === 0xE412 || cp === 0xE04F ||
               (cp >= 0xED00 && cp <= 0xEDFF) || cp === 0xFF22;
      };
      const marks = [];
      let ranking = 0; // 本紙順位（丸数字 ①=1, ②=2, ...）

      // 印領域の全要素を取得（デバッグ + PUA検出用）
      const markRegionEls = elements.filter(e =>
        e.top > labels.computerIndexTop + 1 &&
        e.top < labels.weightJockeyTop - 3 &&
        inCol(e) &&
        e.text.trim()
      );

      if (horseNum === 1) {
        console.log(`[Import] 印領域 (top ${labels.computerIndexTop}〜${labels.weightJockeyTop}, predictors: ${labels.predictors.length}名):`);
        // PUA文字の出現頻度カウント（◎候補の低頻度PUA検出用）
        const puaFreq = {};
        for (const e of markRegionEls) {
          for (const ch of e.text.trim()) {
            const cp = ch.charCodeAt(0);
            if (cp >= 0xE000 && cp <= 0xF8FF) {
              const hex = 'U+' + cp.toString(16).toUpperCase().padStart(4, '0');
              puaFreq[hex] = (puaFreq[hex] || 0) + 1;
            }
          }
        }
        const puaSummary = Object.entries(puaFreq).sort((a,b) => b[1] - a[1]).map(([k,v]) => `${k}:${v}`).join(' ');
        console.log(`[Import] #1 PUA頻度: ${puaSummary}`);
      }

      // 印フィルタ: width制限を緩和（<=5 → <=12）+ PUA文字も候補に含める
      const markEls = markRegionEls.filter(e => {
        if (e.width > 12) return false;
        const txt = e.text.trim();
        if (MARK_CHARS.test(txt)) return true;
        if (/[\uE000-\uF8FF]/.test(txt)) return true;
        if (txt === '…' || txt === '‥') return true;
        return false;
      });

      const markRows = groupByTop(markEls, 4);
      for (const row of markRows) {
        row.sort((a, b) => a.left - b.left);

        let markFound = '';
        for (const e of row) {
          const txt = e.text.trim();
          if (!txt || txt === '…' || txt === '‥') continue;

          const firstChar = txt.charAt(0);

          // 罫線・装飾PUAはスキップ
          if (isBlankDecoPUA(firstChar)) continue;

          // PUAマッピング適用（EC9E→◎, EC9D→○）
          if (PUA_MARK_MAP[firstChar]) {
            markFound = PUA_MARK_MAP[firstChar];
            break;
          }

          // 通常の印文字（◎○▲△☆★× 等）
          const stdMatch = txt.match(MARK_STD);
          if (stdMatch) {
            markFound = stdMatch[0];
            break;
          }

          // 丸数字 → 本紙順位として記録（印スコアには含めない）
          const circledMatch = txt.match(/[①②③④⑤⑥⑦⑧⑨⑩⑪⑫⑬⑭⑮⑯⑰⑱]/);
          if (circledMatch) {
            ranking = CIRCLED_NUMS.indexOf(circledMatch[0]) + 1;
            continue;
          }

          // 未知のPUA文字 → △として救済（ログ出力）
          if (/[\uE000-\uF8FF]/.test(firstChar)) {
            markFound = '△';
            if (horseNum <= 3) {
              console.log(`[Import] 未知PUA→△: U+${firstChar.charCodeAt(0).toString(16).toUpperCase()} (horse#${horseNum}, font=${e.font})`);
            }
            break;
          }
        }

        if (markFound) marks.push(markFound);
      }

      if (horseNum <= 3) {
        const markCounts = {};
        marks.forEach(m => { markCounts[m] = (markCounts[m] || 0) + 1; });
        const markSummary = Object.entries(markCounts).map(([k,v]) => `${k}×${v}`).join(' ');
        console.log(`[Import] #${horseNum} ${name}: marks=[${marks.join(',')}] 内訳: ${markSummary || 'なし'} 順位:${ranking || '-'} (rows=${markRows.length})`);
      }

      // 単予想オッズ
      let odds = '';
      if (labels.oddsTop) {
        const oddsEls = elements.filter(e =>
          Math.abs(e.top - labels.oddsTop) <= 5 && inCol(e) && e.text.trim()
        );
        const numEl = oddsEls.find(e => /[\d.０-９]/.test(e.text));
        if (numEl) odds = numEl.text.trim();
      }

      // 短評
      let comment = '';
      if (labels.commentTop) {
        const cmtEl = elements.find(e =>
          Math.abs(e.top - labels.commentTop) <= 3 && inCol(e) && e.width > 0 && e.text.trim()
        );
        if (cmtEl) comment = cmtEl.text.trim();
      }

      // 近走成績
      let pastRaces = [];
      try {
        pastRaces = extractPastRaces(elements, colLeft, colRight, labels);
      } catch (e) {
        console.warn(`[Import] #${horseNum} 近走抽出エラー:`, e.message);
      }

      // 今回調教
      let training = null;
      try {
        training = extractTraining(elements, colLeft, colRight, labels);
      } catch (e) {
        console.warn(`[Import] #${horseNum} 調教抽出エラー:`, e.message);
      }

      if (DEBUG && horseNum === 1) {
        console.log(`[Import] #${horseNum} ${name}: pastRaces=${pastRaces.length}件`);
      }

      return {
        number: horseNum,
        name, sire, sexAge: sexAgeClean, weight, jockey, trainer,
        computerIndex, marks, ranking, predictorCount: labels.predictors.length,
        odds, comment, pastRaces, training
      };
    }

    // ========== 丸数字→通常数字変換 ==========
    const CIRCLED_NUMS = '①②③④⑤⑥⑦⑧⑨⑩⑪⑫⑬⑭⑮⑯⑰⑱';
    const CIRCLED_RE = /[①②③④⑤⑥⑦⑧⑨⑩⑪⑫⑬⑭⑮⑯⑰⑱]/;

    function circledToNum(ch) {
      const idx = CIRCLED_NUMS.indexOf(ch);
      return idx >= 0 ? String(idx + 1) : '';
    }

    // ========== PDF特殊グリフ正規化 ==========
    function normPUA(s) {
      if (!s) return '';
      return s
        .replace(/[\uE000-\uF8FF]/g, '')
        .replace(/[\x00-\x08\x0B\x0C\x0E-\x1F]/g, '')
        .replace(/\s{2,}/g, ' ')
        .trim();
    }

    function normTime(s) {
      if (!s) return null;
      const cleaned = normPUA(s);
      const m = cleaned.match(/^([外内]?\d[\d.:]+)$/);
      return m ? m[1] : (cleaned || null);
    }

    // ========== 着順抽出（多段フォールバック） ==========
    function extractFinish(raceClass, paceText, blockEls, vTop) {
      const classClean = raceClass.replace(/[\uE000-\uF8FF]/g, '').trim();
      if (classClean.length > 0 && CIRCLED_RE.test(classClean.charAt(0))) {
        return { finish: circledToNum(classClean.charAt(0)), source: 'raceClass' };
      }

      const m2 = paceText.match(CIRCLED_RE);
      if (m2) {
        return { finish: circledToNum(m2[0]), source: 'paceText' };
      }

      for (const el of blockEls) {
        if (el.top > vTop + 5 && el.top < vTop + 20) {
          const cleaned = el.text.replace(/[\uE000-\uF8FF\s]/g, '').trim();
          if (cleaned.length === 1 && CIRCLED_RE.test(cleaned)) {
            return { finish: circledToNum(cleaned), source: 'blockCircled' };
          }
        }
      }

      return { finish: '?', source: 'none' };
    }

    // ========== ペース分解 ==========
    function parsePace(paceText) {
      const cleaned = normPUA(paceText);
      const paceTypeMap = { 'Ｓ': 'S', 'Ｍ': 'M', 'Ｈ': 'H', 'S': 'S', 'M': 'M', 'H': 'H' };
      let paceType = null, paceRank = null, final3F = null;

      const typeMatch = cleaned.match(/^[ＳＭＨSMH]/);
      if (typeMatch) paceType = paceTypeMap[typeMatch[0]] || typeMatch[0];

      const rankMatch = cleaned.match(CIRCLED_RE);
      if (rankMatch) paceRank = parseInt(circledToNum(rankMatch[0])) || null;

      const f3Match = cleaned.match(/(\d{2}\.\d)/);
      if (f3Match) final3F = f3Match[1];

      return { paceType, paceRank, final3F };
    }

    function normCourseNote(raw) {
      const cleaned = normPUA(raw);
      if (/^[A-ZＡ-Ｚ坂芝ダ]/.test(cleaned) && cleaned.length >= 2) return cleaned;
      return null;
    }

    // ========== 近走成績抽出（可変長、最大6件） ==========
    const MAX_PAST_RACES = 6;

    function extractPastRaces(elements, colLeft, colRight, labels) {
      const inCol = (e) => e.left >= colLeft - 2 && e.left < colRight;

      const VENUE_RE = /^\d[東中京阪小新福札函]/;
      const venueEls = elements.filter(e =>
        inCol(e) && e.top >= 400 && e.top <= 870 &&
        e.width >= 25 && e.width <= 40 &&
        VENUE_RE.test(e.text.trim())
      ).sort((a, b) => a.top - b.top);

      if (venueEls.length === 0) return [];

      const races = [];
      for (let i = 0; i < venueEls.length; i++) {
        const vTop = venueEls[i].top;
        const venue = venueEls[i].text.trim();
        const nextVTop = (i + 1 < venueEls.length) ? venueEls[i + 1].top : vTop + 95;

        const blockEls = elements.filter(e =>
          inCol(e) && e.top >= vTop - 2 && e.top < nextVTop - 5
        );

        const classEl = blockEls.find(e => e.top > vTop + 5 && e.top < vTop + 18);
        const raceClass = classEl ? classEl.text.trim() : '';

        const condEl = blockEls.find(e =>
          e.top > vTop + 15 && e.top < vTop + 25 && e.width >= 10 && e.width <= 20
        );
        const cond = condEl ? condEl.text.trim() : '';

        // 距離抽出: 近走ブロック内から「ダ1400」「芝2000」等のパターンを検出
        let distance = null;
        const DIST_RE = /[ダ芝障](\d{3,5})/;
        for (const e of blockEls) {
          if (e.top > vTop + 5 && e.top < vTop + 30) {
            const dm = normPUA(e.text).match(DIST_RE);
            if (dm) {
              distance = normPUA(e.text).match(/[ダ芝障]\d{3,5}/)[0];
              break;
            }
          }
        }
        if (!distance && DEBUG) console.warn(`[Import] 近走distance未取得 (vTop=${vTop}, texts: ${blockEls.filter(e => e.top > vTop + 5 && e.top < vTop + 30).map(e => e.text.trim()).join('|')})`);

        const courseEl = blockEls.find(e =>
          e.top > vTop + 15 && e.top < vTop + 25 && e.left > colLeft + 10 && /[A-ZＡ-Ｚ坂芝ダ]/.test(e.text)
        );
        const courseRatingRaw = courseEl ? courseEl.text.trim() : '';

        const timeEl = blockEls.find(e =>
          e.top > vTop + 24 && e.top < vTop + 36 && e.width >= 30 && /\d/.test(e.text)
        );
        const timeRaw = timeEl ? timeEl.text.trim() : '';

        const jkEl = blockEls.find(e =>
          e.top > vTop + 33 && e.top < vTop + 45 && e.width >= 30 && /\d{2}/.test(e.text)
        );
        let rWeight = null, rJockey = null;
        if (jkEl) {
          const m = jkEl.text.trim().match(/^(\d{2})(.*)/);
          if (m) { rWeight = m[1]; rJockey = normPUA(m[2]).replace(/\s+/g, '') || null; }
        }

        const wtEl = blockEls.find(e =>
          e.top > vTop + 43 && e.top < vTop + 55 && e.width >= 30 && /\d{3}/.test(e.text.trim())
        );
        const bodyWeight = wtEl ? normPUA(wtEl.text).replace(/^\s+/, '') : null;
        const bodyWeightNum = bodyWeight ? parseInt(bodyWeight.match(/\d{3}/)?.[0]) || null : null;

        const paceEls = blockEls.filter(e => e.top > vTop + 52 && e.top < vTop + 66);
        const paceText = paceEls.map(e => e.text.trim()).filter(t => t).join('');

        const winnerEl = blockEls.find(e =>
          e.top > vTop + 68 && e.top < vTop + 83 && e.width >= 30 && e.text.trim().length >= 2
        );
        const winnerRaw = winnerEl ? winnerEl.text.trim() : '';

        const { finish } = extractFinish(raceClass, paceText, blockEls, vTop);
        const { paceType, paceRank, final3F } = parsePace(paceText);
        const courseNote = normCourseNote(courseRatingRaw);

        races.push({
          venue: normPUA(venue),
          raceClass: normPUA(raceClass),
          finish,
          cond: normPUA(cond),
          courseNote,
          distance: distance || null,
          time: normTime(timeRaw),
          weight: rWeight,
          jockey: rJockey,
          bodyWeight: bodyWeightNum,
          paceType,
          paceRank,
          final3F,
          winner: normPUA(winnerRaw) || null
        });
      }

      // 新しい順（top昇順=直近が先）で最大MAX_PAST_RACES件
      return races.slice(0, MAX_PAST_RACES);
    }

    // ========== 今回調教抽出 ==========
    function extractTraining(elements, colLeft, colRight, labels) {
      const inCol = (e) => e.left >= colLeft - 2 && e.left < colRight;
      const base = labels.oddsTop || 938;

      let training4F = null, trainingCourse = null, training3F = null, training1F = null;
      let trainingGrade = null, trainingStyle = null;

      const f4El = elements.find(e =>
        inCol(e) && e.top > base + 10 && e.top < base + 20 && e.width >= 25 && /\d/.test(e.text)
      );
      if (f4El) {
        const m = normPUA(f4El.text).match(/4F([\d.]+)/);
        if (m) training4F = m[1];
      }

      const f3El = elements.find(e =>
        inCol(e) && e.top > base + 19 && e.top < base + 30 && e.width >= 25 && /\d/.test(e.text)
      );
      if (f3El) {
        const raw = normPUA(f3El.text);
        const m = raw.match(/^(.+?)([\d.]+)$/);
        if (m) { trainingCourse = m[1]; training3F = m[2]; }
      }

      const f1El = elements.find(e =>
        inCol(e) && e.top > base + 38 && e.top < base + 48 && e.width >= 25 && /\d/.test(e.text)
      );
      if (f1El) {
        const m = normPUA(f1El.text).match(/([\d.]+)/);
        if (m) training1F = m[1];
      }

      const gradeEl = elements.find(e =>
        inCol(e) && e.top > base + 2 && e.top < base + 12 && e.width === 0
      );
      if (gradeEl) trainingGrade = normPUA(gradeEl.text) || null;

      const styleEl = elements.find(e =>
        inCol(e) && e.top > base + 20 && e.top < base + 30 && e.width === 0
      );
      if (styleEl) {
        const raw = normPUA(styleEl.text);
        if (raw) trainingStyle = raw;
      }

      if (!training4F && !training3F && !training1F) return null;

      return { training4F, trainingCourse, training3F, training1F, trainingGrade, trainingStyle };
    }

    // top値でグルーピング
    function groupByTop(elements, tolerance) {
      if (!elements.length) return [];
      const sorted = [...elements].sort((a, b) => a.top - b.top);
      const groups = [[sorted[0]]];
      for (let i = 1; i < sorted.length; i++) {
        const last = groups[groups.length - 1];
        if (sorted[i].top - last[0].top <= tolerance) {
          last.push(sorted[i]);
        } else {
          groups.push([sorted[i]]);
        }
      }
      return groups;
    }

    // ========== テキスト形式パーサー（南関等） ==========
    function parseTextFormat(text) {
      // 区切り線を除去
      const rawLines = text.split('\n');
      const lines = rawLines.filter(l => !/^[\s\u3000]*={3,}.*={3,}[\s\u3000]*$/.test(l));

      // 1行目からヘッダ情報を取得（"4/8　川崎競馬" 等）
      let headerTrack = '';
      let headerDate = null;
      const headerLine = lines[0] || '';
      const hm = headerLine.match(/(大井|川崎|船橋|浦和|門別|盛岡|水沢|金沢|笠松|名古屋|園田|姫路|高知|佐賀|帯広|東京|中山|京都|阪神|中京|新潟|福島|小倉|札幌|函館)/);
      if (hm) headerTrack = hm[1];
      // 日付: "4/8" or "12/25" パターン
      const dateMatch = headerLine.match(/(\d{1,2})\/(\d{1,2})/);
      if (dateMatch) {
        const now = new Date();
        const y = now.getFullYear();
        const m = String(dateMatch[1]).padStart(2, '0');
        const d = String(dateMatch[2]).padStart(2, '0');
        headerDate = `${y}-${m}-${d}`;
      }

      // レース分割: "XR " で始まる行をレースヘッダーとする
      const raceBlocks = [];
      let currentBlock = null;

      for (let i = 0; i < lines.length; i++) {
        const line = lines[i].trim();
        const rm = line.match(/^(\d{1,2})R\s+(.+)/);
        if (rm) {
          // 次の行から詳細情報を取得 "川崎1R 14:45発走 / ダート1400m12頭"
          const infoLine = (i + 1 < lines.length) ? lines[i + 1].trim() : '';
          const im = infoLine.match(/(\S+?)(\d{1,2})R\s+(\d{1,2}:\d{2})発走\s*\/\s*(ダート|芝)(\d+)m\s*(\d+)頭/);

          currentBlock = {
            raceNumber: parseInt(rm[1]),
            raceClass: rm[2],
            track: im ? im[1] : headerTrack,
            startTime: im ? im[3] : null,
            surface: im ? im[4] : null,
            distance: im ? im[4] + im[5] + 'm' : null,
            headCount: im ? parseInt(im[6]) : null,
            lines: [],
            startLine: i
          };
          raceBlocks.push(currentBlock);
          continue;
        }
        if (currentBlock) currentBlock.lines.push(line);
      }

      if (raceBlocks.length === 0) throw new Error('レースヘッダーが見つかりません');

      // 各レースの馬データを抽出
      const results = [];
      for (const block of raceBlocks) {
        try {
          const race = parseTextRace(block, headerTrack);
          if (race && race.horses.length > 0) results.push(race);
        } catch (e) {
          console.warn(`[TextParser] ${block.raceNumber}R スキップ:`, e.message);
        }
      }

      // headerDateをresultsに付与（runParseで使用）
      if (results.length > 0 && headerDate) {
        results._headerDate = headerDate;
      }

      return results;
    }

    function parseTextRace(block, headerTrack) {
      const { lines } = block;
      const SEX_RE = /[牡牝セ騸]/;

      // 馬データの開始行を検出: "馬番 馬名" の次行が "父名 性齢" パターン
      const horseStarts = [];
      let standaloneMode = false;
      for (let i = 0; i < lines.length; i++) {
        const curr = lines[i].trim();
        const next = (i + 1 < lines.length) ? lines[i + 1].trim() : '';
        if (/^\d{1,2}\s+[ァ-ヺー\u30A0-\u30FFぁ-んＡ-Ｚa-zA-Zア-ン]/.test(curr) && SEX_RE.test(next) && /\d$/.test(next)) {
          const prev = (i > 0) ? lines[i - 1].trim() : '';
          const bracket = /^[1-8]$/.test(prev) ? parseInt(prev) : null;
          horseStarts.push({ idx: i, bracket });
        }
      }

      // フォールバック: 馬番が単独行のパターン（小頭数で枠番=馬番の場合）
      if (horseStarts.length === 0) {
        for (let i = 0; i < lines.length; i++) {
          const curr = lines[i].trim();
          const next = (i + 1 < lines.length) ? lines[i + 1].trim() : '';
          if (/^\d{1,2}$/.test(curr) && SEX_RE.test(next) && /\d$/.test(next)) {
            horseStarts.push({ idx: i, bracket: null });
          }
        }
        if (horseStarts.length > 0) {
          standaloneMode = true;
          if (DEBUG) console.log(`[TextParser] ${block.raceNumber}R: 馬番単独行パターン検出 (${horseStarts.length}頭)`);
        }
      }

      if (horseStarts.length === 0) return null;

      const horses = [];
      for (let hi = 0; hi < horseStarts.length; hi++) {
        const start = horseStarts[hi].idx;
        // standaloneMode: 枠番行がないので次の馬番行まで全て含める
        const end = (hi + 1 < horseStarts.length) ? horseStarts[hi + 1].idx - (standaloneMode ? 0 : 1) : lines.length;
        const hLines = lines.slice(start, end);
        const bracket = horseStarts[hi].bracket;

        try {
          const horse = parseTextHorse(hLines, bracket);
          if (horse) horses.push(horse);
        } catch (e) {
          if (DEBUG) console.warn(`[TextParser] 馬解析失敗 L${start}:`, e.message);
        }
      }

      return {
        raceNumber: block.raceNumber,
        raceInfo: {
          track: block.track || headerTrack,
          raceClass: block.raceClass || '',
          conditions: '',
          distance: block.distance || '',
          startTime: block.startTime || null
        },
        horses,
        predictorNames: []
      };
    }

    function parseTextHorse(hLines, bracket) {
      if (hLines.length < 10) return null;

      // ===== すべてパターンベース、固定インデックス参照禁止 =====

      const MARK_RE = /^[◎○▲△☆★×✕注穴❶❷❸❹❺❻❼❽❾❿]$/;
      const MARK_OR_ELLIPSIS = /^[◎○▲△☆★×✕注穴❶❷❸❹❺❻❼❽❾❿…]$/;
      const SEX_AGE_RE = /([牡牝セ騸]\d+)/;
      const VENUE_NAMES_RE = /^(大井|川崎|船橋|浦和|東京|中山|京都|阪神|中京|新潟|福島|小倉|札幌|函館|盛岡|水沢|金沢|笠松|名古屋|園田|姫路|高知|佐賀|門別|帯広)\s+[\d.]+/;
      const TRAINER_RE = /^(大井|川崎|船橋|浦和|門別|盛岡|水沢|金沢|笠松|名古屋|園田|姫路|高知|佐賀|帯広|美浦|栗東)\s+(.+)/;

      // --- 馬番・馬名（必須: 先頭行） ---
      let number, name;
      const numNameMatch = hLines[0].trim().match(/^(\d{1,2})\s+(.+)/);
      if (numNameMatch) {
        number = parseInt(numNameMatch[1]);
        name = numNameMatch[2].trim();
      } else {
        // フォールバック: 馬番単独行（小頭数で枠番=馬番）
        const numOnlyMatch = hLines[0].trim().match(/^(\d{1,2})$/);
        if (!numOnlyMatch) return null;
        number = parseInt(numOnlyMatch[1]);
        // 馬名は父+性齢行の次行にある
        name = '';
        for (let i = 1; i < Math.min(hLines.length, 5); i++) {
          if (/^.+\s+[牡牝セ騸]\d+$/.test(hLines[i].trim())) {
            if (i + 1 < hLines.length) {
              const candidate = hLines[i + 1].trim();
              if (candidate && !/^\d+$/.test(candidate) && !candidate.includes('（') && !/^[◎○▲△☆★×✕注穴❶❷❸❹❺❻❼❽❾❿…]$/.test(candidate)) {
                name = candidate;
              }
            }
            break;
          }
        }
        if (!name) return null;
        if (DEBUG) console.log(`[TextParser] 馬番単独: ${number}番 → ${name}`);
      }

      // --- 性齢を含む行を探す（上から10行以内） ---
      let sire = '', sexAgeRaw = '', sexAgeLine = -1;
      for (let i = 1; i < Math.min(hLines.length, 10); i++) {
        const m = hLines[i].trim().match(/^(.+?)\s+([牡牝セ騸]\d+)$/);
        if (m) {
          sire = m[1].trim();
          sexAgeRaw = m[2];
          sexAgeLine = i;
          break;
        }
      }

      // --- 母（「（」を含む行を探す、性齢行以降10行以内） ---
      let dam = null;
      const damSearchStart = sexAgeLine > 0 ? sexAgeLine + 1 : 2;
      for (let i = damSearchStart; i < Math.min(hLines.length, damSearchStart + 5); i++) {
        const t = hLines[i].trim();
        if (t.includes('（')) {
          const dm = t.match(/^(.+?)（/);
          if (dm) dam = dm[1];
          break;
        }
      }

      // --- コンピ指数（1-3桁数字の単独行、印行より前） ---
      let computerIndex = '';
      let markStartIdx = -1;
      for (let i = damSearchStart; i < Math.min(hLines.length, 20); i++) {
        const t = hLines[i].trim();
        if (MARK_OR_ELLIPSIS.test(t)) {
          markStartIdx = i;
          break;
        }
        if (/^\d{1,3}$/.test(t) && markStartIdx < 0) {
          computerIndex = t;
        }
      }
      if (markStartIdx < 0) markStartIdx = Math.min(damSearchStart + 5, hLines.length);

      // --- 印（…=なし、◎○▲△☆★×=あり） ---
      const marks = [];
      let markEnd = markStartIdx;
      for (let i = markStartIdx; i < Math.min(hLines.length, markStartIdx + 15); i++) {
        const t = hLines[i].trim();
        if (t === '…' || MARK_RE.test(t)) {
          if (MARK_RE.test(t)) marks.push(t);
          markEnd = i + 1;
        } else {
          break;
        }
      }

      // --- 合計スコア（印終了直後の数値行） ---
      let cursor = markEnd;
      let totalScoreRaw = '0';
      if (cursor < hLines.length && /^\d+$/.test(hLines[cursor].trim())) {
        totalScoreRaw = hLines[cursor].trim();
        cursor++;
      }

      // --- 斤量・騎手（"54 国分祐" パターンを探索） ---
      // 合計スコア行の位置がずれる場合があるため、広範囲で探索
      let weight = null, jockey = null;
      for (let wi = cursor; wi < Math.min(cursor + 8, hLines.length); wi++) {
        const line = hLines[wi].trim();
        // 斤量(2桁) + スペース + 騎手名（漢字/カナで始まる）
        const wjMatch = line.match(/^(\d{2})\s+([\u3000-\u9FFFa-zA-Zァ-ヺぁ-ん].+)/);
        if (wjMatch) {
          weight = wjMatch[1];
          jockey = wjMatch[2].replace(/\s+/g, '').trim();
          cursor = wi + 1;
          break;
        }
      }

      // --- 調教師（"所属 名前" パターンを探索） ---
      let trainer = null;
      for (let ti = cursor; ti < Math.min(cursor + 10, hLines.length); ti++) {
        const trMatch = hLines[ti].trim().match(TRAINER_RE);
        if (trMatch) {
          trainer = trMatch[2].replace(/\s+/g, '');
          cursor = ti + 1;
          break;
        }
      }

      // --- 近走開始行（場名パターン）を直接検索 ---
      while (cursor < hLines.length) {
        if (VENUE_NAMES_RE.test(hLines[cursor]?.trim() || '')) break;
        cursor++;
      }

      // 近走データ: 10行×n走
      const pastRaces = [];
      const MAX_PAST = 6;
      while (cursor + 9 < hLines.length && pastRaces.length < MAX_PAST) {
        const venueLine = hLines[cursor]?.trim() || '';
        if (!VENUE_NAMES_RE.test(venueLine)) break;

        const finishLine = hLines[cursor + 1]?.trim() || '';
        const classDistLine = hLines[cursor + 3]?.trim() || '';
        const timeLine = hLines[cursor + 4]?.trim() || '';
        const detailLine = hLines[cursor + 5]?.trim() || '';
        const jkWeightLine = hLines[cursor + 6]?.trim() || '';
        const paceLine = hLines[cursor + 7]?.trim() || '';
        const winnerLine = hLines[cursor + 9]?.trim() || '';

        // 着順: 先頭の丸数字 or 数字
        let finish = null;
        const circledMatch = finishLine.match(/^[①②③④⑤⑥⑦⑧⑨⑩⑪⑫⑬⑭⑮⑯⑰⑱❶❷❸❹❺❻❼❽❾❿]/);
        if (circledMatch) {
          const CIRCLED_ALL = '①②③④⑤⑥⑦⑧⑨⑩⑪⑫⑬⑭⑮⑯⑰⑱';
          const DINGBAT = '❶❷❸❹❺❻❼❽❾❿';
          let idx = CIRCLED_ALL.indexOf(circledMatch[0]);
          if (idx >= 0) finish = String(idx + 1);
          else {
            idx = DINGBAT.indexOf(circledMatch[0]);
            if (idx >= 0) finish = String(idx + 1);
          }
        } else {
          const numMatch = finishLine.match(/^(\d{1,2})\s/);
          if (numMatch) finish = numMatch[1];
        }

        // クラス+距離: "Ｃ3 ダ2000"
        const cdMatch = classDistLine.match(/^(.+?)\s+(ダ|芝)(\d+)/);
        const raceClass = cdMatch ? cdMatch[1] : classDistLine;
        const distance = cdMatch ? cdMatch[2] + cdMatch[3] : null;

        // タイム
        const time = /^\d/.test(timeLine) ? timeLine : null;

        // 馬体重: "12頭 8枠 443"
        const bwMatch = detailLine.match(/(\d{3,4})\s*$/);
        const bodyWeight = bwMatch ? parseInt(bwMatch[1]) : null;

        // 騎手+斤量: "中島良 52"
        let prJockey = null, prWeight = null;
        const jkMatch = jkWeightLine.match(/^(.+?)\s+(\d{2})/);
        if (jkMatch) { prJockey = jkMatch[1].replace(/\s+/g, ''); prWeight = jkMatch[2]; }

        // ペース: "Ｍ ① 40.6 11人"
        let paceType = null, paceRank = null, final3F = null;
        const paceMatch = paceLine.match(/^([ＳＭＨSMHスミハ])\s*([①②③④⑤⑥⑦⑧⑨⑩⑪⑫⑬⑭⑮⑯⑰⑱❶❷❸❹❺❻❼❽❾❿])\s*([\d.]+)/);
        if (paceMatch) {
          const ptMap = { 'Ｓ':'S','Ｍ':'M','Ｈ':'H','S':'S','M':'M','H':'H','ス':'S','ミ':'M','ハ':'H' };
          paceType = ptMap[paceMatch[1]] || paceMatch[1];
          const CIRCLED_ALL = '①②③④⑤⑥⑦⑧⑨⑩⑪⑫⑬⑭⑮⑯⑰⑱';
          const DINGBAT = '❶❷❸❹❺❻❼❽❾❿';
          let ri = CIRCLED_ALL.indexOf(paceMatch[2]);
          if (ri < 0) ri = DINGBAT.indexOf(paceMatch[2]);
          paceRank = ri >= 0 ? ri + 1 : null;
          final3F = paceMatch[3];
        }

        // 勝ち馬
        const winner = winnerLine.replace(/^\d+休\s*/, '').trim() || null;

        // 開催情報
        const venueMatch = venueLine.match(/^(\S+)\s+([\d.]+)/);
        const venue = venueMatch ? venueMatch[1] + ' ' + venueMatch[2] : venueLine;

        pastRaces.push({
          venue, raceClass, finish, cond: null, courseNote: null,
          distance: distance || null,
          time, weight: prWeight ? parseInt(prWeight) : null,
          jockey: prJockey, bodyWeight, paceType, paceRank, final3F, winner
        });

        cursor += 10;
      }

      return {
        number, name, sire, sexAge: sexAgeRaw, weight, jockey,
        trainer, computerIndex: computerIndex || '', marks, ranking: 0, predictorCount: 0,
        odds: '', comment: '', pastRaces, training: null
      };
    }

    // ========== 3層スコア計算 ==========
    // A層: 印スコア（予想者の印記号から算出）
    const MARK_SCORES = { '◎': 5, '○': 4, '▲': 3, '☆': 3, '★': 2, '穴': 2, '△': 1, '×': 1 };
    const BASE_PREDICTORS = 5;
    // B層: 本紙順位ボーナス（①=5, ②=4, ③=3, ④=2, ⑤=1）
    const RANKING_BONUS = { 1: 5, 2: 4, 3: 3, 4: 2, 5: 1 };
    // C層: コンピ指数レース内順位ボーナス
    const COMPI_RANK_BONUS = { 1: 6, 2: 5, 3: 4, 4: 3, 5: 2 };
    const COMPI_RANK_DEFAULT = 1; // 6位以下

    // コンピ指数のレース内順位を計算
    function calcCompiRanks(horses) {
      const withCompi = horses
        .map(h => ({ number: h.number, ci: parseInt(h.computerIndex || '0') }))
        .filter(x => x.ci > 0)
        .sort((a, b) => b.ci - a.ci);
      const ranks = {};
      withCompi.forEach((x, i) => { ranks[x.number] = i + 1; });
      return ranks;
    }

    // 3層スコア内訳を計算
    function scoreBreakdown(horse, compiRanks) {
      const marks = horse.marks || [];
      const ranking = horse.ranking || 0;
      const pc = horse.predictorCount || 0;

      // A層: 印スコア
      let markScore = 0;
      for (const m of marks) {
        for (const ch of m) { if (MARK_SCORES[ch]) markScore += MARK_SCORES[ch]; }
      }
      const markWeight = pc >= 2 ? Math.sqrt(BASE_PREDICTORS / pc) : 1;
      const normalizedMark = Math.round(markScore * markWeight);

      // B層: 本紙順位ボーナス
      const rankingBonus = RANKING_BONUS[ranking] || 0;

      // C層: コンピ指数レース内順位ボーナス
      const compiRank = (compiRanks && compiRanks[horse.number]) || 0;
      const compiRankBonus = compiRank > 0
        ? (COMPI_RANK_BONUS[compiRank] || COMPI_RANK_DEFAULT)
        : 0;

      const total = normalizedMark + rankingBonus + compiRankBonus;

      return { markScore, markWeight: Math.round(markWeight * 100) / 100, normalizedMark, rankingBonus, compiRank, compiRankBonus, total };
    }

    function calcTotalScore(horse, compiRanks) {
      return scoreBreakdown(horse, compiRanks).total;
    }

    // ◎後段生成: PUAからは◎を作らず、スコア・順位・コンピで最大1頭に付与
    function autoAssignHonmei(horses, compiRanks) {
      const withScore = horses
        .filter(h => (h.marks || []).length > 0)
        .map(h => ({ h, score: calcTotalScore(h, compiRanks), maruCount: (h.marks || []).filter(m => m === '○').length }))
        .sort((a, b) => b.score - a.score);

      if (withScore.some(x => (x.h.marks || []).includes('◎'))) return;

      const top = withScore[0];
      if (!top || top.maruCount === 0) return;
      const ranking = top.h.ranking || 99;
      const compi = parseInt(top.h.computerIndex || '0');
      if (ranking <= 5 || compi >= 50) {
        const idx = top.h.marks.indexOf('○');
        if (idx >= 0) top.h.marks[idx] = '◎';
      }
    }

    // ▲自動生成: ◎なし + ○が複数ある馬 → 先頭○を▲に昇格
    function autoPromoteToTriangle(horses) {
      for (const h of horses) {
        const marks = h.marks;
        if (!marks || marks.length === 0) continue;
        if (marks.includes('◎')) continue;
        if (marks.filter(m => m === '○').length >= 2) {
          const idx = marks.indexOf('○');
          if (idx >= 0) marks[idx] = '▲';
        }
      }
    }

    function assignRoles(horses) {
      const compiRanks = calcCompiRanks(horses);

      // 1. ◎後段生成（最大1頭）
      autoAssignHonmei(horses, compiRanks);
      // 2. ▲自動生成（◎なし+○複数→先頭○を▲に）
      autoPromoteToTriangle(horses);

      const scored = horses.map(h => {
        const bd = scoreBreakdown(h, compiRanks);
        return { number: h.number, score: bd.total, _bd: bd };
      });

      // 同点時タイブレーク: コンピ順位→本紙順位→印数→馬番
      scored.sort((a, b) => {
        if (b.score !== a.score) return b.score - a.score;
        const aH = horses.find(h => h.number === a.number);
        const bH = horses.find(h => h.number === b.number);
        const aCR = a._bd.compiRank || 99;
        const bCR = b._bd.compiRank || 99;
        if (aCR !== bCR) return aCR - bCR;
        const aR = (aH?.ranking || 99);
        const bR = (bH?.ranking || 99);
        if (aR !== bR) return aR - bR;
        const aM = (aH?.marks || []).length;
        const bM = (bH?.marks || []).length;
        if (aM !== bM) return bM - aM;
        return a.number - b.number;
      });

      const assignments = { main: null, sub: null, hole: null, connectTop: null, connect: [], reserve: [], none: [] };

      for (let i = 0; i < scored.length; i++) {
        const { number, score } = scored[i];
        if (score === 0) { assignments.none.push(number); continue; }
        if (i === 0) assignments.main = number;
        else if (i === 1) assignments.sub = number;
        else if (i === 2) assignments.hole = number;
        else if (i === 3) assignments.connectTop = number;
        else if (i >= 4 && i <= 6 && score >= 1) assignments.connect.push(number);
        else assignments.reserve.push(number);
      }

      return { scored, assignments, compiRanks };
    }

    // ========== 正規化ヘルパー ==========
    function normName(s) {
      if (!s) return null;
      return s.replace(/[\s\u3000]+/g, '').trim() || null;
    }

    function parseSexAge(sa) {
      if (!sa) return { sexAge: null, sex: null, age: null };
      const m = sa.match(/^([牡牝セ騸])?(\d)?/);
      return {
        sexAge: sa,
        sex: m && m[1] ? m[1] : null,
        age: m && m[2] ? parseInt(m[2]) : null
      };
    }

    // ========== JSON構築 ==========
    function detectCategory(track) {
      if (JRA_VENUE_CODES[track]) return 'jra';
      if (NANKAN_VENUE_CODES[track]) return 'nankan';
      if (LOCAL_VENUE_CODES[track]) return 'local';
      return 'local'; // 未知の会場もlocalとして扱う
    }

    function buildJSON(results) {
      const date = document.getElementById('raceDate').value;
      const track = results[0].raceInfo.track;
      const category = detectCategory(track);
      const trackCode = ALL_VENUE_CODES[track] || 'UNK';

      return {
        version: '1.1.0',
        source: 'racebook',
        createdAt: new Date().toISOString(),
        date,
        category,
        track,
        trackCode,
        races: results.map(r => {
          const { scored, assignments, compiRanks } = assignRoles(r.horses);

          // コンピ指数ベースの再評価
          // 印なし(score=0) + コンピ45以上 → 補欠に昇格
          const COMPI_THRESHOLD = 45;
          for (const h of r.horses) {
            const sc = scored.find(s => s.number === h.number);
            if (sc && sc.score === 0) {
              const ci = parseInt(h.computerIndex || '0');
              if (ci >= COMPI_THRESHOLD) {
                const nIdx = assignments.none.indexOf(h.number);
                if (nIdx >= 0) { assignments.none.splice(nIdx, 1); assignments.reserve.push(h.number); }
              }
            }
          }

          // 印分布ログ
          const markDist = { '◎': 0, '○': 0, '▲': 0, '☆': 0, '△': 0 };
          for (const h of r.horses) {
            for (const m of (h.marks || [])) { if (markDist[m] !== undefined) markDist[m]++; }
          }
          const distStr = Object.entries(markDist).map(([k,v]) => `${k}${v}`).join(' ');
          const markedCount = r.horses.filter(h => (h.marks || []).length > 0).length;

          // 3層スコアデバッグログ（上位5頭）
          const top5 = [...scored].slice(0, 5);
          const pc = r.horses[0]?.predictorCount || '?';
          console.log(`[Score] ${r.raceNumber}R (${pc}名予想, 印付${markedCount}/${r.horses.length}頭) 分布: ${distStr}`);
          console.log(`[Score] ${r.raceNumber}R 上位: ${top5.map(s => {
            const bd = s._bd || {};
            const h = r.horses.find(x => x.number === s.number);
            return `#${s.number}${h?.name || ''}=${s.score}pt(印${bd.normalizedMark || 0}+順${bd.rankingBonus || 0}+C${bd.compiRank || '-'}:${bd.compiRankBonus || 0})`;
          }).join(', ')}`);

          return {
            raceNumber: r.raceNumber,
            raceClass: r.raceInfo.raceClass || null,
            conditions: r.raceInfo.conditions || null,
            distance: r.raceInfo.distance || null,
            startTime: r.raceInfo.startTime || null,
            horseCount: r.horses.length,
            predictorCount: r.horses[0]?.predictorCount || null,
            assignments,
            horses: [...r.horses].sort((a, b) => a.number - b.number).map(h => {
              const sc = scored.find(s => s.number === h.number);
              const bd = sc?._bd || scoreBreakdown(h, compiRanks);
              const { sexAge, sex, age } = parseSexAge(h.sexAge);
              return {
                number: h.number,
                name: normName(h.name),
                sire: normName(h.sire) || null,
                dam: null,
                sexAge,
                sex,
                age,
                weight: h.weight ? parseInt(h.weight) : null,
                jockey: normName(h.jockey),
                trainer: normName(h.trainer),
                computerIndex: h.computerIndex || null,
                marks: h.marks,
                ranking: h.ranking || null,
                // 3層スコア内訳（検証用）
                markScore: bd.markScore,
                normalizedMark: bd.normalizedMark,
                rankingBonus: bd.rankingBonus,
                compiRank: bd.compiRank || null,
                compiRankBonus: bd.compiRankBonus,
                totalScore: bd.total,
                assignment: getAssignment(h.number, assignments),
                predictedOdds: h.odds ? parseFloat(h.odds) : null,
                shortComment: h.comment || null,
                training: h.training || null,
                recentFormSource: 'racebook',
                pastRaces: (h.pastRaces || []).map(pr => ({
                  venue: pr.venue || null,
                  raceClass: pr.raceClass || null,
                  finish: pr.finish !== '?' ? parseInt(pr.finish) || null : null,
                  cond: pr.cond || null,
                  courseNote: pr.courseNote || null,
                  distance: pr.distance || null,
                  time: pr.time || null,
                  weight: pr.weight ? parseInt(pr.weight) : null,
                  jockey: normName(pr.jockey),
                  bodyWeight: pr.bodyWeight || null,
                  paceType: pr.paceType || null,
                  paceRank: pr.paceRank || null,
                  final3F: pr.final3F || null,
                  winner: normName(pr.winner)
                }))
              };
            })
          };
        })
      };
    }

    function getAssignment(num, a) {
      if (a.main === num) return '本命';
      if (a.sub === num) return '対抗';
      if (a.hole === num) return '単穴';
      if (a.connectTop === num) return '連下最上位';
      if (a.connect.includes(num)) return '連下';
      if (a.reserve.includes(num)) return '補欠';
      return '無';
    }

    // ========== コンピ指数補完（プレビュー時） ==========
    async function tryEnrichWithCompi(results) {
      if (!parsedData) return;
      const { date, trackCode, category } = parsedData;
      if (!date || !trackCode) return;

      const [year, month] = date.split('-');
      const cat = category || 'jra';
      const compiUrl = `https://raw.githubusercontent.com/apol0510/keiba-data-shared/main/${cat}/predictions/computer/${year}/${month}/${date}-${trackCode}.json`;

      console.log(`[Enrich] 使用日付: ${date}, trackCode: ${trackCode}`);
      console.log('[Enrich] コンピ指数取得:', compiUrl);

      try {
        const res = await fetch(compiUrl);
        if (!res.ok) {
          console.log('[Enrich] コンピ指数なし（補完スキップ）');
          return;
        }

        const compiJson = await res.json();
        if (!compiJson.races) return;

        const COMPI_THRESHOLD = 45;
        let enriched = 0;
        let promoted = 0;

        for (const race of parsedData.races) {
          const compiRace = compiJson.races.find(r => r.raceNumber === race.raceNumber);
          if (!compiRace || !compiRace.horses) continue;

          for (const horse of race.horses) {
            const compiHorse = compiRace.horses.find(ch => ch.number === horse.number);
            if (!compiHorse || !compiHorse.computerIndex) continue;

            const ci = parseInt(compiHorse.computerIndex);
            // computerIndex を上書き補完
            horse.computerIndex = String(ci);
            enriched++;

            // 印なし(totalScore=0) + コンピ45以上 → 補欠に昇格
            if (horse.totalScore === 0 && horse.assignment === '無' && ci >= COMPI_THRESHOLD) {
              horse.assignment = '補欠';
              // assignments.none から外して reserve に
              if (race.assignments) {
                const nIdx = race.assignments.none.indexOf(horse.number);
                if (nIdx >= 0) race.assignments.none.splice(nIdx, 1);
                race.assignments.reserve.push(horse.number);
              }
              promoted++;
            }
          }
        }

        console.log(`[Enrich] 補完: ${enriched}頭, 補欠昇格: ${promoted}頭`);

        if (enriched > 0) {
          // プレビューを再描画
          renderPreview(results);
          document.getElementById('jsonPreview').textContent = JSON.stringify(parsedData, null, 2);
          const msg = `✅ ${results.length}レース・${results.reduce((s,r)=>s+r.horses.length,0)}頭を検出`;
          const compiMsg = `📊 コンピ指数補完: ${enriched}頭` + (promoted > 0 ? `（${promoted}頭が補欠に昇格）` : '');
          showStatus(msg + ' — ' + compiMsg, 'success');
        }
      } catch (err) {
        console.log('[Enrich] コンピ取得エラー（続行）:', err.message);
      }
    }

    // ========== プレビュー描画 ==========
    function renderPreview(results) {
      document.getElementById('raceTitle').textContent =
        `${results[0].raceInfo.track} 全${results.length}レース`;

      const container = document.getElementById('raceAccordion');
      container.innerHTML = '';

      const json = parsedData;
      console.log('[Preview] results:', results.length, 'json.races:', json.races.length);

      for (let ri = 0; ri < results.length; ri++) {
        const race = results[ri];
        const jsonRace = json.races[ri];
        const assignments = jsonRace ? jsonRace.assignments : null;
        const sortedHorses = [...race.horses].sort((a, b) => a.number - b.number);

        // スコア計算（3層）
        const compiRanks = calcCompiRanks(sortedHorses);
        const scored = sortedHorses.map(h => {
          const bd = scoreBreakdown(h, compiRanks);
          return { ...h, _ts: bd.total, _bd: bd, _assign: jsonRace ? getAssignment(h.number, jsonRace.assignments) : '無' };
        });

        const acc = document.createElement('div');
        acc.className = 'race-accordion';

        // ヘッダー
        const header = document.createElement('div');
        header.className = 'race-accordion-header';
        const st = race.raceInfo.startTime || '';
        header.innerHTML = `<span>▸ ${race.raceNumber}R ${esc(race.raceInfo.raceClass)} ${esc(race.raceInfo.distance)} ${st ? st + '発走' : ''} — ${race.horses.length}頭</span><span style="font-size:0.8rem;color:#94a3b8">✅ 成功</span>`;
        header.onclick = () => {
          const body = acc.querySelector('.race-accordion-body');
          body.classList.toggle('open');
          header.querySelector('span').textContent = body.classList.contains('open')
            ? `▾ ${race.raceNumber}R ${esc(race.raceInfo.raceClass)} ${esc(race.raceInfo.distance)} ${st ? st + '発走' : ''} — ${race.horses.length}頭`
            : `▸ ${race.raceNumber}R ${esc(race.raceInfo.raceClass)} ${esc(race.raceInfo.distance)} ${st ? st + '発走' : ''} — ${race.horses.length}頭`;
        };
        acc.appendChild(header);

        // ボディ（全HTMLを一度に組み立て）
        const body = document.createElement('div');
        body.className = 'race-accordion-body' + (ri === 0 ? ' open' : '');
        if (ri === 0) header.querySelector('span').textContent = header.querySelector('span').textContent.replace('▸', '▾');

        let bodyHtml = '';

        // レース情報カード
        bodyHtml += `<div class="race-info-card">
          <div><dt>発走</dt><dd>${esc(st) || '-'}</dd></div>
          <div><dt>レース名</dt><dd>${esc(race.raceInfo.raceClass)}</dd></div>
          <div><dt>距離</dt><dd>${esc(race.raceInfo.distance)}</dd></div>
          <div><dt>頭数</dt><dd>${race.horses.length}頭</dd></div>
        </div>`;

        // 振り分けカード
        if (assignments) {
          const findH = (num) => { const h = scored.find(x => x.number === num); return h ? `${num}番 ${esc(h.name)} (${h._ts}点)` : ''; };
          const findMulti = (nums) => (nums || []).map(n => findH(n)).filter(s => s).map(s => '<li>' + s + '</li>').join('') || '<li>なし</li>';
          bodyHtml += `<div style="padding:0.5rem 0.5rem 0;font-weight:700;color:#f1f5f9;font-size:0.85rem">🎯 自動振り分け結果</div>
          <div class="assign-grid">
            <div class="assign-card assign-honmei"><div class="assign-label">◎ 本命</div><ul class="assign-list">${assignments.main ? '<li>' + findH(assignments.main) + '</li>' : '<li>なし</li>'}</ul></div>
            <div class="assign-card assign-taikou"><div class="assign-label">○ 対抗</div><ul class="assign-list">${assignments.sub ? '<li>' + findH(assignments.sub) + '</li>' : '<li>なし</li>'}</ul></div>
            <div class="assign-card assign-tanana"><div class="assign-label">▲ 単穴</div><ul class="assign-list">${assignments.hole ? '<li>' + findH(assignments.hole) + '</li>' : '<li>なし</li>'}</ul></div>
            <div class="assign-card assign-renkatop"><div class="assign-label">△ 連下最上位</div><ul class="assign-list">${assignments.connectTop ? '<li>' + findH(assignments.connectTop) + '</li>' : '<li>なし</li>'}</ul></div>
            <div class="assign-card assign-renka"><div class="assign-label">△ 連下 (1~3頭)</div><ul class="assign-list">${findMulti(assignments.connect)}</ul></div>
            <div class="assign-card assign-hoseki"><div class="assign-label">× 補欠 (1点以上)</div><ul class="assign-list">${findMulti(assignments.reserve)}</ul></div>
            <div class="assign-card assign-none"><div class="assign-label">無 (0点)</div><ul class="assign-list">${findMulti(assignments.none || [])}</ul></div>
          </div>`;
        }

        // 馬カード一覧
        bodyHtml += '<div class="horse-cards">';
        for (const h of scored) {
          const badgeCls = h._assign === '本命' ? 'badge-honmei' : h._assign === '対抗' ? 'badge-taikou' : h._assign === '単穴' ? 'badge-tanana' : (h._assign.includes('連下') ? 'badge-renka' : (h._assign === '補欠' ? 'badge-hoseki' : 'badge-none'));
          const borderCls = h._assign === '本命' ? 'hcard-honmei' : h._assign === '対抗' ? 'hcard-taikou' : h._assign === '単穴' ? 'hcard-tanana' : (h._assign.includes('連下') ? 'hcard-renka' : '');
          const marksStr = h.marks.length > 0 ? h.marks.map(m => '<span class="hcard-mark">' + esc(m) + '</span>').join('') : '<span style="color:#64748b">-</span>';
          const rankStr = h.ranking ? '<span style="color:#fbbf24;font-weight:600;margin-left:4px">' + CIRCLED_NUMS[h.ranking - 1] + '</span>' : '';
          const compiRankStr = h._bd?.compiRank ? '<span style="color:#60a5fa;font-size:0.7rem;margin-left:4px">C' + h._bd.compiRank + '位</span>' : '';
          const bdStr = h._bd ? `<span style="color:#64748b;font-size:0.7rem;margin-left:4px">(印${h._bd.normalizedMark}+順${h._bd.rankingBonus}+C${h._bd.compiRankBonus})</span>` : '';
          const pastStr = (h.pastRaces && h.pastRaces.length > 0)
            ? h.pastRaces.slice(0, 3).map(r => '<span class="past-race">' + esc(r.finish || '?') + '着 ' + esc(r.venue) + ' ' + esc(r.time) + '</span>').join('')
            : '';
          const trainerStr = (h.trainer || '').replace(/\s+/g, '');
          bodyHtml += '<div class="horse-card ' + borderCls + '">'
            + '<div class="hcard-header">'
            + '<span class="hcard-number">' + h.number + '</span>'
            + '<span class="hcard-name">' + esc(h.name) + '</span>'
            + '<span class="assign-badge ' + badgeCls + '">' + esc(h._assign) + '</span>'
            + '<span class="hcard-score">' + h._ts + '点' + bdStr + '</span>'
            + '</div>'
            + '<div class="hcard-details">'
            + '<span>' + esc(h.sexAge) + '</span>'
            + (h.weight ? '<span>⚖️' + esc(h.weight) + 'kg</span>' : '')
            + (h.jockey ? '<span>🏇' + esc(h.jockey) + '</span>' : '')
            + (trainerStr ? '<span>🏠' + esc(trainerStr) + '</span>' : '')
            + (h.computerIndex ? '<span>📊' + esc(h.computerIndex) + '</span>' : '')
            + '</div>'
            + '<div class="hcard-marks">' + marksStr + rankStr + compiRankStr + '</div>'
            + (pastStr ? '<div class="hcard-past">' + pastStr + '</div>' : '')
            + '</div>';
        }
        bodyHtml += '</div>';

        if (ri === 0) console.log('[Preview] 1R bodyHtml length:', bodyHtml.length, 'assignments:', !!assignments);
        body.innerHTML = bodyHtml;
        acc.appendChild(body);
        container.appendChild(acc);
      }

      document.getElementById('jsonPreview').textContent = JSON.stringify(parsedData, null, 2);
    }

    function esc(s) {
      if (!s) return '';
      return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    // ========== 保存 ==========
    async function saveData() {
      const saveBtn = document.getElementById('saveBtn');
      if (!parsedData) { showStatus('先に解析を実行してください', 'error'); return; }

      const date = document.getElementById('raceDate').value;
      if (!date) { showStatus('開催日を入力してください', 'error'); return; }

      parsedData.date = date;
      const track = parsedData.track;
      parsedData.trackCode = ALL_VENUE_CODES[track] || 'UNK';
      parsedData.category = detectCategory(track);

      // バリデーション
      if (parsedData.trackCode === 'UNK') {
        showStatus(`競馬場「${track}」のコードが未登録です。データを確認してください`, 'error');
        return;
      }
      if (!parsedData.races || parsedData.races.length === 0) {
        showStatus('レースデータがありません', 'error');
        return;
      }
      const emptyRaces = parsedData.races.filter(r => r.horseCount === 0);
      if (emptyRaces.length > 0) {
        showStatus(`${emptyRaces.map(r => r.raceNumber + 'R').join(',')} の出走馬が0頭です`, 'error');
        return;
      }

      const totalHorses = parsedData.races.reduce((s, r) => s + r.horseCount, 0);
      const savePath = `${parsedData.category}/racebook/${date.slice(0,4)}/${date.slice(5,7)}/${date}-${parsedData.trackCode}.json`;

      if (!confirm(
        `以下のデータを保存しますか？\n\n` +
        `競馬場: ${track}\n` +
        `日付: ${date}\n` +
        `レース数: ${parsedData.races.length}R（${totalHorses}頭）\n` +
        `保存先: ${savePath}\n\n` +
        `※同日・同場のデータが既に存在する場合は上書きされます`
      )) return;

      saveBtn.disabled = true;
      saveBtn.textContent = '💾 保存中...';
      showStatus('💾 保存中...', 'info');

      try {
        const res = await fetch('/.netlify/functions/save-keiba-book', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(parsedData)
        });
        const result = await res.json();
        if (!res.ok) throw new Error(result.error || result.details || res.statusText);
        console.log('[Import] 保存完了:', result.filePath);
        showStatus('🎉 保存完了: ' + result.filePath + ' — 次のデータを貼り付けできます', 'success');
        // リセット: 次のデータを貼れる状態にする
        document.getElementById('xmlInput').value = '';
        document.getElementById('trackName').value = '';
        document.getElementById('raceDate').value = '';
        document.getElementById('previewSection').style.display = 'none';
        parsedData = null;
        window.scrollTo({ top: 0, behavior: 'smooth' });
      } catch (e) {
        console.error('[Import] 保存エラー:', e);
        showStatus('保存エラー: ' + e.message, 'error');
      } finally {
        saveBtn.disabled = false;
        saveBtn.textContent = '🚀 保存してGit Push';
      }
    }

    // ========== ステータス表示 ==========
    function showStatus(msg, type) {
      const el = document.getElementById('statusMessage');
      el.textContent = msg;
      el.className = 'status-message status-' + type;
      el.style.display = 'block';
    }
    function hideStatus() {
      document.getElementById('statusMessage').style.display = 'none';
    }
  </script>
</BaseLayout>
