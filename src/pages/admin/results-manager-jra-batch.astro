---
/**
 * JRA結果データ管理画面（12レース一括入力版）
 * results-manager-jraとは完全に別のファイル
 *
 * 機能:
 * - 12レース分の結果HTMLを一括貼り付け
 * - レース境界を自動検出して分割
 * - 各レースを個別に抽出・バリデーション
 * - 12レース分を1つのJSONファイルに保存
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import { JRA_VENUE_CODE_MAP, getVenueCode } from "../../lib/constants/venue-codes";

export const prerender = false;
---

<BaseLayout
  title="JRA 結果管理画面（一括入力）"
  description="12レース分の結果HTMLを一括で解析してデータ化します"
>
  <section class="admin-section">
    <div class="container">
      <h1 class="page-title">⚡ JRA 結果管理（12レース一括）</h1>
      <p class="page-description">
        <strong>12レース分の結果を一度に貼り付けて一括処理できます</strong><br>
        JRA公式サイトの結果ページをコピー＆貼り付けするだけ！<br>
        ※ 個別入力が必要な場合は <a href="/admin/results-manager-jra" style="color: var(--primary-end); text-decoration: underline;">JRA 結果管理（個別入力）</a> をご利用ください
      </p>

      <!-- 共通情報入力 -->
      <div class="card common-info-card">
        <h2>📅 開催情報</h2>
        <div class="common-info-grid">
          <div class="form-group">
            <label for="commonDate">開催日</label>
            <input
              type="date"
              id="commonDate"
              class="form-input"
              value={new Date().toISOString().split('T')[0]}
            />
          </div>
          <div class="form-group">
            <label for="fallbackVenue">競馬場（自動検出失敗時）</label>
            <select id="fallbackVenue" class="form-select">
              <option value="">-- 自動検出を優先 --</option>
              <option value="東京">東京</option>
              <option value="中山">中山</option>
              <option value="京都">京都</option>
              <option value="阪神">阪神</option>
              <option value="中京">中京</option>
              <option value="新潟">新潟</option>
              <option value="福島">福島</option>
              <option value="小倉">小倉</option>
              <option value="札幌">札幌</option>
              <option value="函館">函館</option>
            </select>
          </div>
        </div>
        <p style="color: var(--text-secondary); margin-top: var(--spacing-sm); font-size: 0.9rem;">
          ※ 競馬場は貼り付けたテキストから自動抽出されます（「○○競馬」「1回○○2日」などから取得）<br>
          ※ 自動検出に失敗した場合のみ、上のフィールドで手動選択してください
        </p>
      </div>

      <!-- 一括入力エリア -->
      <div class="card input-card">
        <h2>📋 12レース分の結果テキスト貼り付け</h2>
        <p style="color: var(--text-secondary); margin-bottom: var(--spacing-md);">
          JRA公式サイトの結果ページで<strong>第1R〜第12R</strong>までの表示内容を全て選択してコピーし、下のテキストエリアに貼り付けてください。<br>
          自動的にレースごとに分割・解析します。（HTMLタグは不要です）
        </p>

        <textarea
          id="batchInput"
          class="batch-textarea"
          rows="20"
          placeholder="12レース分の結果テキストを貼り付けてください

※ JRA公式サイトの結果ページで、第1R〜第12Rまでの
  表示されている内容を全て選択してコピー＆貼り付けしてください。

例:
1レース
2026年2月1日 京都競馬 第1日
3歳未勝利
コース：1,800メートル（ダート・右）（13頭）
発走時刻：09:50
天候：晴
馬場：良
着    枠    馬番    馬名...
1    1    1    グラシアムヘール...
...
払戻金
単勝    複勝...

2レース
2026年2月1日 京都競馬 第1日
...
(第12レースまで)"
        ></textarea>

        <div class="action-buttons" style="margin-top: var(--spacing-lg);">
          <button
            type="button"
            class="btn btn-primary btn-large"
            onclick="parseBatchRaces()"
          >
            🔍 12レース一括解析
          </button>
        </div>

        <div id="parseStatus" class="parse-status" style="display: none;"></div>
      </div>

      <!-- プレビューエリア -->
      <div id="previewSection" class="preview-section" style="display: none;">
        <div class="card">
          <h2>✅ 解析結果プレビュー</h2>
          <div id="raceSummary" class="race-summary"></div>

          <!-- 各レースの詳細プレビュー -->
          <div id="raceDetails" class="race-details"></div>

          <!-- 一括保存ボタン -->
          <div class="action-buttons" style="margin-top: var(--spacing-2xl);">
            <button
              type="button"
              class="btn btn-secondary"
              onclick="copyAllJSON()"
            >
              📋 JSON全コピー
            </button>
            <button
              type="button"
              id="saveAllBtn"
              class="btn btn-success btn-large"
              onclick="saveAllRacesToGit(false)"
            >
              🚀 12レース一括保存してGit Push
            </button>
            <button
              type="button"
              class="btn btn-warning"
              onclick="if(confirm('この日付の既存データを完全に上書きします。よろしいですか？')) saveAllRacesToGit(true)"
            >
              🔥 完全上書き保存
            </button>
          </div>
          <div id="saveStatus" class="save-status" style="display: none;"></div>
        </div>
      </div>

      <!-- 使用方法 -->
      <div class="card info-card">
        <h2>📖 使用方法</h2>
        <ol>
          <li><strong>開催日・競馬場</strong>を上部で選択</li>
          <li>JRA公式サイトの結果ページを開く</li>
          <li><strong>第1レース〜第12レース全ての表示内容</strong>をブラウザで選択してコピー
            <ul style="margin-top: 0.5rem; font-size: 0.9rem;">
              <li>ページ全体を選択（Ctrl+A / Cmd+A）</li>
              <li>または、1レースの「1レース」から12レースの払戻金まで選択</li>
            </ul>
          </li>
          <li>上のテキストエリアに貼り付け（Ctrl+V / Cmd+V）</li>
          <li>「12レース一括解析」ボタンをクリック</li>
          <li>プレビューで各レースの抽出結果を確認</li>
          <li>「12レース一括保存してGit Push」で keiba-data-shared に保存</li>
          <li>自動的に各サイトに反映されます 🎉</li>
        </ol>

        <h3>💡 ポイント</h3>
        <ul>
          <li>12レース分を一度に処理できます（効率重視）</li>
          <li>HTMLタグは不要です（表示されているテキストをそのままコピー）</li>
          <li>エラーが出たレースは赤色で表示されます</li>
          <li>慎重に確認したい場合は <a href="/admin/results-manager-jra" style="color: var(--primary-end);">個別入力</a> をご利用ください</li>
          <li>既存データは自動的にマージされます（上書きされません）</li>
        </ul>
      </div>
    </div>
  </section>

  <style>
    .admin-section {
      padding: var(--spacing-2xl) 0;
      min-height: 100vh;
    }

    .page-title {
      font-size: 2rem;
      margin-bottom: var(--spacing-md);
      text-align: center;
    }

    .page-description {
      text-align: center;
      color: var(--text-secondary);
      margin-bottom: var(--spacing-2xl);
      line-height: 1.6;
    }

    .common-info-card {
      max-width: 800px;
      margin: 0 auto var(--spacing-2xl);
    }

    .common-info-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--spacing-lg);
      margin-top: var(--spacing-md);
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-sm);
    }

    .form-group label {
      font-weight: 600;
      color: var(--text-primary);
    }

    .form-input,
    .form-select {
      padding: var(--spacing-sm) var(--spacing-md);
      border: 1px solid var(--border-color);
      border-radius: var(--radius-md);
      background: var(--bg-secondary);
      color: var(--text-primary);
      font-size: 1rem;
    }

    .input-card {
      max-width: 1200px;
      margin: 0 auto var(--spacing-2xl);
    }

    .batch-textarea {
      width: 100%;
      padding: var(--spacing-md);
      border: 1px solid var(--border-color);
      border-radius: var(--radius-md);
      background: var(--bg-secondary);
      color: var(--text-primary);
      font-family: 'Courier New', monospace;
      font-size: 0.875rem;
      resize: vertical;
      min-height: 400px;
    }

    .action-buttons {
      display: flex;
      gap: var(--spacing-md);
      flex-wrap: wrap;
    }

    .btn-large {
      flex: 1;
      min-width: 200px;
    }

    .parse-status,
    .save-status {
      margin-top: var(--spacing-md);
      padding: var(--spacing-md);
      border-radius: var(--radius-md);
      font-weight: 600;
      display: none;
    }

    .parse-status.success,
    .save-status.success {
      background: rgba(16, 185, 129, 0.1);
      border-left: 4px solid var(--success);
      color: var(--success);
    }

    .parse-status.error,
    .save-status.error {
      background: rgba(239, 68, 68, 0.1);
      border-left: 4px solid var(--error);
      color: var(--error);
    }

    .parse-status.loading,
    .save-status.loading {
      background: rgba(59, 130, 246, 0.1);
      border-left: 4px solid var(--primary-end);
      color: var(--primary-end);
    }

    .preview-section {
      max-width: 1200px;
      margin: 0 auto var(--spacing-2xl);
    }

    .race-summary {
      margin-bottom: var(--spacing-xl);
      padding: var(--spacing-lg);
      background: var(--bg-secondary);
      border-radius: var(--radius-md);
    }

    .race-details {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-md);
    }

    .race-detail-card {
      border: 2px solid var(--border-color);
      border-radius: var(--radius-md);
      overflow: hidden;
    }

    .race-detail-card.success {
      border-color: var(--success);
    }

    .race-detail-card.error {
      border-color: var(--error);
    }

    .race-detail-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: var(--spacing-lg);
      cursor: pointer;
      font-weight: 600;
      font-size: 1.25rem;
      user-select: none;
      background: var(--bg-secondary);
    }

    .race-detail-header:hover {
      background: var(--bg-tertiary);
    }

    .race-number-badge {
      color: var(--primary-end);
      font-size: 1.5rem;
    }

    .race-status-badge {
      font-size: 0.875rem;
      padding: 4px 12px;
      border-radius: var(--radius-sm);
      font-weight: 600;
    }

    .race-status-badge.success {
      background: rgba(16, 185, 129, 0.2);
      color: var(--success);
    }

    .race-status-badge.error {
      background: rgba(239, 68, 68, 0.2);
      color: var(--error);
    }

    .race-detail-content {
      padding: var(--spacing-lg);
      border-top: 1px solid var(--border-color);
    }

    .info-card {
      max-width: 1200px;
      margin: var(--spacing-2xl) auto 0;
    }

    .info-card ol,
    .info-card ul {
      margin-left: var(--spacing-lg);
      color: var(--text-secondary);
    }

    .info-card li {
      margin-bottom: var(--spacing-sm);
    }

    @media (max-width: 768px) {
      .common-info-grid {
        grid-template-columns: 1fr;
      }

      .action-buttons {
        flex-direction: column;
      }

      .btn-large {
        width: 100%;
      }
    }
  </style>

  <script is:inline>
    // グローバル変数
    let batchResults = [];

    // 【共通処理】区切り線除去
    // スタッフ運用で混入する区切り線（==========   1R   ↓   ==========）を除去
    function removeSeparatorLines(input) {
      if (!input || typeof input !== 'string') {
        return input;
      }

      const lines = input.split('\n');
      const SEPARATOR_LINE_PATTERN = /^[\s\u3000]*={3,}.*={3,}[\s\u3000]*$/;

      const cleanedLines = lines.filter(line => !SEPARATOR_LINE_PATTERN.test(line));
      const removedCount = lines.length - cleanedLines.length;

      if (removedCount > 0) {
        console.log(`[InputCleaner] 除去された区切り線: ${removedCount}行`);
      }

      return cleanedLines.join('\n');
    }

    // 一括解析メイン関数
    function parseBatchRaces() {
      const textarea = document.getElementById('batchInput');
      let html = textarea.value;

      if (!html.trim()) {
        alert('12レース分の結果HTMLを入力してください');
        return;
      }

      // 【区切り線除去処理】
      html = removeSeparatorLines(html);

      const statusDiv = document.getElementById('parseStatus');
      statusDiv.style.display = 'block';
      statusDiv.className = 'parse-status loading';
      statusDiv.textContent = '🔍 12レース分を解析中...';

      try {
        // レース境界で分割
        const raceHTMLs = splitRacesHTML(html);
        console.log(`[parseBatchRaces] 検出したレース数: ${raceHTMLs.length}`);

        if (raceHTMLs.length === 0) {
          statusDiv.className = 'parse-status error';
          statusDiv.textContent = '❌ レースが検出できませんでした。HTMLの形式を確認してください。';
          return;
        }

        // 共通情報取得
        const fallbackDate = document.getElementById('commonDate').value;
        const fallbackVenue = document.getElementById('fallbackVenue').value;

        // 各レースを解析
        batchResults = [];
        let successCount = 0;
        let errorCount = 0;
        let commonVenue = null; // 全レース共通の競馬場
        let commonDate = null;  // 全レース共通の開催日

        raceHTMLs.forEach((raceData, index) => {
          const raceHTML = typeof raceData === 'string' ? raceData : raceData.text;
          const raceNum = typeof raceData === 'string' ? (index + 1) : raceData.raceNumber;
          try {
            console.log(`[Batch] 処理中: 第${raceNum}R (配列インデックス: ${index})`);
            // レース情報抽出
            const raceInfo = extractRaceInfo(raceHTML, raceNum);

            // 最初のレースで共通情報を設定
            if (index === 0) {
              // 競馬場の自動検出（既存のロジック）
              commonVenue = raceInfo.venue;

              // 自動検出できなかった場合、フォールバックを使用
              if (!commonVenue && fallbackVenue) {
                commonVenue = fallbackVenue;
                console.log(`[Batch] 自動検出失敗。フォールバック競馬場を使用: ${commonVenue}`);
              }

              if (!commonVenue) {
                throw new Error('競馬場が検出できませんでした。「競馬場（自動検出失敗時）」フィールドで手動選択してください。');
              }

              console.log(`[Batch] 確定した競馬場: ${commonVenue}`);

              // 開催日の自動検出（新規）
              commonDate = raceInfo.raceDate;

              // 自動検出できなかった場合、フォールバックを使用
              if (!commonDate && fallbackDate) {
                commonDate = fallbackDate;
                console.log(`[Batch] 開催日の自動検出失敗。フォールバック日付を使用: ${commonDate}`);
              }

              if (!commonDate) {
                throw new Error('開催日が検出できませんでした。「開催日」フィールドで手動入力してください。');
              }

              console.log(`[Batch] 確定した開催日: ${commonDate}`);
            } else {
              // 2レース目以降はvenueの一致を確認
              if (raceInfo.venue && raceInfo.venue !== commonVenue) {
                console.warn(`⚠️ 第${raceNum}Rの競馬場（${raceInfo.venue}）が第1Rの競馬場（${commonVenue}）と異なります。`);
              }

              // 2レース目以降はraceDateの一致を確認
              if (raceInfo.raceDate && raceInfo.raceDate !== commonDate) {
                console.warn(`⚠️ 第${raceNum}Rの開催日（${raceInfo.raceDate}）が第1Rの開催日（${commonDate}）と異なります。`);
              }
            }

            // 結果データ抽出（個別エラーハンドリング）
            let results = [];
            let payouts = {};
            let timeData = {};
            let cornerData = [];

            try {
              results = extractResults(raceHTML);
              console.log(`[Batch] 第${raceNum}R: 着順データ抽出成功（${results.length}頭）`);
            } catch (err) {
              console.error(`[Batch] 第${raceNum}R: 着順データ抽出エラー:`, err);
              throw new Error(`着順データ抽出失敗: ${err.message}`);
            }

            try {
              payouts = extractPayouts(raceHTML);
              console.log(`[Batch] 第${raceNum}R: 払戻金抽出成功`);
            } catch (err) {
              console.warn(`[Batch] 第${raceNum}R: 払戻金抽出エラー（スキップ）:`, err);
              payouts = {};
            }

            try {
              timeData = extractTimeData(raceHTML);
              console.log(`[Batch] 第${raceNum}R: タイムデータ抽出成功`);
            } catch (err) {
              console.warn(`[Batch] 第${raceNum}R: タイムデータ抽出エラー（スキップ）:`, err);
              timeData = {};
            }

            try {
              cornerData = extractCornerData(raceHTML);
              console.log(`[Batch] 第${raceNum}R: コーナー通過順抽出成功`);
            } catch (err) {
              console.warn(`[Batch] 第${raceNum}R: コーナー通過順抽出エラー（スキップ）:`, err);
              cornerData = [];
            }

            // レースオブジェクトを構築（generateRaceCommentary用）
            const race = {
              raceNumber: raceNum,
              raceName: raceInfo.raceName,
              surface: raceInfo.surface,
              distance: raceInfo.distance,
              horses: results.length,
              results: results,
              payouts: payouts,
              cornerData: cornerData,
              timeData: timeData
            };

            const comment = generateRaceCommentary(race, commonDate, commonVenue);

            const data = {
              date: commonDate,
              venue: commonVenue,
              raceNumber: raceNum,
              raceName: raceInfo.raceName,
              raceSubtitle: raceInfo.raceSubtitle,
              distance: raceInfo.distance,
              surface: raceInfo.surface,
              track: raceInfo.track,
              startTime: raceInfo.startTime,
              weather: raceInfo.weather,
              trackCondition: raceInfo.trackCondition,
              results: results,
              payouts: payouts,
              timeData: timeData,
              cornerData: cornerData,
              comment: comment,
            };

            batchResults.push({
              raceNumber: raceNum,
              success: true,
              data,
              date: commonDate,
              venue: commonVenue,
            });
            successCount++;

          } catch (error) {
            console.error(`第${raceNum}R解析エラー:`, error);
            batchResults.push({
              raceNumber: raceNum,
              success: false,
              errors: [error.message],
            });
            errorCount++;
          }
        });

        // ステータス更新
        statusDiv.className = errorCount > 0 ? 'parse-status error' : 'parse-status success';
        statusDiv.innerHTML = `
          ✅ 解析完了: 成功 ${successCount}レース / エラー ${errorCount}レース<br>
          ${commonDate ? `📅 開催日: ${commonDate}<br>` : ''}
          ${commonVenue ? `📍 競馬場: ${commonVenue}` : ''}${commonVenue && errorCount > 0 ? '<br>' : ''}${errorCount > 0 ? '⚠️ エラーが出たレースは下で確認してください' : ''}
        `;

        // プレビュー表示
        displayBatchPreview(batchResults, commonDate, commonVenue);

      } catch (error) {
        statusDiv.className = 'parse-status error';
        statusDiv.innerHTML = `❌ エラー: ${error.message}`;
        console.error(error);
      }
    }

    // レーステキストを分割（結果用・プレーンテキスト対応）
    function splitRacesHTML(text) {
      const races = [];

      console.log(`[splitRacesHTML] 入力テキスト長: ${text.length}文字`);
      console.log(`[splitRacesHTML] 最初の500文字:`, text.substring(0, 500));

      // 中央競馬の結果はプレーンテキスト形式（HTMLタグなし）
      // パターン: 「1レース」「2レース」...「12レース」または「第1レース」「第2レース」のような形式（両方対応）
      // (?:第)? は「第」がオプショナル（あってもなくてもOK）
      // (?:^|[^\d]) は前方が数字でないことを確認（11レース→1レース誤検出を防止）
      const racePattern = /(?:^|[^\d])(?:第)?(\d{1,2})レース/gm;

      const raceMatches = [];
      let match;

      while ((match = racePattern.exec(text)) !== null) {
        // match.index は境界文字を含む位置なので、実際のレース番号の開始位置を調整
        const actualIndex = match[0].match(/(?:第)?(\d{1,2})レース/) ?
          match.index + match[0].indexOf(match[0].match(/(?:第)?(\d{1,2})レース/)[0]) :
          match.index;

        raceMatches.push({
          index: actualIndex,
          raceNum: parseInt(match[1], 10),
          fullMatch: match[0]
        });
      }

      console.log(`[splitRacesHTML] ○レースパターン検出数: ${raceMatches.length}個`);

      // レース番号の重複を除去（同じレース番号が複数ある場合、最初のものだけ残す）
      const seenRaceNumbers = new Set();
      const uniqueRaceMatches = raceMatches.filter(rm => {
        if (seenRaceNumbers.has(rm.raceNum)) {
          console.warn(`[splitRacesHTML] 重複検出: 第${rm.raceNum}レース（スキップ）`);
          return false;
        }
        seenRaceNumbers.add(rm.raceNum);
        return true;
      });

      console.log(`[splitRacesHTML] 重複除去後のレース数: ${uniqueRaceMatches.length}個`);

      if (uniqueRaceMatches.length > 0) {
        // 各レースのテキストを抽出（レース番号も含める）
        for (let i = 0; i < uniqueRaceMatches.length; i++) {
          const startIndex = uniqueRaceMatches[i].index;
          const endIndex = i < uniqueRaceMatches.length - 1 ? uniqueRaceMatches[i + 1].index : text.length;
          const raceText = text.substring(startIndex, endIndex);

          if (raceText.length > 100) {
            races.push({
              text: raceText,
              raceNumber: uniqueRaceMatches[i].raceNum  // 実際のレース番号を保持
            });
            console.log(`[splitRacesHTML] 第${uniqueRaceMatches[i].raceNum}レース: ${raceText.length}文字`);
            console.log(`[splitRacesHTML] 第${uniqueRaceMatches[i].raceNum}レース 最初の200文字:`, raceText.substring(0, 200));
          } else {
            console.warn(`[splitRacesHTML] 第${uniqueRaceMatches[i].raceNum}レース: データが短すぎる（${raceText.length}文字）`);
          }
        }
      } else {
        console.error('[splitRacesHTML] レース境界を検出できませんでした');
        console.log('[splitRacesHTML] テキストサンプル（最初の1000文字）:', text.substring(0, 1000));
      }

      console.log(`[splitRacesHTML] 最終的に検出したレース数: ${races.length}`);
      return races;
    }

    // ===== results-manager-jra.astroから統合した抽出関数 =====
    // TODO: 中央競馬特有のフォーマット対応が必要な場合は個別に調整

    function extractRaceInfo(text, raceNumber) {
      // HTMLタグを除去（より厳密に）
      const cleanText = text
        .replace(/<script[^>]*>[\s\S]*?<\/script>/gi, '')  // scriptタグを除去
        .replace(/<style[^>]*>[\s\S]*?<\/style>/gi, '')    // styleタグを除去
        .replace(/<[^>]+>/g, '')                            // すべてのHTMLタグを除去
        .replace(/&nbsp;/g, ' ')                            // 特殊文字を変換
        .replace(/&lt;/g, '<')
        .replace(/&gt;/g, '>')
        .replace(/&amp;/g, '&');

      const lines = cleanText.split('\n').map(l => l.trim()).filter(l => l);

      console.log('[extractRaceInfo] レース番号:', raceNumber);
      console.log('[extractRaceInfo] テキスト行数:', lines.length);
      console.log('[extractRaceInfo] 最初の10行:', lines.slice(0, 10));

      // 競馬場を抽出（複数パターンに対応）
      // 例: 「2026年2月1日 京都競馬 第1日」
      // 例: 「京都競馬場」
      // 例: 「1回京都2日」
      let venue = '';
      const venueNames = ['東京', '中山', '京都', '阪神', '中京', '新潟', '福島', '小倉', '札幌', '函館'];

      for (const line of lines) {
        // パターン1: 「○○競馬」
        for (const venueName of venueNames) {
          if (line.includes(`${venueName}競馬`)) {
            venue = venueName;
            console.log('[extractRaceInfo] 競馬場（パターン1）:', venue);
            break;
          }
        }
        if (venue) break;

        // パターン2: 「1回○○2日」形式（JRA公式の開催表記）
        const match = line.match(/\d+回(東京|中山|京都|阪神|中京|新潟|福島|小倉|札幌|函館)\d+日/);
        if (match) {
          venue = match[1];
          console.log('[extractRaceInfo] 競馬場（パターン2）:', venue);
          break;
        }
      }

      console.log('[extractRaceInfo] 抽出したvenue:', venue || '(検出できず)');

      // 開催日を抽出（複数パターンに対応）
      // 例: 「2026年3月15日（日曜）1回中京2日」
      // 例: 「2026年3月15日 中京競馬 第1日」
      let raceDate = null;
      for (const line of lines) {
        // パターン1: 「YYYY年M月D日」形式
        const dateMatch = line.match(/(\d{4})年(\d{1,2})月(\d{1,2})日/);
        if (dateMatch) {
          const year = dateMatch[1];
          const month = dateMatch[2].padStart(2, '0');
          const day = dateMatch[3].padStart(2, '0');
          raceDate = `${year}-${month}-${day}`;
          console.log('[extractRaceInfo] 開催日:', raceDate);
          break;
        }
      }

      // レース名候補を評価する関数（スコアが高いほど適切）
      const evaluateRaceNameCandidate = (line) => {
        let score = 0;

        // 絶対NG（スコア: -1000）
        if (
          line.includes('賞金') ||
          line.includes('番組ポイント') ||
          line.includes('サラブレッド系') ||
          line.includes('普通競走') ||
          line.includes('アラブ系') ||
          line.includes('発走時刻') ||
          line.includes('天候:') ||
          line.includes('天候') && !line.match(/第\d+回/) ||  // 「天候」は除外だが、レース名に含まれる場合は許可
          line.includes('馬場:') ||
          line.includes('馬場') && !line.match(/第\d+回/) ||  // 「馬場」も同様
          line.includes('本賞金') ||
          line.includes('オッズ') ||
          line.includes('コース：') ||
          line.includes('コース:') ||
          line.includes('メートル') ||
          line.includes('印刷用') ||
          line.includes('レース映像') ||
          line.includes('パトロール') ||
          line.includes('通過順位') ||
          line.includes('推定上り') ||
          line.includes('馬体重') ||
          line.includes('着') && line.includes('枠') && line.includes('馬番') ||  // ヘッダー行
          line.includes('番') && line.includes('馬名') && line.includes('性齢') ||  // ヘッダー行
          line.includes('重量') && line.includes('騎手') ||  // ヘッダー行
          /^\d+[\s\u3000]+\d+[\s\u3000]+\d+/.test(line) ||  // データ行（着順データ）
          line.length > 60 ||  // 60文字以上は不適切（重賞レース名は40-50文字程度）
          line.length < 2      // 短すぎる行も不適切
        ) {
          return -1000;
        }

        // 重賞レース（スコア: +250）← 第○回は重賞レース名のため優先
        if (line.match(/第\d+回/) && !line.match(/競馬|月|日|年/)) {
          score += 250;
        }

        // 中央競馬の重賞グレード（GI/GII/GIII/GⅠ/GⅡ/GⅢ）（スコア: +300）← 最優先
        if (line.match(/[（(]?G[IⅠⅡⅢ]+[）)]?/) || line.match(/Ｇ[IⅠⅡⅢ]+/)) {
          score += 300;
        }

        // ステークスを含む（スコア: +180）← 最優先
        if (line.includes('ステークス') || line.includes('Ｓ')) {
          score += 180;
        }

        // 特別レース名（スコア: +170）
        if (line.includes('特別') && !line.includes('賞金')) {
          score += 170;
        }

        // 杯・盃を含む（スコア: +160）
        if (line.match(/杯|盃/) && !line.includes('賞金')) {
          score += 160;
        }

        // 記念を含む（スコア: +160）
        if (line.includes('記念') && !line.includes('賞金')) {
          score += 160;
        }

        // 「○○賞」で終わる特別レース名（スコア: +160）
        // 例: ラジオ福島賞、ひめさゆり賞、青葉賞、皐月賞 等
        // 「賞金」「本賞金」は絶対NG (-1000) で除外済み、ここでは末尾「賞」のみ判定
        if (/[^金]賞$/.test(line) && line.length >= 3) {
          score += 160;
        }

        // 中央競馬の一般レース名（スコア: +30）← 条件表記なので低優先度
        // 「オープン」単体は条件なのでレース名候補から除外
        if (line.match(/[1-4]歳|新馬|未勝利|1勝クラス|2勝クラス|3勝クラス/) && line.length >= 5) {
          score += 30;
        }
        if (line.match(/\d+万下/)) {
          score += 30;
        }
        // 「オープン」単体は条件行として扱う（レース名にしない）
        if (line === 'オープン' || line === '（オープン）' || line === '(オープン)') {
          return -1000;
        }

        // 地方競馬グレード（スコア: +80）
        if (line.match(/[ＡＢＣ][１２３０]/)) {
          score += 80;
        }
        if (line.match(/[ABC][0-3]/)) {
          score += 80;
        }

        // 適切な文字数（10-50文字）にボーナス（スコア: +20）
        // 重賞レース名は長くなる傾向があるため範囲を拡大
        if (line.length >= 10 && line.length <= 50) {
          score += 20;
        }

        // カタカナを含む（競走馬名風）（スコア: +10）
        if (line.match(/[ァ-ヴ]/)) {
          score += 10;
        }

        // 数字が多すぎる行はマイナス（スコア: -50）
        const digitCount = (line.match(/\d/g) || []).length;
        if (digitCount > 5) {
          score -= 50;
        }

        return score;
      };

      // 全行を評価してスコアリング
      const candidates = [];
      for (let i = 0; i < lines.length; i++) {
        const line = lines[i];
        const score = evaluateRaceNameCandidate(line);

        if (score > 0) {
          candidates.push({ line, score, index: i });
          console.log(`[extractRaceInfo] 候補: "${line}" (スコア: ${score})`);
        }
      }

      // スコアが最も高い候補を選択（レース名）
      let raceName = '';
      let raceSubtitle = '';

      if (candidates.length > 0) {
        candidates.sort((a, b) => b.score - a.score);
        raceName = candidates[0].line;
        console.log(`[extractRaceInfo] レース名決定: "${raceName}" (スコア: ${candidates[0].score})`);

        // 条件（サブタイトル）を取得: 複数行を結合
        // 「3歳」「4歳以上」「未勝利」「1勝クラス」などを含む行を収集
        const subtitleParts = [];
        for (let i = 0; i < lines.length; i++) {
          const line = lines[i];

          // レース名と同じ行はスキップ
          if (line === raceName) continue;

          // 不適切な行をスキップ
          if (
            line.includes('賞金') ||
            line.includes('番組ポイント') ||
            line.includes('コース：') ||
            line.includes('コース:') ||
            line.includes('メートル') ||
            line.includes('発走時刻') ||
            line.includes('天候') ||
            line.includes('馬場') ||
            line.includes('本賞金') ||
            line.includes('オッズ') ||
            line.length > 30 ||
            line.length < 2
          ) {
            continue;
          }

          // 条件として適切なパターンをチェック
          if (
            line.match(/^[234]歳/) ||
            line.match(/歳以上/) ||
            line.match(/未勝利/) ||
            line.match(/\d+勝クラス/) ||
            line.match(/新馬/) ||
            line.match(/オープン/) ||
            line.match(/^\[指定\]$/) ||
            line.match(/^[（(]?[混合指定]+[）)]?$/) ||
            line.match(/^牝\[指定\]$/) ||
            line.match(/^牝［指定］$/) ||
            line.match(/^定量$/) ||
            line.match(/^ハンデ$/) ||
            line.match(/^馬齢$/)
          ) {
            subtitleParts.push(line);
            console.log(`[extractRaceInfo] 条件パーツ追加: "${line}"`);
          }
        }

        // 複数行を結合（最大3行まで）
        if (subtitleParts.length > 0) {
          raceSubtitle = subtitleParts.slice(0, 3).join('　');
          console.log(`[extractRaceInfo] 条件（サブタイトル）決定: "${raceSubtitle}"`);
        }
      } else {
        console.log('[extractRaceInfo] レース名が見つかりません');
        console.log('[extractRaceInfo] 最初の10行:', lines.slice(0, 10));
      }

      // 距離抽出（中央競馬: 「1,400メートル」のようにカンマ区切り）
      const distanceMatch = cleanText.match(/コース[：:]\s*(\d{1}),?(\d{3})メートル/) ||
                           cleanText.match(/[ダ芝][\s\u3000]*(\d{1}),?(\d{3})m/);
      const distance = distanceMatch ? parseInt(distanceMatch[1] + distanceMatch[2], 10) : null;

      // 芝/ダート判定（コース行を優先、天候行も参照）
      const courseLineMatch = cleanText.match(/コース[：:][^\n]*（(芝|ダート)[・･]/) ||
                              cleanText.match(/コース[：:][^\n]*(芝|ダート)/) ||
                              cleanText.match(/天候[^\n]*(芝|ダート)(良|稍重|重|不良)/);
      const surface = courseLineMatch ? (courseLineMatch[1] === 'ダート' ? 'ダート' : '芝') :
                      (cleanText.includes('ダート') ? 'ダート' : '芝');

      // コースの方向を抽出（全角中点「・」の後）
      const trackMatch = text.match(/[・･](外|内|右|左)[）)]/) ||
                         text.match(/（(外|内|右|左)）/);
      const track = trackMatch ? trackMatch[1] : null;

      // 出走頭数（複数パターン対応）
      const horsesMatch = text.match(/（(\d+)頭）/) ||
                         text.match(/(\d+)頭立/) ||
                         text.match(/出走頭数[：:]\s*(\d+)/) ||
                         text.match(/出走[：:]\s*(\d+)頭/);
      const horses = horsesMatch ? parseInt(horsesMatch[1], 10) : null;

      // 発走時刻（複数パターン対応）
      const startTimeMatch = text.match(/発走時刻[：:]\s*(\d{1,2})[:：時](\d{2})/) ||
                            text.match(/発走[：:]\s*(\d{1,2})[:：時](\d{2})/) ||
                            text.match(/(\d{1,2})[:：](\d{2})\s*発走/);
      const startTime = startTimeMatch ? `${startTimeMatch[1]}:${startTimeMatch[2]}` : null;

      // 天候抽出（改善版: 「天候晴ダート良」→「晴」のみ取得）
      const weatherMatch = text.match(/天候\s*([^\s　\nダ芝・]+)/);
      const weather = weatherMatch ? weatherMatch[1] : null;

      // 馬場状態抽出（改善版: 「ダート良」→「良」のみ取得）
      const trackConditionMatch = text.match(/(?:ダート|芝)\s*(良|稍重|重|不良)/);
      const trackCondition = trackConditionMatch ? trackConditionMatch[1] : null;

      console.log('[extractRaceInfo] 天候:', weather);
      console.log('[extractRaceInfo] 馬場状態:', trackCondition);
      console.log('[extractRaceInfo] 条件（サブタイトル）:', raceSubtitle);
      console.log('[extractRaceInfo] 競馬場（venue）:', venue);
      console.log('[extractRaceInfo] 開催日（raceDate）:', raceDate);

      return { raceNumber, raceName, raceSubtitle, distance, surface, track, horses, startTime, weather, trackCondition, venue, raceDate };
    }

    function extractResults(text) {
      const results = [];
      const lines = text.split('\n');

      console.log('[extractResults] テキスト行数:', lines.length);

      // 着順データのセクション終了を示すキーワード
      const sectionEndKeywords = [
        'タイム',
        'ハロンタイム',
        'コーナー通過順位',
        '払戻金',
        '上り',
        '4F',
        '3F'
      ];

      // 中央競馬のフォーマット（複数行に分かれている可能性があるので結合）
      let currentLine = '';
      let inResultSection = false;

      for (let i = 0; i < lines.length; i++) {
        const line = lines[i].trim();
        if (!line) continue; // 空行をスキップ

        // セクション終了判定
        const isEndOfSection = sectionEndKeywords.some(keyword => line.includes(keyword));
        if (isEndOfSection) {
          if (currentLine) {
            console.log('[extractResults] セクション終了検出（前の行を処理）:', line);
            // 現在の行を処理して終了
            processLine(currentLine, results);
            currentLine = '';
          }
          inResultSection = false;
          continue;
        }

        // 着順データの開始を検出（中央競馬は必ず「枠」という文字を含む）
        // 例: "1     枠10白     10     ケブランリ..."
        const isStartOfResult = /^\d+[\s\u3000]+枠\d+/.test(line);

        if (isStartOfResult) {
          // 新しい着順行が始まった
          if (currentLine) {
            // 前の行を処理
            console.log('[extractResults] 新しい着順行検出（前の行を処理）');
            processLine(currentLine, results);
          }
          // 新しい行を開始
          currentLine = line;
          inResultSection = true;
          console.log('[extractResults] 着順行開始:', line.substring(0, 80));
        } else if (inResultSection && currentLine) {
          // 継続行の判定：着順データの一部と思われる場合のみ結合
          // ただし、明らかに別のセクションのデータは結合しない

          // 枠色パターン（"枠8桃"など）が来たら、別の馬のデータなので前の行を処理
          const hasWakuIro = /枠\d+[桃橙青赤緑黄黒白]/.test(line);
          if (hasWakuIro) {
            console.log('[extractResults] 枠色検出（前の行を処理）:', line);
            processLine(currentLine, results);
            currentLine = '';
            inResultSection = false;
            continue;
          }

          // 特記事項行（ブリンカー着用など）をスキップ
          const isRemark = line.includes('ブリンカー着用') ||
                          line.includes('シャドーロール着用') ||
                          line.includes('メンコ着用') ||
                          line.includes('パシュファイヤー着用') ||
                          line.includes('着用');
          if (isRemark) {
            console.log('[extractResults] 特記事項行をスキップ:', line);
            continue;
          }

          // 継続行として結合すべきかどうかを判定
          const shouldMerge = !isStartOfResult &&
                             !isEndOfSection &&
                             line.length > 0 &&
                             !line.startsWith('タイム') &&
                             !line.startsWith('ハロン') &&
                             !line.startsWith('コーナー') &&
                             !line.startsWith('払戻');

          if (shouldMerge) {
            // 継続行を結合（ただし、性齢が2回目に出現したら切る）
            const currentSexAgeCount = (currentLine.match(/[牡牝セ]\d+/g) || []).length;
            const lineSexAgeCount = (line.match(/[牡牝セ]\d+/g) || []).length;

            if (currentSexAgeCount > 0 && lineSexAgeCount > 0) {
              // 性齢が既にcurrentLineにあり、新しい行にもある場合、別の馬のデータ
              console.log('[extractResults] 性齢重複検出（前の行を処理）');
              processLine(currentLine, results);
              currentLine = '';
              inResultSection = false;
            } else {
              // 継続行を結合
              currentLine += ' ' + line;
              console.log('[extractResults] 継続行結合:', line.substring(0, 50));
            }
          }
        }
      }

      // 最後の行を処理
      if (currentLine) {
        processLine(currentLine, results);
      }

      console.log('[extractResults] 抽出された着順数:', results.length);

      if (results.length === 0) throw new Error('着順データが見つかりません');
      return results;
    }

    function processLine(line, results) {
      // 中央競馬フォーマット:
      // 着順 枠 馬番 馬名 性齢 負担重量 騎手名 タイム 着差 コーナー通過 推定上り 馬体重 調教師名 単勝人気
      // 例: 1    10    ケブランリ    牡3    57.0    C.ルメール    1:25.4        •    1 •    1    37.2    500(-2)    加藤 士津八    1

      const parts = line.split(/[\s\u3000]+/).filter(p => p && p !== '•');

      console.log('[processLine] parts:', parts.slice(0, 20)); // 最初の20個のみ表示

      if (parts.length < 8) {
        console.log('[processLine] データ不足、スキップ');
        return;
      }

      let idx = 0;

      // 着順
      const rank = parseInt(parts[idx++], 10);
      if (isNaN(rank)) {
        console.log('[processLine] 着順が数字でない、スキップ');
        return;
      }

      // 枠（中央競馬は "枠8桃" 形式、南関は "8" 形式）
      let bracket = 0;
      const bracketPart = parts[idx++];
      const wakuMatch = bracketPart.match(/^枠(\d+)[桃橙青赤緑黄黒白]$/);
      if (wakuMatch) {
        bracket = parseInt(wakuMatch[1], 10);
        console.log('[processLine] 枠色検出:', bracketPart, '→', bracket);
      } else {
        bracket = parseInt(bracketPart, 10);
      }

      // 馬番
      const number = parseInt(parts[idx++], 10);

      // 馬名（カタカナまたは英字を含む名前を探す）
      // 性齢パターン（牡3、せん5など）や負担重量パターン（57.0など）が来るまで探す
      let name = '';
      while (idx < parts.length && idx < 10) { // 最大10個まで探す
        const part = parts[idx];
        // 性齢パターン（牡3、牝3、セ3、せん5など）が来たら馬名終了
        if (/^([牡牝セ]|せん)\d+$/.test(part)) {
          break;
        }
        // 負担重量パターン（57.0など）が来たら馬名終了
        if (/^\d+\.\d+$/.test(part)) {
          break;
        }
        // カタカナ、ひらがな、英字を含む場合は馬名の一部
        if (/[ァ-ヴぁ-んa-zA-Z]/.test(part)) {
          name = part;
          idx++;
          break;
        }
        // 数字だけの場合はスキップ（馬名ではない）
        if (/^\d+$/.test(part)) {
          idx++;
          continue;
        }
        // その他の文字列は馬名候補
        name = part;
        idx++;
        break;
      }

      if (!name) {
        console.log('[processLine] 馬名が見つからない、スキップ');
        return;
      }

      // 性齢を抽出（牡3、牝3、セ3、せん5など）
      let sexAge = '';
      if (idx < parts.length && /^([牡牝セ]|せん)\d+$/.test(parts[idx])) {
        sexAge = parts[idx++];
        console.log('[processLine] 性齢検出:', sexAge);
      }

      // 負担重量を抽出（57.0など）
      let weight = '';
      if (idx < parts.length && /^\d+\.\d+$/.test(parts[idx])) {
        weight = parts[idx++];
        console.log('[processLine] 負担重量検出:', weight);
      }

      // 騎手名（次の項目がタイム形式 "1:25.4" になるまで、または最大3パーツまで）
      let jockey = '';
      let jockeyPartCount = 0;
      const startIdx = idx;
      while (idx < parts.length && jockeyPartCount < 3) {
        // タイム形式が見つかったらループを抜ける
        if (/^\d+:\d+\.\d+$/.test(parts[idx])) {
          break;
        }
        // 不適切なパターン（馬体重や調教師エリア）が来たら抜ける
        if (/^\d+\([+-]?\d+\)$/.test(parts[idx])) {
          break;
        }
        // "タイム"などのセクションヘッダーが来たら抜ける
        if (parts[idx] === 'タイム' || parts[idx] === 'ハロンタイム' || parts[idx] === 'コーナー通過順位') {
          break;
        }
        jockey += (jockey ? ' ' : '') + parts[idx];
        idx++;
        jockeyPartCount++;
      }

      // タイム（"1:25.4" 形式）
      let time = '';
      if (idx < parts.length && /^\d+:\d+\.\d+$/.test(parts[idx])) {
        time = parts[idx++];
      }

      // 着差（1着は"-"、それ以外は数字+単位のパターン）
      let margin = '-';
      if (idx < parts.length) {
        const part = parts[idx];
        // 着差のパターン: "１", "２", "３"などの全角数字、または "-"
        // 半角数字だけの場合はコーナー通過順位なので含めない
        if (!/^\d+$/.test(part) && !/^\d+\.\d+$/.test(part) && !/^\d+\(/.test(part)) {
          margin = parts[idx++];
          // 着差が複数パーツの場合（例: "１ 1/2", "２ 1/4"）
          // スラッシュを含む場合のみ着差として扱う（半角数字だけはコーナー通過順位）
          if (idx < parts.length && /^[\d/]+$/.test(parts[idx]) && parts[idx].includes('/')) {
            margin += ' ' + parts[idx++];
          }
        }
      }

      // コーナー通過順位をスキップ（中央競馬は4個：1C, 2C, 3C, 4C）
      let cornerSkipped = 0;
      while (idx < parts.length && /^\d+$/.test(parts[idx]) && cornerSkipped < 4) {
        idx++;
        cornerSkipped++;
      }

      // 推定上り（上3F: "37.2" のような小数）
      let lastFurlong = '';
      if (idx < parts.length && /^\d+\.\d+$/.test(parts[idx])) {
        lastFurlong = parts[idx++];
      }

      // 馬体重（増減）をスキップ（"500(-2)" 形式）
      if (idx < parts.length && /^\d+\([+-]?\d+\)$/.test(parts[idx])) {
        idx++;
      }

      // 調教師名（最後から2番目まで、最後の1個は単勝人気）
      let trainer = '';
      // parts.length - 1 が最後の要素（単勝人気）なので、それより前を全て結合
      const endIdx = parts.length - 1;
      while (idx < endIdx) {
        trainer += (trainer ? ' ' : '') + parts[idx];
        idx++;
      }

      // 単勝人気（最後の数字）
      const popularity = parseInt(parts[idx], 10) || 0;

      console.log('[processLine] 抽出結果:', { rank, bracket, number, name, sexAge, weight, jockey, time, margin, lastFurlong, trainer, popularity });

      if (!isNaN(rank) && !isNaN(bracket) && !isNaN(number) && name) {
        results.push({
          rank,
          bracket,
          number,
          name,
          sexAge,
          weight,
          jockey,
          trainer,
          time,
          margin: margin || '-',
          lastFurlong,
          popularity
        });
      }
    }

    function extractPayouts(text) {
      const payouts = {};

      const payoutMatch = text.match(/払戻金[\s\S]*$/);
      if (!payoutMatch) return payouts;

      const payoutSection = payoutMatch[0];
      const lines = payoutSection.split('\n').filter(l => l.trim());

      // 単勝: 10 210円 1番人気 または 1 → 650円 (3人気)
      const tanshoMatch = payoutSection.match(/単勝[：:\s]+(\d+)\s*(?:→)?\s*([\d,]+)円\s*[\(（]?(\d+)番?人気[\)）]?/);
      if (tanshoMatch) {
        payouts.tansho = [{
          number: tanshoMatch[1],
          payout: parseInt(tanshoMatch[2].replace(/,/g, ''), 10),
          popularity: parseInt(tanshoMatch[3], 10)
        }];
      }

      // 複勝: 10 120円 1番人気  9 210円 5番人気  6 150円 3番人気
      // 中央競馬形式: 1 → 120円 (1番人気) または 1 120円 1番人気
      const fukushoMatches = [...payoutSection.matchAll(/(\d+)\s*(?:→)?\s*([\d,]+)円\s*[\(（]?(\d+)番?人気[\)）]?/g)];
      if (fukushoMatches.length > 0) {
        // 「複勝」キーワードの後のマッチのみを抽出
        const fukushoStartIndex = payoutSection.indexOf('複勝');
        const fukushoEndIndex = payoutSection.indexOf('枠', fukushoStartIndex) !== -1
          ? payoutSection.indexOf('枠', fukushoStartIndex)
          : payoutSection.indexOf('馬', fukushoStartIndex);
        const fukushoSection = payoutSection.substring(fukushoStartIndex, fukushoEndIndex);

        const fukushoOnlyMatches = [...fukushoSection.matchAll(/(\d+)\s*(?:→)?\s*([\d,]+)円\s*[\(（]?(\d+)番?人気[\)）]?/g)];
        if (fukushoOnlyMatches.length > 0) {
          payouts.fukusho = fukushoOnlyMatches.map(m => ({
            number: m[1],
            payout: parseInt(m[2].replace(/,/g, ''), 10),
            popularity: parseInt(m[3], 10)
          }));
        }
      }

      // 枠連: 5-5 1,270円 6番人気 または 1-8 → 1,580円 (6人気)
      const wakurenMatch = payoutSection.match(/枠連[：:\s]+([\d-]+)\s*(?:→)?\s*([\d,]+)円\s*[\(（]?(\d+)番?人気[\)）]?/);
      if (wakurenMatch) {
        payouts.wakuren = [{
          combination: wakurenMatch[1],
          payout: parseInt(wakurenMatch[2].replace(/,/g, ''), 10),
          popularity: parseInt(wakurenMatch[3], 10)
        }];
      }

      // 枠単: 1-2 → 340円 (2人気)
      const wakutanMatch = payoutSection.match(/枠単[：:\s]+([\d-]+)\s*(?:→)?\s*([\d,]+)円\s*[\(（]?(\d+)番?人気[\)）]?/);
      if (wakutanMatch) {
        payouts.wakutan = [{
          combination: wakutanMatch[1],
          payout: parseInt(wakutanMatch[2].replace(/,/g, ''), 10),
          popularity: parseInt(wakutanMatch[3], 10)
        }];
      }

      // ワイド: 9-10 380円 3番人気  6-10 330円 2番人気  6-9 740円 10番人気
      // 中央競馬形式: 1-2 → 380円 (3番人気) または 1-2 380円 3番人気
      const wideMatches = [...payoutSection.matchAll(/([\d-]+)\s*(?:→)?\s*([\d,]+)円\s*[\(（]?(\d+)番?人気[\)）]?/g)];
      if (wideMatches.length > 0) {
        // 「ワイド」キーワードの後のマッチのみを抽出
        const wideStartIndex = payoutSection.indexOf('ワイド');
        if (wideStartIndex !== -1) {
          const wideEndIndex = payoutSection.indexOf('馬連', wideStartIndex) !== -1
            ? payoutSection.indexOf('馬連', wideStartIndex)
            : payoutSection.indexOf('馬単', wideStartIndex);
          const wideSection = payoutSection.substring(wideStartIndex, wideEndIndex);

          const wideOnlyMatches = [...wideSection.matchAll(/([\d-]+)\s*(?:→)?\s*([\d,]+)円\s*[\(（]?(\d+)番?人気[\)）]?/g)];
          if (wideOnlyMatches.length > 0) {
            payouts.wide = wideOnlyMatches.map(m => ({
              combination: m[1],
              payout: parseInt(m[2].replace(/,/g, ''), 10),
              popularity: parseInt(m[3], 10)
            }));
          }
        }
      }

      // 馬連: 9-10 1,010円 3番人気 または 1-12 → 2,550円 (9人気)
      const umarenMatch = payoutSection.match(/馬[連複][：:\s]+([\d-]+)\s*(?:→)?\s*([\d,]+)円\s*[\(（]?(\d+)番?人気[\)）]?/);
      if (umarenMatch) {
        payouts.umaren = [{
          combination: umarenMatch[1],
          payout: parseInt(umarenMatch[2].replace(/,/g, ''), 10),
          popularity: parseInt(umarenMatch[3], 10)
        }];
      }

      // 馬単: 10-9 1,380円 3番人気 または 1-12 → 5,530円 (18人気)
      const umatanMatch = payoutSection.match(/馬単[：:\s]+([\d-]+)\s*(?:→)?\s*([\d,]+)円\s*[\(（]?(\d+)番?人気[\)）]?/);
      if (umatanMatch) {
        payouts.umatan = [{
          combination: umatanMatch[1],
          payout: parseInt(umatanMatch[2].replace(/,/g, ''), 10),
          popularity: parseInt(umatanMatch[3], 10)
        }];
      }

      // 3連複: 6-9-10 1,730円 4番人気 または 1-10-12 → 3,750円 (12人気)
      const sanrenpukuMatch = payoutSection.match(/[三3]連複[：:\s]+([\d-]+)\s*(?:→)?\s*([\d,]+)円\s*[\(（]?(\d+)番?人気[\)）]?/);
      if (sanrenpukuMatch) {
        payouts.sanrenpuku = [{
          combination: sanrenpukuMatch[1],
          payout: parseInt(sanrenpukuMatch[2].replace(/,/g, ''), 10),
          popularity: parseInt(sanrenpukuMatch[3], 10)
        }];
      }

      // 3連単: 10-9-6 6,940円 12番人気 または 1-12-10 → 23,020円 (69人気)
      const sanrentanMatch = payoutSection.match(/[三3]連単[：:\s]+([\d-]+)\s*(?:→)?\s*([\d,]+)円\s*[\(（]?(\d+)番?人気[\)）]?/);
      if (sanrentanMatch) {
        payouts.sanrentan = [{
          combination: sanrentanMatch[1],
          payout: parseInt(sanrentanMatch[2].replace(/,/g, ''), 10),
          popularity: parseInt(sanrentanMatch[3], 10)
        }];
      }

      return payouts;
    }

    function extractTimeData(text) {
      const timeData = {};

      console.log('[extractTimeData] 開始');
      console.log('[extractTimeData] 入力テキスト長:', text.length);

      // ハロンタイム: 12.7 - 11.1 - 12.0 - 12.4 - 12.6 - 12.2 - 12.4
      const furlongMatch = text.match(/ハロンタイム\s+([\d.\s-]+)/);
      if (furlongMatch) {
        const furlongStr = furlongMatch[1].trim();
        console.log('[extractTimeData] ハロンタイム文字列:', furlongStr);
        const furlongs = furlongStr.split(/\s*-\s*/).map(f => parseFloat(f.trim())).filter(f => !isNaN(f));
        console.log('[extractTimeData] ハロンタイム配列:', furlongs);
        if (furlongs.length > 0) {
          timeData.furlongTimes = furlongs;
        }
      }

      // 上り: 4F 49.6 - 3F 37.2
      const last3FMatch = text.match(/3F\s+([\d.]+)/);
      if (last3FMatch) {
        timeData.last3F = parseFloat(last3FMatch[1]);
        console.log('[extractTimeData] 上がり3F抽出成功:', timeData.last3F);
      }

      const last4FMatch = text.match(/4F\s+([\d.]+)/);
      if (last4FMatch) {
        timeData.last4F = parseFloat(last4FMatch[1]);
        console.log('[extractTimeData] 上がり4F抽出成功:', timeData.last4F);
      }

      const result = Object.keys(timeData).length > 0 ? timeData : null;
      console.log('[extractTimeData] 結果:', result);

      return result;
    }

    function extractCornerData(text) {
      const corners = [];

      // 中央競馬: 「3コーナー」「4コーナー」のような形式
      const cornerSection = text.match(/コーナー通過順位[\s\S]*?(?=払戻金|$)/);
      if (!cornerSection) {
        console.log('[extractCornerData] コーナー通過順セクション: 見つかりません');
        return null;
      }

      const cornerSectionText = cornerSection[0];
      console.log('[extractCornerData] コーナー通過順セクション抽出成功');

      // 中央競馬のコーナー通過順: 改行で分割して各コーナーを個別に処理
      // 例:
      // 1コーナー     7,10(5,12,11)(3,4,6)9(1,13)8-2
      // 2コーナー     7,10(5,11)12(3,4,6)9(1,13)8-2
      const lines = cornerSectionText.split('\n');

      for (const line of lines) {
        const trimmedLine = line.trim();
        if (!trimmedLine) continue;

        // コーナー番号とデータを抽出（全角・半角対応）
        const match = trimmedLine.match(/([１２３４1234])コーナー\s+(.*)/);
        if (!match) continue;

        const cornerNumber = match[1].replace(/[１]/g, '1').replace(/[２]/g, '2').replace(/[３]/g, '3').replace(/[４]/g, '4');
        const orderStr = match[2].trim();

        console.log('[extractCornerData] コーナーマッチ:', cornerNumber, 'コーナー');
        console.log('[extractCornerData] - orderStr:', orderStr);

        // 括弧やハイフンで分割して馬番を抽出
        // 例: (1,*10)(8,11,15)(9,14)3,12(2,5,6)-16,4-7-13 → 1,10,8,11,15,9,14,3,12,2,5,6,16,4,7,13
        const cleanedStr = orderStr.replace(/[*()\[\]]/g, ' ');  // 括弧とアスタリスクを空白に
        const parts = cleanedStr.split(/[\s\u3000-]+/).filter(p => p);  // 空白とハイフンで分割
        const order = [];
        for (const part of parts) {
          const nums = part.split(',').map(n => parseInt(n.trim(), 10)).filter(n => !isNaN(n));
          order.push(...nums);
        }

        if (order.length > 0) {
          const cornerName = `${cornerNumber}コーナー`;
          corners.push({
            corner: cornerName,
            order,
            orderString: orderStr  // 元の文字列を保存（括弧やハイフンを含む）
          });
          console.log('[extractCornerData] コーナー抽出成功:', cornerName, '頭数:', order.length);
        }
      }

      console.log('[extractCornerData] 抽出されたコーナー数:', corners.length);
      return corners.length > 0 ? corners : null;
    }

    function generateRaceCommentary(race, date, venue) {
      if (!race.results || race.results.length === 0) return '';

      const winner = race.results[0];
      const second = race.results[1];
      const third = race.results[2];
      const fourth = race.results[3];
      const favorite = race.results.find(h => h.popularity === 1);

      // 逃げ馬を特定（最初のコーナーで先頭にいた馬）
      let pacemaker = null;
      if (race.cornerData && race.cornerData.length > 0) {
        const firstCorner = race.cornerData[0];
        const leadHorseNum = firstCorner.order[0];
        pacemaker = race.results.find(h => h.number === leadHorseNum);
      }

      // 各馬の位置取りを判定する関数（序盤・中盤・終盤）
      const getPosition = (horseNum, timing = 'last') => {
        if (!race.cornerData || race.cornerData.length === 0) return null;

        let corner;
        if (timing === 'early') {
          // 序盤：最初のコーナー
          corner = race.cornerData[0];
        } else if (timing === 'mid') {
          // 中盤：中間のコーナー
          const midIndex = Math.floor(race.cornerData.length / 2);
          corner = race.cornerData[midIndex];
        } else {
          // 終盤：最終コーナー
          corner = race.cornerData[race.cornerData.length - 1];
        }

        const position = corner.order.indexOf(horseNum) + 1;
        if (position === 1) return { pos: position, label: '先頭' };
        if (position === 2) return { pos: position, label: '2番手' };
        if (position === 3) return { pos: position, label: '3番手' };
        if (position <= 5) return { pos: position, label: `${position}番手` };
        if (position <= 8) return { pos: position, label: '中団' };
        return { pos: position, label: '後方' };
      };

      // 全コーナーでの平均位置と一貫性を取得
      const getPositionConsistency = (horseNum) => {
        if (!race.cornerData || race.cornerData.length === 0) return null;

        const positions = [];
        for (const corner of race.cornerData) {
          const pos = corner.order.indexOf(horseNum) + 1;
          if (pos > 0) positions.push(pos);
        }

        if (positions.length === 0) return null;

        const avg = positions.reduce((a, b) => a + b, 0) / positions.length;
        const maxPos = Math.max(...positions);
        const minPos = Math.min(...positions);
        const range = maxPos - minPos;

        return {
          avgPos: avg,
          minPos: minPos,
          maxPos: maxPos,
          range: range,
          isConsistent: range <= 1 // 位置のばらつきが1以下なら一貫
        };
      };

      const winnerPosEarly = getPosition(winner.number, 'early');
      const winnerPosMid = getPosition(winner.number, 'mid');
      const winnerPosLast = getPosition(winner.number, 'last');
      const secondPosEarly = second ? getPosition(second.number, 'early') : null;
      const secondPosMid = second ? getPosition(second.number, 'mid') : null;
      const secondPosLast = second ? getPosition(second.number, 'last') : null;
      const thirdPosLast = third ? getPosition(third.number, 'last') : null;

      let commentary = '';

      // 冒頭：日付・競馬場・レース番号・条件（SEO対策）
      if (date && venue) {
        const [year, month, day] = date.split('-');
        const formattedDate = `${year}年${parseInt(month)}月${parseInt(day)}日`;
        const surfaceLabel = race.surface === 'ダート' ? 'ダ' : '芝';
        commentary += `${formattedDate}${venue}競馬${race.raceNumber}レース（${race.raceName || 'C3'} ${surfaceLabel}${race.distance}m・${race.horses}頭立）は、`;
      }

      // パターン1: 逃げ切り勝ち
      if (pacemaker && pacemaker.number === winner.number) {
        // 勝ち馬の逃げ
        commentary += `${winner.number}番${winner.name}（`;
        if (winner.popularity === 1) {
          commentary += `1番人気`;
        } else {
          commentary += `${winner.popularity}番人気`;
        }
        commentary += `）が`;
        commentary += `スタートからハナを切って主導権を握る展開。`;

        // 直線での粘り
        commentary += `直線でも粘り強く脚を使い、勝ちタイム${winner.time}で1着。`;

        // 2着馬
        if (second && secondPosLast) {
          commentary += `2着には${secondPosLast.label}から追い込んだ${second.number}番${second.name}（${second.popularity}番人気）、`;
        } else if (second) {
          commentary += `2着には${second.number}番${second.name}（${second.popularity}番人気）、`;
        }

        // 3着馬
        if (third) {
          commentary += `3着には${third.number}番${third.name}（${third.popularity}番人気）が入線。`;
        }

        // 三連単配当情報を追加（SEO対策）
        if (race.payouts?.sanrentan && race.payouts.sanrentan.length > 0) {
          const sanrentanPayout = race.payouts.sanrentan[0].payout;
          const sanrentanPop = race.payouts.sanrentan[0].popularity;
          const sanrentanCombo = race.payouts.sanrentan[0].combination;
          commentary += `三連単${sanrentanCombo}は${sanrentanPayout.toLocaleString()}円（${sanrentanPop}番人気）で決着した。`;
        }

        // 騎手・厩舎情報を追加（簡潔に、必ず句点で閉じる）
        commentary += `鞍上は${winner.jockey}騎手と${winner.trainer}厩舎のコンビだった。`;
      }
      // パターン2: 逃げ馬がいて、差し切りパターン
      else if (pacemaker && pacemaker.number !== winner.number) {
        // 逃げ馬の動き（人気も表示）
        commentary += `${pacemaker.number}番${pacemaker.name}（${pacemaker.popularity}番人気）がハナを切る展開の中、`;

        // 勝ち馬の追い込み
        commentary += `${winner.number}番${winner.name}（`;
        if (winner.popularity === 1) {
          commentary += `1番人気`;
        } else {
          commentary += `${winner.popularity}番人気`;
        }
        commentary += `）が`;

        // 全コーナーでの位置取りを分析
        const winnerConsistency = getPositionConsistency(winner.number);
        if (winnerConsistency) {
          const avgPos = winnerConsistency.avgPos;
          const isConsistent = winnerConsistency.isConsistent;
          const earlyPos = winnerPosEarly ? winnerPosEarly.pos : null;
          const lastPos = winnerPosLast ? winnerPosLast.pos : null;

          // 序盤と終盤で位置が変化したか判定
          if (earlyPos && lastPos && earlyPos >= 4 && lastPos <= 2) {
            // 序盤4番手以降 → 終盤2番手以内 = 先行
            commentary += `先行して脚を溜め`;
          } else if (isConsistent && avgPos <= 2.5) {
            // 一貫して2番手以内
            if (Math.round(avgPos) === 2) {
              commentary += `2番手で折り合い`;
            } else {
              commentary += `逃げ馬の直後で折り合い`;
            }
          } else if (avgPos >= 2 && avgPos <= 5) {
            // 2番手〜5番手（変動あり）
            commentary += `好位で脚を溜め`;
          } else if (avgPos > 5 && avgPos <= 8) {
            // 中団
            commentary += `中団で脚を溜め`;
          } else {
            // 後方
            commentary += `後方で追走待機し`;
          }
        } else if (winnerPosLast) {
          // コーナーデータなしの場合は最終コーナー
          if (winnerPosLast.pos >= 2 && winnerPosLast.pos <= 5) {
            commentary += `好位で脚を溜め`;
          } else {
            commentary += `${winnerPosLast.label}を追走し`;
          }
        }

        // 末脚と決着方法（4角位置で判断）
        // 4角位置で適切な動詞を選択
        if (winnerPosLast && winnerPosLast.pos <= 2) {
          // 4角1〜2位：抜け出し
          commentary += `直線で抜け出し、勝ちタイム${winner.time}で1着となった`;
        } else if (winnerPosLast && winnerPosLast.pos <= 5) {
          // 4角3〜5位：差し切り（動作は最大2つ）
          commentary += `直線では`;
          if (winner.lastFurlong && parseFloat(winner.lastFurlong) < 39.5) {
            // 上がり39.5秒未満：上がりをマーク
            commentary += `上がり${winner.lastFurlong}秒をマークして`;
          } else if (winner.lastFurlong) {
            // 上がり39.5秒以上：粘り強く
            commentary += `しぶとく`;
          }
          commentary += `差し切り、勝ちタイム${winner.time}で1着となった`;
        } else {
          // 4角6位以下：追い込んで差し切り（動作は最大2つ）
          commentary += `直線では`;
          if (winner.lastFurlong && parseFloat(winner.lastFurlong) < 39.5) {
            // 上がり39.5秒未満：上がりをマーク（「追い込んで」は省略して2連鎖に抑える）
            commentary += `上がり${winner.lastFurlong}秒をマークして差し切り`;
          } else if (winner.lastFurlong) {
            // 上がりあるが遅い：追い込んで差し切り
            commentary += `追い込んで差し切り`;
          } else {
            // 上がりデータなし：追い込んで差し切り
            commentary += `追い込んで差し切り`;
          }
          commentary += `、勝ちタイム${winner.time}で1着となった`;
        }

        // 騎手・厩舎情報を追加（簡潔に、必ず句点で閉じる）
        commentary += `。鞍上は${winner.jockey}騎手と${winner.trainer}厩舎のコンビ。`;

        // 2着・3着
        if (second && third) {
          // 2着馬の表現：逃げ馬かどうかで変更
          if (pacemaker && second.number === pacemaker.number) {
            // 逃げ馬が2着に粘った場合
            commentary += `2着には粘り込んだ${second.number}番${second.name}（${second.popularity}番人気）、`;
          } else if (secondPosLast && secondPosLast.pos === 1) {
            // その他の先行馬が2着
            commentary += `2着には先行した${second.number}番${second.name}（${second.popularity}番人気）、`;
          } else if (secondPosLast) {
            // その他（位置取りあり）
            commentary += `2着には${secondPosLast.label}から伸びた${second.number}番${second.name}（${second.popularity}番人気）、`;
          } else {
            // 位置取りなし
            commentary += `2着には${second.number}番${second.name}（${second.popularity}番人気）、`;
          }

          // 3着馬の表現：逃げ馬かどうかで変更
          if (pacemaker && third.number === pacemaker.number) {
            commentary += `3着には逃げた${third.number}番${third.name}（${third.popularity}番人気）が入線。`;
          } else {
            commentary += `3着には${third.number}番${third.name}（${third.popularity}番人気）が入線。`;
          }
        } else if (second) {
          if (pacemaker && second.number === pacemaker.number) {
            commentary += `2着には粘り込んだ${second.number}番${second.name}（${second.popularity}番人気）が続いた。`;
          } else if (secondPosLast && secondPosLast.pos === 1) {
            commentary += `2着には先行した${second.number}番${second.name}（${second.popularity}番人気）が続いた。`;
          } else {
            commentary += `2着には${second.number}番${second.name}（${second.popularity}番人気）が続いた。`;
          }
        }

        // 三連単配当情報を追加（SEO対策）
        if (race.payouts?.sanrentan && race.payouts.sanrentan.length > 0) {
          const sanrentanPayout = race.payouts.sanrentan[0].payout;
          const sanrentanPop = race.payouts.sanrentan[0].popularity;
          const sanrentanCombo = race.payouts.sanrentan[0].combination;
          commentary += `三連単${sanrentanCombo}は${sanrentanPayout.toLocaleString()}円（${sanrentanPop}番人気）で決着した。`;
        }
      }
      // パターン3: 逃げ馬情報なし
      else {
        // 勝ち馬
        commentary += `${winner.number}番${winner.name}（`;
        if (winner.popularity === 1) {
          commentary += `1番人気`;
        } else {
          commentary += `${winner.popularity}番人気`;
        }
        commentary += `）が`;

        if (winnerPosLast) {
          commentary += `${winnerPosLast.label}から抜け出し、`;
        }

        if (winner.lastFurlong) {
          commentary += `上がり${winner.lastFurlong}秒の末脚で`;
        }
        commentary += `勝ちタイム${winner.time}で1着`;

        // 騎手・厩舎情報を追加（簡潔に、必ず句点で閉じる）
        commentary += `。鞍上は${winner.jockey}騎手と${winner.trainer}厩舎のコンビ。`;

        if (second && third) {
          commentary += `2着に${second.number}番${second.name}（${second.popularity}番人気）、3着に${third.number}番${third.name}（${third.popularity}番人気）が入線。`;
        } else if (second) {
          commentary += `2着には${second.number}番${second.name}（${second.popularity}番人気）が続いた。`;
        }

        // 三連単配当情報を追加（SEO対策）
        if (race.payouts?.sanrentan && race.payouts.sanrentan.length > 0) {
          const sanrentanPayout = race.payouts.sanrentan[0].payout;
          const sanrentanPop = race.payouts.sanrentan[0].popularity;
          const sanrentanCombo = race.payouts.sanrentan[0].combination;
          commentary += `三連単${sanrentanCombo}は${sanrentanPayout.toLocaleString()}円（${sanrentanPop}番人気）で決着した。`;
        }
      }

      // 高配当の場合は馬単も追加
      if (race.payouts?.umatan && race.payouts.umatan.length > 0) {
        const umatanPayout = race.payouts.umatan[0].payout;
        if (umatanPayout >= 10000) {
          commentary += `馬単は${umatanPayout.toLocaleString()}円の高配当となった。`;
        }
      }

      // 250文字を超える場合はトリミング（最後の句点で切る）
      if (commentary.length > 260) {
        const trimmed = commentary.substring(0, 250);
        const lastPeriod = trimmed.lastIndexOf('。');
        if (lastPeriod > 200) {
          commentary = trimmed.substring(0, lastPeriod + 1);
        }
      }

      return commentary;
    }

