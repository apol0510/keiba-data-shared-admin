          html += `<div style="padding: 0.5rem 1rem; background: var(--bg-secondary); border-radius: 4px;"><strong>上がり4F:</strong> ${data.timeData.last4F}秒</div>`;
        }
        if (data.timeData.furlongTimes) {
          html += `<div style="padding: 0.5rem 1rem; background: var(--bg-secondary); border-radius: 4px;"><strong>ハロンタイム:</strong> ${data.timeData.furlongTimes.join(' - ')}</div>`;
