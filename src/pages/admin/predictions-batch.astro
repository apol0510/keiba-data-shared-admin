---
/**
 * 競馬予想データ管理画面（12レース一括入力版）
 * predictions-managerとは完全に別のファイル
 *
 * 機能:
 * - 12レース分のHTMLを一括貼り付け
 * - レース境界を自動検出して分割
 * - 各レースを個別に抽出・バリデーション
 * - 12レース分を1つのJSONファイルに保存
 *
 * 著作権対応: 記者名を印番号化（印3/印2/印1/印0）
 */
import BaseLayout from "../../layouts/BaseLayout.astro";

export const prerender = false;
---

<BaseLayout
  title="予想管理画面（一括入力）"
  description="12レース分の予想HTMLを一括で解析してデータ化します"
>
  <section class="admin-section">
    <div class="container">
      <h1 class="page-title">⚡ 南関競馬 予想管理（12レース一括）</h1>
      <p class="page-description">
        <strong>12レース分のHTMLを一度に貼り付けて一括処理できます</strong><br>
        ※ 個別入力が必要な場合は <a href="/admin/predictions-manager" style="color: var(--primary-end); text-decoration: underline;">予想管理（個別入力）</a> をご利用ください
      </p>

      <!-- 共通情報入力 -->
      <div class="card common-info-card">
        <h2>📅 開催情報（全レース共通）</h2>
        <div style="padding: var(--spacing-md); background: rgba(16, 185, 129, 0.1); border-left: 4px solid #10b981; border-radius: 4px; margin-bottom: var(--spacing-lg);">
          <strong style="color: #10b981;">✅ 自動検出機能</strong>
          <ul style="margin: var(--spacing-sm) 0 0 var(--spacing-lg); color: var(--text-secondary);">
            <li>解析時にHTMLから日付・競馬場を自動検出します</li>
            <li>入力フォームの値は自動的に上書きされます</li>
            <li>保存前のプレビューで日付・競馬場を確認してください</li>
          </ul>
        </div>
        <div class="common-info-grid">
          <div class="form-group">
            <label for="commonDate">開催日</label>
            <input
              type="date"
              id="commonDate"
              class="form-input"
              value={new Date().toISOString().split('T')[0]}
            />
            <small style="color: var(--text-secondary); display: block; margin-top: 0.25rem;">
              ※ HTMLから自動検出された場合は上書きされます
            </small>
          </div>
          <div class="form-group">
            <label for="commonVenue">競馬場</label>
            <select id="commonVenue" class="form-select">
              <option value="船橋">船橋</option>
              <option value="大井">大井</option>
              <option value="川崎">川崎</option>
              <option value="浦和">浦和</option>
            </select>
            <small style="color: var(--text-secondary); display: block; margin-top: 0.25rem;">
              ※ HTMLから自動検出された場合は上書きされます
            </small>
          </div>
        </div>
      </div>

      <!-- 一括入力エリア -->
      <div class="card input-card">
        <h2>📋 12レース分の予想HTML貼り付け</h2>
        <p style="color: var(--text-secondary); margin-bottom: var(--spacing-md);">
          予想サイトから<strong>第1R〜第12R</strong>までのHTMLを全てコピーして、下のテキストエリアに貼り付けてください。<br>
          自動的にレースごとに分割・解析します。
        </p>

        <textarea
          id="batchInput"
          class="batch-textarea"
          rows="20"
          placeholder="12レース分のHTMLを貼り付けてください

例:
<div class='racename'>
  2026年1月30日 大井競馬 第1R
  ...
</div>
<table class='default syutuba'>...</table>

<div class='racename'>
  2026年1月30日 大井競馬 第2R
  ...
</div>
<table class='default syutuba'>...</table>

... (第12Rまで)"
        ></textarea>

        <div class="action-buttons" style="margin-top: var(--spacing-lg);">
          <button
            type="button"
            class="btn btn-primary btn-large"
            onclick="parseBatchRaces()"
          >
            🔍 12レース一括解析
          </button>
        </div>

        <div id="parseStatus" class="parse-status" style="display: none;"></div>
      </div>

      <!-- プレビューエリア -->
      <div id="previewSection" class="preview-section" style="display: none;">
        <div class="card">
          <h2>✅ 解析結果プレビュー</h2>
          <div id="raceSummary" class="race-summary"></div>

          <!-- 各レースの詳細プレビュー -->
          <div id="raceDetails" class="race-details"></div>

          <!-- 一括保存ボタン -->
          <div class="action-buttons" style="margin-top: var(--spacing-2xl);">
            <button
              type="button"
              class="btn btn-secondary"
              onclick="copyAllJSON()"
            >
              📋 JSON全コピー
            </button>
            <button
              type="button"
              id="saveAllBtn"
              class="btn btn-success btn-large"
              onclick="saveAllRacesToGit()"
            >
              🚀 12レース一括保存してGit Push
            </button>
          </div>
          <div id="saveStatus" class="save-status" style="display: none;"></div>
        </div>
      </div>

      <!-- 使用方法 -->
      <div class="card info-card">
        <h2>📖 使用方法</h2>
        <ol>
          <li><strong>開催日・競馬場</strong>を上部で選択</li>
          <li>予想サイトから<strong>第1R〜第12R全てのHTML</strong>をコピー</li>
          <li>上のテキストエリアに貼り付け</li>
          <li>「12レース一括解析」ボタンをクリック</li>
          <li>プレビューで各レースの抽出結果を確認</li>
          <li>「12レース一括保存してGit Push」で keiba-data-shared に保存</li>
          <li>自動的に各予想サイトに反映されます 🎉</li>
        </ol>

        <h3>💡 ポイント</h3>
        <ul>
          <li>12レース分を一度に処理できます（効率重視）</li>
          <li>エラーが出たレースは赤色で表示されます</li>
          <li>慎重に確認したい場合は <a href="/admin/predictions-manager" style="color: var(--primary-end);">個別入力</a> をご利用ください</li>
          <li>既存データは自動的にマージされます（上書きされません）</li>
        </ul>
      </div>
    </div>
  </section>

  <style>
    .admin-section {
      padding: var(--spacing-2xl) 0;
      min-height: 100vh;
    }

    .page-title {
      font-size: 2rem;
      margin-bottom: var(--spacing-md);
      text-align: center;
    }

    .page-description {
      text-align: center;
      color: var(--text-secondary);
      margin-bottom: var(--spacing-2xl);
      line-height: 1.6;
    }

    .common-info-card {
      max-width: 800px;
      margin: 0 auto var(--spacing-2xl);
    }

    .common-info-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--spacing-lg);
      margin-top: var(--spacing-md);
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-sm);
    }

    .form-group label {
      font-weight: 600;
      color: var(--text-primary);
    }

    .form-input,
    .form-select {
      padding: var(--spacing-sm) var(--spacing-md);
      border: 1px solid var(--border-color);
      border-radius: var(--radius-md);
      background: var(--bg-secondary);
      color: var(--text-primary);
      font-size: 1rem;
    }

    .input-card {
      max-width: 1200px;
      margin: 0 auto var(--spacing-2xl);
    }

    .batch-textarea {
      width: 100%;
      padding: var(--spacing-md);
      border: 1px solid var(--border-color);
      border-radius: var(--radius-md);
      background: var(--bg-secondary);
      color: var(--text-primary);
      font-family: 'Courier New', monospace;
      font-size: 0.875rem;
      resize: vertical;
      min-height: 400px;
    }

    .action-buttons {
      display: flex;
      gap: var(--spacing-md);
      flex-wrap: wrap;
    }

    .btn-large {
      flex: 1;
      min-width: 200px;
    }

    .parse-status,
    .save-status {
      margin-top: var(--spacing-md);
      padding: var(--spacing-md);
      border-radius: var(--radius-md);
      font-weight: 600;
      display: none;
    }

    .parse-status.success,
    .save-status.success {
      background: rgba(16, 185, 129, 0.1);
      border-left: 4px solid var(--success);
      color: var(--success);
    }

    .parse-status.error,
    .save-status.error {
      background: rgba(239, 68, 68, 0.1);
      border-left: 4px solid var(--error);
      color: var(--error);
    }

    .parse-status.loading,
    .save-status.loading {
      background: rgba(59, 130, 246, 0.1);
      border-left: 4px solid var(--primary-end);
      color: var(--primary-end);
    }

    .preview-section {
      max-width: 1200px;
      margin: 0 auto var(--spacing-2xl);
    }

    .race-summary {
      margin-bottom: var(--spacing-xl);
      padding: var(--spacing-lg);
      background: var(--bg-secondary);
      border-radius: var(--radius-md);
    }

    .race-details {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-md);
    }

    .race-detail-card {
      border: 2px solid var(--border-color);
      border-radius: var(--radius-md);
      overflow: hidden;
    }

    .race-detail-card.success {
      border-color: var(--success);
    }

    .race-detail-card.error {
      border-color: var(--error);
    }

    .race-detail-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: var(--spacing-lg);
      cursor: pointer;
      font-weight: 600;
      font-size: 1.25rem;
      user-select: none;
      background: var(--bg-secondary);
    }

    .race-detail-header:hover {
      background: var(--bg-tertiary);
    }

    .race-number-badge {
      color: var(--primary-end);
      font-size: 1.5rem;
    }

    .race-status-badge {
      font-size: 0.875rem;
      padding: 4px 12px;
      border-radius: var(--radius-sm);
      font-weight: 600;
    }

    .race-status-badge.success {
      background: rgba(16, 185, 129, 0.2);
      color: var(--success);
    }

    .race-status-badge.error {
      background: rgba(239, 68, 68, 0.2);
      color: var(--error);
    }

    .race-detail-content {
      padding: var(--spacing-lg);
      border-top: 1px solid var(--border-color);
    }

    .info-card {
      max-width: 1200px;
      margin: var(--spacing-2xl) auto 0;
    }

    .info-card ol,
    .info-card ul {
      margin-left: var(--spacing-lg);
      color: var(--text-secondary);
    }

    .info-card li {
      margin-bottom: var(--spacing-sm);
    }

    @media (max-width: 768px) {
      .common-info-grid {
        grid-template-columns: 1fr;
      }

      .action-buttons {
        flex-direction: column;
      }

      .btn-large {
        width: 100%;
      }
    }
  </style>

  <script is:inline>
    // グローバル変数
    let batchResults = [];

    // 一括解析メイン関数
    function parseBatchRaces() {
      const textarea = document.getElementById('batchInput');
      const html = textarea.value;

      if (!html.trim()) {
        alert('12レース分のHTMLを入力してください');
        return;
      }

      const statusDiv = document.getElementById('parseStatus');
      statusDiv.style.display = 'block';
      statusDiv.className = 'parse-status loading';
      statusDiv.textContent = '🔍 12レース分を解析中...';

      try {
        // レース境界で分割
        const raceHTMLs = splitRacesHTML(html);
        console.log(`[parseBatchRaces] 検出したレース数: ${raceHTMLs.length}`);

        if (raceHTMLs.length === 0) {
          statusDiv.className = 'parse-status error';
          statusDiv.textContent = '❌ レースが検出できませんでした。HTMLの形式を確認してください。';
          return;
        }

        // 【新規】HTMLから日付・競馬場を自動抽出
        const firstRaceHTML = raceHTMLs[0];
        const autoDetected = extractRaceInfo(firstRaceHTML);
        const detectedDate = autoDetected.date; // "2026年3月12日"
        const detectedVenue = extractVenueFromHTML(firstRaceHTML); // "船橋" or "大井" etc

        console.log(`[parseBatchRaces] 自動検出: 日付=${detectedDate}, 競馬場=${detectedVenue}`);

        // 共通情報取得
        const commonDate = document.getElementById('commonDate').value;
        const commonVenue = document.getElementById('commonVenue').value;

        // 【新規】日付・競馬場の一致チェック
        let finalDate = commonDate;
        let finalVenue = commonVenue;
        let hasDateMismatch = false;
        let hasVenueMismatch = false;

        // 日付チェック（YYYY-MM-DD形式に変換して比較）
        if (detectedDate) {
          const detectedDateISO = convertJapaneseDateToISO(detectedDate);
          if (detectedDateISO && detectedDateISO !== commonDate) {
            hasDateMismatch = true;
            console.warn(`[parseBatchRaces] 日付不一致: 入力フォーム=${commonDate}, HTML=${detectedDateISO}`);
          }
        }

        // 競馬場チェック
        if (detectedVenue && detectedVenue !== commonVenue) {
          hasVenueMismatch = true;
          console.warn(`[parseBatchRaces] 競馬場不一致: 入力フォーム=${commonVenue}, HTML=${detectedVenue}`);
        }

        // 【修正】不一致がある場合、自動的にHTMLの情報を使用（確認ダイアログなし）
        if (hasDateMismatch || hasVenueMismatch) {
          // HTMLの情報を自動的に使用
          if (hasDateMismatch) {
            finalDate = convertJapaneseDateToISO(detectedDate);
            document.getElementById('commonDate').value = finalDate;
            console.log(`[parseBatchRaces] 日付をHTMLから自動設定: ${finalDate} (フォーム: ${commonDate})`);
          }
          if (hasVenueMismatch) {
            finalVenue = detectedVenue;
            document.getElementById('commonVenue').value = finalVenue;
            console.log(`[parseBatchRaces] 競馬場をHTMLから自動設定: ${finalVenue} (フォーム: ${commonVenue})`);
          }
        }

        const date = finalDate;
        const venue = finalVenue;

        // 各レースを解析
        batchResults = [];
        let successCount = 0;
        let errorCount = 0;

        raceHTMLs.forEach((raceHTML, index) => {
          const raceNum = index + 1;
          try {
            const extracted = extractPredictions(raceHTML);
            if (!extracted.success) {
              batchResults.push({
                raceNumber: raceNum,
                success: false,
                errors: extracted.errors,
              });
              errorCount++;
              return;
            }

            const raceInfo = extractRaceInfo(raceHTML);
            const scored = scoreAndAssign(extracted);

            const data = {
              version: "1.0.0",
              createdAt: new Date().toISOString(),
              lastUpdated: new Date().toISOString(),
              raceInfo: {
                date: raceInfo.date,
                track: venue,
                raceNumber: `${raceNum}R`,
                raceName: raceInfo.raceName,
                raceSubtitle: raceInfo.raceSubtitle,
                raceType: raceInfo.raceType,
                distance: raceInfo.distance,
                surface: raceInfo.surface,
                startTime: raceInfo.startTime,
              },
              horses: scored.horses.map(h => ({
                number: h.number,
                name: h.name,
                umacd: h.umacd,
                marks: h.marks,
                seirei: h.seirei,
                kisyu: h.kisyu,
                kinryo: h.kinryo,
                kyusya: h.kyusya,
                totalScore: h.totalScore,
                assignment: h.assignment,
              })),
              predictors: scored.predictors,
              assignments: {
                main: scored.assignments.main?.number,
                sub: scored.assignments.sub?.number,
                hole: scored.assignments.hole?.number,
                connectTop: scored.assignments.connectTop?.number,
                connect: scored.assignments.connect.map(h => h.number),
                reserve: scored.assignments.reserve.map(h => h.number),
                none: scored.assignments.none.map(h => h.number),
              },
            };

            batchResults.push({
              raceNumber: raceNum,
              success: true,
              data,
              date,
              venue,
            });
            successCount++;

          } catch (error) {
            console.error(`第${raceNum}R解析エラー:`, error);
            batchResults.push({
              raceNumber: raceNum,
              success: false,
              errors: [error.message],
            });
            errorCount++;
          }
        });

        // ステータス更新
        statusDiv.className = errorCount > 0 ? 'parse-status error' : 'parse-status success';
        statusDiv.innerHTML = `
          ✅ 解析完了: 成功 ${successCount}レース / エラー ${errorCount}レース<br>
          ${errorCount > 0 ? '⚠️ エラーが出たレースは下で確認してください' : ''}
        `;

        // プレビュー表示
        displayBatchPreview(batchResults, date, venue);

      } catch (error) {
        statusDiv.className = 'parse-status error';
        statusDiv.innerHTML = `❌ エラー: ${error.message}`;
        console.error(error);
      }
    }

    // レースHTMLを分割
    function splitRacesHTML(html) {
      const races = [];

      // パターン1: <div class='racename'> または <div class="racename"> で分割
      const racenamePattern = /<div\s+class=["']racename["']\s*>/gi;

      // 各レースの開始位置を見つける
      const matches = [];
      let match;
      racenamePattern.lastIndex = 0; // リセット
      while ((match = racenamePattern.exec(html)) !== null) {
        matches.push(match.index);
      }

      console.log(`[splitRacesHTML] racename検出数: ${matches.length}個`);

      // 各レースのHTMLを抽出（次のracenameまで、または最後まで）
      for (let i = 0; i < matches.length; i++) {
        const startIndex = matches[i];
        const endIndex = i < matches.length - 1 ? matches[i + 1] : html.length;
        const raceHTML = html.substring(startIndex, endIndex);

        // 最低限のバリデーション（tableが含まれているか）
        if (raceHTML.includes('<table')) {
          races.push(raceHTML);
          console.log(`[splitRacesHTML] レース${i + 1}: ${raceHTML.length}文字`);
        } else {
          console.warn(`[splitRacesHTML] レース${i + 1}: tableが見つからない`);
        }
      }

      console.log(`[splitRacesHTML] 最終的に検出したレース数: ${races.length}`);
      return races;
    }

    // プレビュー表示
    function displayBatchPreview(results, date, venue) {
      const previewSection = document.getElementById('previewSection');
      const raceSummary = document.getElementById('raceSummary');
      const raceDetails = document.getElementById('raceDetails');

      const successResults = results.filter(r => r.success);
      const errorResults = results.filter(r => !r.success);

      // 【新規】保存先情報を取得
      const saveDate = successResults.length > 0 ? successResults[0].date : '';
      const saveVenue = successResults.length > 0 ? successResults[0].venue : '';

      // サマリー表示（日付・競馬場を明示）
      raceSummary.innerHTML = `
        <h3 style="margin-bottom: var(--spacing-md);">📊 解析サマリー</h3>

        ${successResults.length > 0 ? `
          <div style="padding: var(--spacing-lg); background: linear-gradient(135deg, rgba(59, 130, 246, 0.15), rgba(16, 185, 129, 0.15)); border: 2px solid var(--primary-end); border-radius: var(--radius-md); margin-bottom: var(--spacing-lg);">
            <h4 style="margin-bottom: var(--spacing-sm); color: var(--primary-end);">💾 保存先情報</h4>
            <div style="display: grid; grid-template-columns: auto 1fr; gap: var(--spacing-sm) var(--spacing-md); font-size: 1.125rem;">
              <strong>📅 日付:</strong>
              <span style="font-weight: 600; color: var(--text-primary);">${saveDate}</span>
              <strong>🏇 競馬場:</strong>
              <span style="font-weight: 600; color: var(--text-primary);">${saveVenue}</span>
              <strong>📂 保存ファイル:</strong>
              <span style="font-family: monospace; font-size: 0.875rem; color: var(--text-secondary);">nankan/predictions/${saveDate.substring(0,4)}/${saveDate.substring(5,7)}/${saveDate}.json</span>
            </div>
          </div>
        ` : ''}

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: var(--spacing-md);">
          <div style="padding: var(--spacing-md); background: rgba(16, 185, 129, 0.1); border-radius: var(--radius-md);">
            <div style="font-size: 2rem; font-weight: 700; color: var(--success);">${successResults.length}</div>
            <div style="color: var(--text-secondary);">成功</div>
          </div>
          <div style="padding: var(--spacing-md); background: rgba(239, 68, 68, 0.1); border-radius: var(--radius-md);">
            <div style="font-size: 2rem; font-weight: 700; color: var(--error);">${errorResults.length}</div>
            <div style="color: var(--text-secondary);">エラー</div>
          </div>
          <div style="padding: var(--spacing-md); background: rgba(59, 130, 246, 0.1); border-radius: var(--radius-md);">
            <div style="font-size: 2rem; font-weight: 700; color: var(--primary-end);">${results.length}</div>
            <div style="color: var(--text-secondary);">合計</div>
          </div>
        </div>
      `;

      // 各レースの詳細
      let detailsHTML = '';
      results.forEach(result => {
        const statusClass = result.success ? 'success' : 'error';
        const statusText = result.success ? '✅ 成功' : '❌ エラー';

        detailsHTML += `
          <details class="race-detail-card ${statusClass}">
            <summary class="race-detail-header">
              <span class="race-number-badge">第${result.raceNumber}R</span>
              <span class="race-status-badge ${statusClass}">${statusText}</span>
            </summary>
            <div class="race-detail-content">
              ${result.success ? generateRacePreviewHTML(result) : generateErrorHTML(result)}
            </div>
          </details>
        `;
      });

      raceDetails.innerHTML = detailsHTML;
      previewSection.style.display = 'block';
    }

    // レースプレビューHTML生成（詳細版）
    function generateRacePreviewHTML(result) {
      const { data } = result;

      let html = `
        <div style="margin-bottom: 1rem; padding: 1rem; background: var(--bg-tertiary); border-radius: 8px;">
          <h4 style="margin-bottom: 0.5rem;">📋 レース情報</h4>
          <p><strong>発走:</strong> ${data.raceInfo.startTime || '-'}</p>
          <p><strong>レース名:</strong> ${data.raceInfo.raceName || '-'}</p>
          ${data.raceInfo.raceSubtitle ? `<p><strong>サブタイトル:</strong> ${data.raceInfo.raceSubtitle}</p>` : ''}
          ${data.raceInfo.raceType ? `<p><strong>条件:</strong> ${data.raceInfo.raceType}</p>` : ''}
          <p><strong>距離:</strong> ${data.raceInfo.surface}${data.raceInfo.distance}m</p>
          <p><strong>出走頭数:</strong> ${data.horses.length}頭</p>
        </div>
      `;

      // 振り分け結果（カード形式・7種類全表示）
      html += '<div style="margin-bottom: 1.5rem;">';
      html += '<h4 style="margin-bottom: 0.75rem;">🎯 自動振り分け結果</h4>';
      html += '<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 0.75rem;">';

      const formatHorse = (horse) => horse ? `${horse.number}番 ${horse.name} (${horse.totalScore}点)` : "なし";

      const createCard = (bgColor, borderColor, title, horses) => {
        const horsesList = Array.isArray(horses)
          ? horses.map(h => `<li style="margin: 0.25rem 0;">${formatHorse(h)}</li>`).join("")
          : `<li style="margin: 0.25rem 0;">${formatHorse(horses)}</li>`;

        const isEmpty = (Array.isArray(horses) && horses.length === 0) || (!Array.isArray(horses) && !horses);
        const content = isEmpty ? "<li>なし</li>" : horsesList;

        return `
          <div style="background: ${bgColor}; border-left: 4px solid ${borderColor}; border-radius: 4px; padding: 0.75rem;">
            <div style="font-weight: 600; margin-bottom: 0.5rem; color: ${borderColor};">${title}</div>
            <ul style="list-style: none; padding: 0; margin: 0; font-size: 0.875rem;">${content}</ul>
          </div>
        `;
      };

      html += createCard('rgba(239, 68, 68, 0.1)', '#ef4444', '◎ 本命', data.horses.find(h => h.number === data.assignments.main));
      html += createCard('rgba(59, 130, 246, 0.1)', '#3b82f6', '○ 対抗', data.horses.find(h => h.number === data.assignments.sub));
      html += createCard('rgba(245, 158, 11, 0.1)', '#f59e0b', '▲ 単穴', data.horses.find(h => h.number === data.assignments.hole));
      html += createCard('rgba(16, 185, 129, 0.1)', '#10b981', '△ 連下最上位', data.horses.find(h => h.number === data.assignments.connectTop));

      const connectHorses = data.assignments.connect.map(num => data.horses.find(h => h.number === num)).filter(h => h);
      html += createCard('rgba(139, 92, 246, 0.1)', '#8b5cf6', '△ 連下 (1~3頭)', connectHorses);

      const reserveHorses = data.assignments.reserve.map(num => data.horses.find(h => h.number === num)).filter(h => h);
      html += createCard('rgba(100, 116, 139, 0.1)', '#64748b', '× 補欠 (1点以上)', reserveHorses);

      const noneHorses = data.assignments.none.map(num => data.horses.find(h => h.number === num)).filter(h => h);
      html += createCard('rgba(156, 163, 175, 0.1)', '#9ca3af', '無 (0点)', noneHorses);

      html += '</div>';
      html += '</div>';

      // 全馬の詳細テーブル（印4→印1の順に表示）
      html += '<div style="margin-bottom: 1rem;">';
      html += '<h4 style="margin-bottom: 0.5rem;">🏇 全馬詳細</h4>';
      html += '<div style="overflow-x: auto;">';
      html += '<table style="width: 100%; border-collapse: collapse; font-size: 0.875rem;">';
      html += '<thead><tr style="background: var(--bg-tertiary);">';
      html += '<th style="padding: 0.5rem; border: 1px solid var(--border-color);">馬番</th>';

      // 印を逆順（印4→印1）で表示
      data.predictors.forEach(p => {
        html += `<th style="padding: 0.5rem; border: 1px solid var(--border-color);">${p}</th>`;
      });

      html += '<th style="padding: 0.5rem; border: 1px solid var(--border-color);">馬名</th>';
      html += '<th style="padding: 0.5rem; border: 1px solid var(--border-color);">性齢</th>';
      html += '<th style="padding: 0.5rem; border: 1px solid var(--border-color);">騎手</th>';
      html += '<th style="padding: 0.5rem; border: 1px solid var(--border-color);">厩舎</th>';
      html += '<th style="padding: 0.5rem; border: 1px solid var(--border-color);">合計点</th>';
      html += '<th style="padding: 0.5rem; border: 1px solid var(--border-color);">振り分け</th>';
      html += '</tr></thead><tbody>';

      // 点数順にソート
      const sortedHorses = [...data.horses].sort((a, b) => b.totalScore - a.totalScore);

      sortedHorses.forEach(horse => {
        html += '<tr>';
        html += `<td style="padding: 0.5rem; border: 1px solid var(--border-color); text-align: center;">${horse.number}</td>`;

        // 印を逆順で表示
        data.predictors.forEach(p => {
          const mark = horse.marks[p] || '-';
          html += `<td style="padding: 0.5rem; border: 1px solid var(--border-color); text-align: center;">${mark}</td>`;
        });

        html += `<td style="padding: 0.5rem; border: 1px solid var(--border-color);">${horse.name}</td>`;
        html += `<td style="padding: 0.5rem; border: 1px solid var(--border-color); text-align: center;">${horse.seirei || '-'}</td>`;
        html += `<td style="padding: 0.5rem; border: 1px solid var(--border-color); text-align: center;">${horse.kisyu || '-'}</td>`;
        html += `<td style="padding: 0.5rem; border: 1px solid var(--border-color); text-align: center;">${horse.kyusya || '-'}</td>`;
        html += `<td style="padding: 0.5rem; border: 1px solid var(--border-color); text-align: center; font-weight: 600;">${horse.totalScore}</td>`;
        html += `<td style="padding: 0.5rem; border: 1px solid var(--border-color); text-align: center;">${horse.assignment}</td>`;
        html += '</tr>';
      });

      html += '</tbody></table>';
      html += '</div>';
      html += '</div>';

      return html;
    }

