---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="管理画面">
  <section class="hero">
    <div class="container">
      <h1>📊 KEIBA Data Shared Admin</h1>
      <p class="lead">競馬データ共有管理画面</p>

      <!-- よく使う機能（一括入力） -->
      <h2 style="margin-top: 2rem; margin-bottom: 1rem; text-align: center;">⚡ 一括入力（推奨）</h2>
      <div class="card-grid">
        <a href="/admin/results-batch" class="feature-card">
          <div class="card-icon">⚡</div>
          <h2>南関競馬 結果管理（一括）</h2>
          <p>南関競馬の結果を一括入力</p>
          <span class="badge badge-nankan">南関</span>
        </a>

        <a href="/admin/predictions-batch" class="feature-card">
          <div class="card-icon">⚡</div>
          <h2>南関競馬 予想管理（一括）</h2>
          <p>12レース分を一度に処理・効率化</p>
          <span class="badge badge-nankan">南関</span>
        </a>

        <a href="/admin/results-manager-jra-batch" class="feature-card">
          <div class="card-icon">⚡</div>
          <h2>JRA 結果管理（一括）</h2>
          <p>中央競馬（JRA）12レース分を一括入力</p>
          <span class="badge badge-jra">JRA</span>
        </a>

        <a href="/admin/predictions-manager-jra-batch" class="feature-card">
          <div class="card-icon">⚡</div>
          <h2>JRA 予想管理（一括）</h2>
          <p>中央競馬（JRA）12レース分を一括入力</p>
          <span class="badge badge-jra">JRA</span>
        </a>

        <a href="/admin/results-manager-local" class="feature-card">
          <div class="card-icon">🏇</div>
          <h2>地方競馬 結果管理</h2>
          <p>地方競馬の結果を一括入力</p>
          <span class="badge badge-local">地方</span>
        </a>
      </div>

      <!-- 出走表管理（全競馬場対応） -->
      <h2 style="margin-top: 3rem; margin-bottom: 1rem; text-align: center;">📋 出走表管理</h2>
      <div class="card-grid">
        <a href="/admin/entries-manager" class="feature-card" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); color: white; border: none; box-shadow: 0 8px 30px rgba(16, 185, 129, 0.3);">
          <div class="card-icon" style="font-size: 4rem; background: rgba(255, 255, 255, 0.2); width: 100px; height: 100px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem;">📋</div>
          <h2 style="color: white; font-size: 1.5rem; margin-bottom: 0.5rem;">出走表管理</h2>
          <p style="color: rgba(255, 255, 255, 0.9); font-size: 1rem; margin-bottom: 1rem;">全競馬場対応（JRA・南関・地方）</p>
          <p style="color: rgba(255, 255, 255, 0.8); font-size: 0.9rem; margin-bottom: 1rem;">出走表データ（近5走含む）を入力・保存</p>
          <div class="badge-group">
            <span class="badge" style="background: rgba(255, 255, 255, 0.3); color: white; border: 1px solid rgba(255, 255, 255, 0.5);">JRA</span>
            <span class="badge" style="background: rgba(255, 255, 255, 0.3); color: white; border: 1px solid rgba(255, 255, 255, 0.5);">南関</span>
            <span class="badge" style="background: rgba(255, 255, 255, 0.3); color: white; border: 1px solid rgba(255, 255, 255, 0.5);">地方</span>
            <span class="badge" style="background: #FFD700; color: #333; font-weight: bold; animation: pulse 2s infinite;">NEW</span>
          </div>
        </a>
      </div>

      <!-- コンピ指数管理（全競馬場対応） -->
      <h2 style="margin-top: 3rem; margin-bottom: 1rem; text-align: center;">📊 コンピ指数管理</h2>
      <div class="card-grid">
        <a href="/admin/computer-manager" class="feature-card" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; box-shadow: 0 8px 30px rgba(102, 126, 234, 0.3);">
          <div class="card-icon" style="font-size: 4rem; background: rgba(255, 255, 255, 0.2); width: 100px; height: 100px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem;">📊</div>
          <h2 style="color: white; font-size: 1.5rem; margin-bottom: 0.5rem;">コンピ指数管理</h2>
          <p style="color: rgba(255, 255, 255, 0.9); font-size: 1rem; margin-bottom: 1rem;">全競馬場対応（JRA・南関・地方）</p>
          <p style="color: rgba(255, 255, 255, 0.8); font-size: 0.9rem; margin-bottom: 1rem;">コンピ指数データを入力・保存<br>予想データと自動補完で効率化</p>
          <div class="badge-group">
            <span class="badge" style="background: rgba(255, 255, 255, 0.3); color: white; border: 1px solid rgba(255, 255, 255, 0.5);">JRA</span>
            <span class="badge" style="background: rgba(255, 255, 255, 0.3); color: white; border: 1px solid rgba(255, 255, 255, 0.5);">南関</span>
            <span class="badge" style="background: rgba(255, 255, 255, 0.3); color: white; border: 1px solid rgba(255, 255, 255, 0.5);">地方</span>
            <span class="badge" style="background: #FFD700; color: #333; font-weight: bold; animation: pulse 2s infinite;">NEW</span>
          </div>
        </a>
      </div>

      <!-- 個別入力（コンパクト表示） -->
      <h2 style="margin-top: 3rem; margin-bottom: 1rem; text-align: center; font-size: 1.25rem; color: var(--text-secondary);">🎯 個別入力（必要時のみ）</h2>
      <div class="card-grid-compact">
        <a href="/admin/results-manager" class="feature-card-compact">
          <div class="card-icon-compact">🏇</div>
          <h3>南関 結果（個別）</h3>
          <span class="badge badge-nankan">南関</span>
        </a>

        <a href="/admin/predictions-manager" class="feature-card-compact">
          <div class="card-icon-compact">🎯</div>
          <h3>南関 予想（個別）</h3>
          <span class="badge badge-nankan">南関</span>
        </a>

        <a href="/admin/results-manager-jra" class="feature-card-compact">
          <div class="card-icon-compact">🎌</div>
          <h3>JRA 結果（個別）</h3>
          <span class="badge badge-jra">JRA</span>
        </a>

        <a href="/admin/predictions-manager-jra" class="feature-card-compact">
          <div class="card-icon-compact">🎯</div>
          <h3>JRA 予想（個別）</h3>
          <span class="badge badge-jra">JRA</span>
        </a>
      </div>

      <!-- その他リンク -->
      <h2 style="margin-top: 3rem; margin-bottom: 1rem; text-align: center; font-size: 1.25rem; color: var(--text-secondary);">📂 リポジトリ</h2>
      <div class="card-grid-compact">
        <a href="https://github.com/apol0510/keiba-data-shared" target="_blank" class="feature-card-compact">
          <div class="card-icon-compact">📂</div>
          <h3>Data Repository</h3>
        </a>

        <a href="https://github.com/apol0510/keiba-data-shared-admin" target="_blank" class="feature-card-compact">
          <div class="card-icon-compact">⚙️</div>
          <h3>Admin Repository</h3>
        </a>
      </div>

      <div class="info-section">
        <h2>🎯 役割分担</h2>
        <div class="roles">
          <div class="role-card">
            <h3>📊 keiba-data-shared</h3>
            <p>データ専用リポジトリ</p>
            <ul>
              <li>nankan/results/ - 南関競馬結果データ</li>
              <li>nankan/predictions/ - 南関競馬予想データ</li>
              <li>jra/results/ - 中央競馬（JRA）結果データ</li>
              <li>jra/predictions/ - 中央競馬（JRA）予想データ NEW</li>
              <li>parser/ - パーサーライブラリ</li>
            </ul>
          </div>
          <div class="role-card">
            <h3>⚙️ keiba-data-shared-admin</h3>
            <p>管理画面専用リポジトリ</p>
            <ul>
              <li>南関競馬: 結果入力（個別/一括）</li>
              <li>南関競馬: 予想変換（個別/一括）</li>
              <li>中央競馬（JRA）: 結果入力（個別/一括）</li>
              <li>中央競馬（JRA）: 予想変換（個別/一括）NEW</li>
              <li>GitHub API - データ保存</li>
              <li>Netlify Functions - バックエンド</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    .hero {
      padding: var(--spacing-2xl) 0;
      min-height: 80vh;
      text-align: center;
    }

    h1 {
      font-size: 3rem;
      margin-bottom: var(--spacing-md);
    }

    .lead {
      font-size: 1.5rem;
      color: var(--text-secondary);
      margin-bottom: var(--spacing-2xl);
    }

    .card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: var(--spacing-xl);
      margin-top: var(--spacing-2xl);
    }

    .feature-card {
      padding: var(--spacing-xl);
      background: var(--bg-secondary);
      border-radius: var(--radius-lg);
      text-decoration: none;
      color: inherit;
      transition: all 0.3s ease;
      border: 2px solid transparent;
      position: relative;
    }

    .feature-card:hover {
      transform: translateY(-4px);
      border-color: var(--primary-end);
      background: var(--bg-tertiary);
    }

    .card-icon {
      font-size: 3rem;
      margin-bottom: var(--spacing-md);
    }

    .feature-card h2 {
      font-size: 1.5rem;
      margin-bottom: var(--spacing-sm);
    }

    .feature-card p {
      color: var(--text-secondary);
    }

    .badge {
      display: inline-block;
      padding: var(--spacing-xs) var(--spacing-sm);
      background: var(--primary-end);
      color: white;
      border-radius: var(--radius-sm);
      font-size: 0.875rem;
      margin-top: var(--spacing-sm);
    }

    .badge-nankan {
      background: linear-gradient(135deg, #8b5cf6, #6366f1);
    }

    .badge-jra {
      background: linear-gradient(135deg, #ef4444, #dc2626);
    }

    .badge-local {
      background: linear-gradient(135deg, #10b981, #059669);
    }

    .new-badge {
      background: linear-gradient(135deg, #f59e0b, #ef4444);
      animation: pulse 2s ease-in-out infinite;
    }

    .badge-group {
      display: flex;
      gap: var(--spacing-xs);
      margin-top: var(--spacing-sm);
    }

    @keyframes pulse {
      0%, 100% {
        opacity: 1;
      }
      50% {
        opacity: 0.8;
      }
    }

    /* コンパクトカードグリッド */
    .card-grid-compact {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: var(--spacing-md);
      margin-top: var(--spacing-xl);
      margin-bottom: var(--spacing-2xl);
    }

    .feature-card-compact {
      padding: var(--spacing-md);
      background: var(--bg-secondary);
      border-radius: var(--radius-md);
      text-decoration: none;
      color: inherit;
      transition: all 0.3s ease;
      border: 1px solid var(--border-color);
      text-align: center;
    }

    .feature-card-compact:hover {
      transform: translateY(-2px);
      border-color: var(--primary-end);
      background: var(--bg-tertiary);
    }

    .card-icon-compact {
      font-size: 2rem;
      margin-bottom: var(--spacing-xs);
    }

    .feature-card-compact h3 {
      font-size: 1rem;
      margin-bottom: var(--spacing-xs);
    }

    .feature-card-compact .badge {
      margin-top: var(--spacing-xs);
    }

    .info-section {
      margin-top: var(--spacing-3xl);
      padding: var(--spacing-2xl);
      background: var(--bg-secondary);
      border-radius: var(--radius-lg);
    }

    .info-section h2 {
      margin-bottom: var(--spacing-xl);
    }

    .roles {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
      gap: var(--spacing-xl);
      text-align: left;
    }

    .role-card {
      padding: var(--spacing-lg);
      background: var(--bg-tertiary);
      border-radius: var(--radius-md);
    }

    .role-card h3 {
      font-size: 1.25rem;
      margin-bottom: var(--spacing-sm);
    }

    .role-card p {
      color: var(--text-secondary);
      margin-bottom: var(--spacing-md);
    }

    .role-card ul {
      list-style: none;
      padding: 0;
    }

    .role-card li {
      padding: var(--spacing-xs) 0;
      color: var(--text-secondary);
    }

    .role-card li::before {
      content: '✓ ';
      color: var(--primary-end);
      font-weight: bold;
    }
  </style>
</BaseLayout>
