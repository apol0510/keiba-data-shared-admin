  <button class="scroll-top-btn" id="scrollTopBtn" onclick="window.scrollTo({top:0,behavior:'smooth'})">вҶ‘</button>

<script is:inline>
  let parsedResult = null;

  // ========== гғҰгғјгғҶгӮЈгғӘгғҶгӮЈпјҲгӮҝгғ–+гӮ№гғҡгғјгӮ№дёЎеҜҫеҝңпјү ==========

  function getCategoryByVenue(venue) {
    const jra = ['жқұдә¬', 'дёӯеұұ', 'йҳӘзҘһ', 'дә¬йғҪ', 'дёӯдә¬', 'ж–°жҪҹ', 'е°ҸеҖү', 'жңӯе№Ң', 'еҮҪйӨЁ', 'зҰҸеі¶'];
    const nankan = ['еӨ§дә•', 'е·қеҙҺ', 'иҲ№ж©Ӣ', 'жөҰе’Ң'];
    if (jra.includes(venue)) return 'jra';
    if (nankan.includes(venue)) return 'nankan';
    return 'local';
  }

  function getVenueCode(venue) {
    const codes = {
      'жқұдә¬': 'TOK', 'дёӯеұұ': 'NAK', 'йҳӘзҘһ': 'HAN', 'дә¬йғҪ': 'KYO',
      'дёӯдә¬': 'CHU', 'ж–°жҪҹ': 'NII', 'е°ҸеҖү': 'KOK', 'жңӯе№Ң': 'SAP',
      'еҮҪйӨЁ': 'HKD', 'зҰҸеі¶': 'FKS',
      'еӨ§дә•': 'OOI', 'е·қеҙҺ': 'KAW', 'иҲ№ж©Ӣ': 'FUN', 'жөҰе’Ң': 'URA',
      'й–ҖеҲҘ': 'MON', 'еёҜеәғ': 'OBI', 'зӣӣеІЎ': 'MOR', 'ж°ҙжІў': 'MIZ', 'йҮ‘жІў': 'KNZ',
      'з¬ жқҫ': 'KSM', 'еҗҚеҸӨеұӢ': 'NGY', 'ең’з”°': 'SON', 'е§«и·Ҝ': 'HIM',
      'й«ҳзҹҘ': 'KOC', 'дҪҗиіҖ': 'SAG'
    };
    return codes[venue] || 'XXX';
  }

  function removeSeparatorLines(text) {
    const lines = text.split('\n');
    const pattern = /^[\s\u3000]*={3,}.*={3,}[\s\u3000]*$/;
    const filtered = lines.filter(line => !pattern.test(line));
    const removed = lines.length - filtered.length;
    if (removed > 0) console.log(`[InputCleaner] йҷӨеҺ»гҒ•гӮҢгҒҹеҢәеҲҮгӮҠз·ҡ: ${removed}иЎҢ`);
    return filtered.join('\n');
  }

  function updateCategoryPath() {
    const date = document.getElementById('raceDate').value;
    const venue = document.getElementById('venue').value;
    const display = document.getElementById('pathDisplay');
    if (!date || !venue) {
      display.textContent = '-- ж—Ҙд»ҳгҒЁз«¶йҰ¬е ҙгӮ’йҒёжҠһгҒ—гҒҰгҒҸгҒ гҒ•гҒ„ --';
      return;
    }
    const category = getCategoryByVenue(venue);
    const code = getVenueCode(venue);
    const year = date.substring(0, 4);
    const month = date.substring(5, 7);
    display.textContent = `${category}/entries/${year}/${month}/${date}-${code}.json`;
  }

  function showStatus(msg, type) {
    const bar = document.getElementById('statusBar');
    bar.textContent = msg;
    bar.className = 'status-bar ' + type;
  }

  // ========== иҮӘеӢ•жӨңеҮә ==========

  function detectDateFromText(text) {
    // гҖҢ2026е№ҙ3жңҲ30ж—ҘгҖҚеҪўејҸ
    const m = text.match(/(\d{4})е№ҙ(\d{1,2})жңҲ(\d{1,2})ж—Ҙ/);
    if (m) {
      return `${m[1]}-${m[2].padStart(2, '0')}-${m[3].padStart(2, '0')}`;
    }
    return null;
  }

  function detectVenueFromText(text) {
    const venues = ['еӨ§дә•', 'е·қеҙҺ', 'иҲ№ж©Ӣ', 'жөҰе’Ң', 'жқұдә¬', 'дёӯеұұ', 'йҳӘзҘһ', 'дә¬йғҪ', 'дёӯдә¬', 'ж–°жҪҹ', 'е°ҸеҖү', 'жңӯе№Ң', 'еҮҪйӨЁ', 'зҰҸеі¶', 'й–ҖеҲҘ', 'еёҜеәғ', 'зӣӣеІЎ', 'ж°ҙжІў', 'йҮ‘жІў', 'з¬ жқҫ', 'еҗҚеҸӨеұӢ', 'ең’з”°', 'е§«и·Ҝ', 'й«ҳзҹҘ', 'дҪҗиіҖ'];
    // гҖҢз¬¬Nз«¶иө°гҖҚгӮ’еҗ«гӮҖгғҳгғғгғҖгғјиЎҢгҒӢгӮүжӨңеҮәпјҲйЁҺжүӢжүҖеұһзӯүгҒ®иӘӨжӨңеҮәгӮ’йҳІжӯўпјү
    const lines = text.split('\n');
    for (const line of lines) {
      if (/з¬¬\d{1,2}з«¶иө°/.test(line)) {
        const n = line.replace(/[\s\u3000]+/g, '');
        for (const v of venues) { if (n.includes(v)) return v; }
      }
    }
    // гғ•гӮ©гғјгғ«гғҗгғғгӮҜ: е…Ҳй ӯ200ж–Үеӯ—
    const head = text.substring(0, 200).replace(/[\s\u3000]+/g, '');
    for (const v of venues) { if (head.includes(v)) return v; }
    return null;
  }

  // ========== гғ‘гғјгӮөгғј ==========

  function parseEntries() {
    const rawText = document.getElementById('entryText').value;
    if (!rawText.trim()) {
      showStatus('гғҶгӮӯгӮ№гғҲгҒҢе…ҘеҠӣгҒ•гӮҢгҒҰгҒ„гҒҫгҒӣгӮ“', 'error');
      return;
    }

    const text = removeSeparatorLines(rawText);
    console.log('[Parser] гғҶгӮӯгӮ№гғҲиЎҢж•°:', text.split('\n').length);

    // иҮӘеӢ•жӨңеҮә
    const detectedDate = detectDateFromText(text);
    const detectedVenue = detectVenueFromText(text);

    if (detectedDate && !document.getElementById('raceDate').value) {
      document.getElementById('raceDate').value = detectedDate;
    }
    if (detectedVenue && !document.getElementById('venue').value) {
      document.getElementById('venue').value = detectedVenue;
      updateCategoryPath();
    }

    try {
      const races = splitAndParseRaces(text);
      if (races.length === 0) {
        showStatus('гғ¬гғјгӮ№гғҮгғјгӮҝгӮ’жҠҪеҮәгҒ§гҒҚгҒҫгҒӣгӮ“гҒ§гҒ—гҒҹ', 'error');
        return;
      }

      const date = document.getElementById('raceDate').value;
      const venue = document.getElementById('venue').value;

      if (!date || !venue) {
        showStatus('ж—Ҙд»ҳгҒЁз«¶йҰ¬е ҙгӮ’йҒёжҠһгҒ—гҒҰгҒҸгҒ гҒ•гҒ„', 'error');
        return;
      }

      const category = getCategoryByVenue(venue);
      const code = getVenueCode(venue);

      parsedResult = {
        version: '1.0.0',
        createdAt: new Date().toISOString(),
        lastUpdated: new Date().toISOString(),
        date: date,
        venue: venue,
        venueCode: code,
        category: category,
        totalRaces: races.length,
        races: races
      };

      showStatus(`вң… ${races.length}гғ¬гғјгӮ№и§Јжһҗе®ҢдәҶпјҲеҗҲиЁҲ${races.reduce((s, r) => s + r.horses.length, 0)}й ӯпјү`, 'success');
      renderPreview(races);
      renderJson();
      updateCategoryPath();

    } catch (e) {
      console.error('[Parser] гӮЁгғ©гғј:', e);
      showStatus('и§ЈжһҗгӮЁгғ©гғј: ' + e.message, 'error');
    }
  }

  function splitAndParseRaces(text) {
    const lines = text.split('\n');
    const races = [];

    // гғ¬гғјгӮ№еўғз•Ң: гҖҢз¬¬Nз«¶иө°гҖҚгӮ’еҗ«гӮҖиЎҢгҒ§еҲҶеүІпјҲжңҖгӮӮзўәе®ҹпјү
    const raceStartIndices = [];
    for (let i = 0; i < lines.length; i++) {
      if (/з¬¬\d{1,2}з«¶иө°/.test(lines[i])) {
        raceStartIndices.push(i);
      }
    }

    console.log('[Parser] гғ¬гғјгӮ№еўғз•ҢжӨңеҮә:', raceStartIndices.length, 'з®ҮжүҖ');

    if (raceStartIndices.length === 0) {
      const race = parseOneRace(lines);
      if (race && race.horses.length > 0) races.push(race);
      return races;
    }

    for (let i = 0; i < raceStartIndices.length; i++) {
      const startIdx = raceStartIndices[i];
      const endIdx = i + 1 < raceStartIndices.length ? raceStartIndices[i + 1] : lines.length;
      const raceLines = lines.slice(startIdx, endIdx);

      try {
        const race = parseOneRace(raceLines);
        if (race && race.horses.length > 0) {
          races.push(race);
          console.log(`[Parser] R${race.raceNumber}: ${race.horses.length}й ӯ`);
        }
      } catch (e) {
        console.warn(`[Parser] гғ¬гғјгӮ№и§ЈжһҗгӮЁгғ©гғј (index ${i}):`, e.message);
      }
    }

    return races;
  }

  function parseOneRace(lines) {
    const race = {
      raceNumber: null, raceName: '', startTime: '',
      distance: '', surface: '', direction: '',
      conditions: '', headCount: 0, horses: []
    };

    // дёҠйғЁ20иЎҢгҒӢгӮүгғ¬гғјгӮ№жғ…е ұгӮ’жҠҪеҮә
    const topText = lines.slice(0, Math.min(20, lines.length)).join(' ').replace(/[\s\u3000]+/g, ' ');

    const raceNumMatch = topText.match(/з¬¬(\d{1,2})з«¶иө°/);
    if (raceNumMatch) race.raceNumber = parseInt(raceNumMatch[1], 10);

    const timeMatch = topText.match(/(\d{1,2}:\d{2})зҷәиө°/);
    if (timeMatch) race.startTime = timeMatch[1];

    const distMatch = topText.match(/(гғҖгғјгғҲ|иҠқ)\s*(\d{3,4})\s*[mпҪҚ]/);
    if (distMatch) { race.surface = distMatch[1]; race.distance = distMatch[2]; }

    const dirMatch = topText.match(/\d{3,4}\s*[mпҪҚ]\s*[пјҲ(]\s*(е·Ұ|еҸі|зӣҙ)/);
    if (dirMatch) race.direction = dirMatch[1];

    // гғ¬гғјгӮ№еҗҚ: гғҳгғғгғҖгғјиЎҢгӮҲгӮҠеүҚгҒ®жқЎд»¶зҡ„гҒӘзҹӯгҒ„иЎҢ
    for (let i = 0; i < Math.min(12, lines.length); i++) {
      const line = lines[i].trim();
      if (!line || line.length < 2 || line.length > 50) continue;
      if (/жһ з•Ә|йҰ¬з•Ә|зҷәиө°|еүҚгғ¬гғјгӮ№|ж¬Ўгғ¬гғјгӮ№|иіһйҮ‘|йӣ»и©ұжҠ•зҘЁ|гӮөгғ©гғ–гғ¬гғғгғү|еҜҫжҲҰиЎЁ|гӮӘгғғгӮә|гғ©гӮӨгғ–|еҚ°еҲ·з”Ё/.test(line)) continue;
      if (/^\d{4}е№ҙ/.test(line) || /з¬¬\d{1,2}з«¶иө°/.test(line)) continue;
      if (/^(гғҖгғјгғҲ|иҠқ)/.test(line)) continue;
      if (/[гӮЎ-гғ¶гғјдёҖ-йҫҘпјЎ-пјәпјҗ-пјҷ]/.test(line)) {
        race.raceName = line;
        break;
      }
    }

    race.horses = parseHorses(lines);
    race.headCount = race.horses.length;
    return race;
  }

  function parseHorses(lines) {
    const horses = [];
    // йҰ¬гғ–гғӯгғғгӮҜгҒ®й–Ӣе§ӢгӮ’жӨңеҮә: жһ з•Ә+йҰ¬з•Әгғ‘гӮҝгғјгғі
    // гҖҢ1    1    гӮ·гӮ§гғҠгӮҜгғ©гӮҰгғігҖҚгҒ®гӮҲгҒҶгҒ«жһ з•Ә йҰ¬з•Ә йҰ¬еҗҚгҒ§е§ӢгҒҫгӮӢиЎҢ
    const horseBlockStarts = [];

    for (let i = 0; i < lines.length; i++) {
      const line = lines[i];
      // жһ з•Ә(1-8) + гӮҝгғ–/гӮ№гғҡгғјгӮ№ + йҰ¬з•Ә(1-18) + гӮҝгғ–/гӮ№гғҡгғјгӮ№ + йҰ¬еҗҚпјҲгӮ«гӮҝгӮ«гғҠ/жјўеӯ—пјү
      const m = line.match(/^(\d)\s+(\d{1,2})\s+([гӮЎ-гғ¶гғјдёҖ-йҫҘa-zA-ZпҪҒ-пҪҡпјЎ-пјә].+)/);
      if (m) {
        const postPos = parseInt(m[1], 10);
        const num = parseInt(m[2], 10);
        // жһ з•ӘгҒҢ1-8гҖҒйҰ¬з•ӘгҒҢ1-18гҒ®зҜ„еӣІ
        if (postPos >= 1 && postPos <= 8 && num >= 1 && num <= 18) {
          horseBlockStarts.push({ index: i, postPosition: postPos, number: num });
        }
        continue;
      }

      // жһ з•ӘгҒӘгҒ—гҒ§йҰ¬з•Ә+йҰ¬еҗҚгҒ®гҒҝгҒ®е ҙеҗҲпјҲжһ з•ӘгҒЁйҰ¬з•ӘгҒҢеҗҢгҒҳиЎҢгҒ«гҒӘгҒ„е ҙеҗҲгӮӮгҒӮгӮӢпјү
      // гҖҢ4    гӮўгӮӨгғҮгӮЈгӮўгғӘгӮ№гғҲгҖҚгҒ®гӮҲгҒҶгҒ«жһ з•ӘгҒ®еҫҢгҒ«зӣҙжҺҘйҰ¬еҗҚгҒҢжқҘгӮӢгӮұгғјгӮ№гӮӮ
      // гҒ“гӮҢгҒҜжһ з•Ә=4, йҰ¬з•ӘгҒҢеҫҢз¶ҡиЎҢгҒ«гҒӮгӮӢеҸҜиғҪжҖ§
    }

    console.log('[Parser] йҰ¬гғ–гғӯгғғгӮҜжӨңеҮә:', horseBlockStarts.length, 'й ӯ');

    for (let h = 0; h < horseBlockStarts.length; h++) {
      const start = horseBlockStarts[h].index;
      const end = h + 1 < horseBlockStarts.length ? horseBlockStarts[h + 1].index : lines.length;
      const block = lines.slice(start, end);

      try {
        const horse = parseOneHorse(block, horseBlockStarts[h]);
        if (horse) horses.push(horse);
      } catch (e) {
        console.warn(`[Parser] йҰ¬гғҮгғјгӮҝи§ЈжһҗгӮЁгғ©гғј (йҰ¬з•Ә${horseBlockStarts[h].number}):`, e.message);
      }
    }

    return horses;
  }

  function parseOneHorse(block, meta) {
    const horse = {
      postPosition: meta.postPosition,
      number: meta.number,
      name: '',
      gender: '',
      age: null,
      coat: '',
      weight: null,
      jockey: '',
      jockeyAffiliation: '',
      trainer: '',
      trainerAffiliation: '',
      owner: '',
      breeder: '',
      sire: '',
      bms: '',
      record: {
        total: { wins: 0, seconds: 0, thirds: 0, unplaced: 0 },
        left: { wins: 0, seconds: 0, thirds: 0, unplaced: 0 },
        right: { wins: 0, seconds: 0, thirds: 0, unplaced: 0 },
        venue: { wins: 0, seconds: 0, thirds: 0, unplaced: 0 },
        distance: { wins: 0, seconds: 0, thirds: 0, unplaced: 0 }
      },
      bestTime: '',
      recentRaces: []
    };

    // 1иЎҢзӣ®: жһ з•Ә йҰ¬з•Ә йҰ¬еҗҚ йЁҺжүӢпјҲжүҖеұһпјү вҖ” гӮҝгғ– or гӮ№гғҡгғјгӮ№еҢәеҲҮгӮҠ
    const firstLine = block[0];
    const tabParts = firstLine.split(/\t/).map(s => s.trim()).filter(s => s);
    if (tabParts.length >= 3) {
      horse.name = tabParts[2];
      if (tabParts[3]) {
        const jm = tabParts[3].match(/^(.+?)[пјҲ(](.+?)[пјү)]/);
        if (jm) { horse.jockey = jm[1].trim(); horse.jockeyAffiliation = jm[2].trim(); }
        else horse.jockey = tabParts[3].trim();
      }
    } else {
      const fm = firstLine.match(/^\d\s+\d{1,2}\s+(\S+)\s+(.+)/);
      if (fm) {
        horse.name = fm[1].trim();
        const jm = fm[2].match(/^(.+?)[пјҲ(](.+?)[пјү)]/);
        if (jm) { horse.jockey = jm[1].trim(); horse.jockeyAffiliation = jm[2].trim(); }
        else horse.jockey = fm[2].trim();
      }
    }

    // зқҖеҲҘжҲҗзёҫ: гҖҢе…Ё   \t1- \t0- \t0- \t7гҖҚ
    const recordKeys = ['total', 'left', 'right', 'venue', 'distance'];
    const recordLabels = ['е…Ё', 'е·Ұ', 'еҸі', 'е ҙ', 'и·қ'];
    for (const line of block) {
      const normalized = line.replace(/\t/g, ' ').trim();
      for (let r = 0; r < recordLabels.length; r++) {
        if (normalized.startsWith(recordLabels[r])) {
          const rm = normalized.match(/(\d+)-\s*(\d+)-\s*(\d+)-\s*(\d+)/);
          if (rm) {
            horse.record[recordKeys[r]] = {
              wins: parseInt(rm[1]), seconds: parseInt(rm[2]),
              thirds: parseInt(rm[3]), unplaced: parseInt(rm[4])
            };
          }
        }
      }
    }

    // жҖ§йҪўгғ»жҜӣиүІгғ»ж–ӨйҮҸ: гҖҢзүЎ3 \tй»’й№ҝжҜӣ \t03.23з”ҹ \t54.0гҖҖ...гҖҚ
    for (const line of block) {
      const normalized = line.replace(/\t/g, ' ');
      const gm = normalized.match(/(зүЎ|зүқ|гӮ»гғі)(\d{1,2})\s+([\S]*жҜӣ|ж —жҜӣ|иҠҰжҜӣ)\s+/);
      if (gm) {
        horse.gender = gm[1];
        horse.age = parseInt(gm[2]);
        horse.coat = gm[3];
        const wm = normalized.match(/з”ҹ\s+[в–ів–ІвҳҶвҳ…]?\s*(\d{2,3}\.\d)/);
        if (wm) horse.weight = parseFloat(wm[1]);
        break;
      }
    }

    // жңҖй«ҳгӮҝгӮӨгғ : гҖҢ1:17.5 \tиүҜ1:17.5гҖҚ or гҖҢпјҚ \tиүҜпјҚгҖҚ
    for (const line of block) {
      const trimmed = line.replace(/\t/g, ' ').trim();
      const btm = trimmed.match(/^(\d:\d{2}\.\d)\s+[иүҜзЁҚйҮҚдёҚ]/);
      if (btm) { horse.bestTime = btm[1]; break; }
      if (/^пјҚ\s+[иүҜзЁҚйҮҚдёҚ]/.test(trimmed)) { horse.bestTime = ''; break; }
    }

    // иҝ‘5иө°гғҮгғјгӮҝгҒ®жҠҪеҮә
    horse.recentRaces = parseRecentRaces(block);

    // дёӢж®өгғ–гғӯгғғгӮҜпјҲжҖ§йҪўиЎҢгҒ®еҫҢпјүгҒӢгӮүзҲ¶йҰ¬гғ»иӘҝж•ҷеё«гғ»йҰ¬дё»гғ»з”ҹз”Јзү§е ҙгғ»жҜҚзҲ¶гӮ’жҠҪеҮә
    // ж§ӢйҖ :
    //   жҖ§йҪўиЎҢ:    зүЎ6 й№ҝжҜӣ 02.27з”ҹ 56.0 1-0-0-0 гғ¬гғјгӮ№еҗҚГ—5
    //   зҲ¶+иӘҝж•ҷеё«иЎҢ: гғӣгғғгӮігғјгӮҝгғ«гғһгӮЁ    еҶЁз”°ж•ҸпјҲжөҰе’Ңпјү
    //   дәәж°—иЎҢ:    8дәә 504 иҰӢи¶ҠеҪ¬ 56.0 Г— 5иө°еҲҶ
    //   йҰ¬дё»+з”ҹз”Ј+гӮҝгӮӨгғ иЎҢ: гғ”гғјгғҒгғ•гӮЎгғјгғ“гғј    еҶЁз”°и—Өз”·    2:14.4 7-8-4-2 40.0 Г— 5иө°еҲҶ
    //   жҜҚзҲ¶+гғ–гғӘгғјгғҖгғј+зқҖе·®иЎҢ: пјҲгғҸгғјгғүгӮ№гғ‘гғіпјү    еҜҢз”°жҒӯеҸё    0.1 гӮігӮігғӘгӮўгӮӨгғ©гғігғү Г— 5иө°еҲҶ
    extractLowerBlock(block, horse);

    return horse;
  }

  function extractLowerBlock(block, horse) {
    let genderLineIdx = -1;
    for (let i = 0; i < block.length; i++) {
      const normalized = block[i].replace(/\t/g, ' ').trim();
      if (/^(зүЎ|зүқ|гӮ»гғі)\d/.test(normalized)) { genderLineIdx = i; break; }
    }

    if (genderLineIdx === -1) {
      console.warn(`[Parser] жҖ§йҪўиЎҢгҒҢиҰӢгҒӨгҒӢгӮүгҒӘгҒ„: ${horse.name}`);
      return;
    }

    // жҖ§йҪўиЎҢгҒ®ж¬Ў = зҲ¶йҰ¬еҗҚ + иӘҝж•ҷеё«еҗҚ(жүҖеұһ)
    const sireLineIdx = genderLineIdx + 1;
    if (sireLineIdx < block.length) {
      const sireLine = block[sireLineIdx].replace(/\t/g, '  ').trim();
      const sm = sireLine.match(/^(\S+)\s+(.+?)[пјҲ(](.+?)[пјү)]/);
      if (sm) {
        horse.sire = sm[1].trim();
        horse.trainer = sm[2].trim();
        horse.trainerAffiliation = sm[3].trim();
      } else if (sireLine && !/^\d/.test(sireLine) && !/^[пјҲ(]/.test(sireLine)) {
        const p = sireLine.split(/\s{2,}/).filter(s => s.trim());
        if (p.length >= 1) horse.sire = p[0].trim();
        if (p.length >= 2) horse.trainer = p[1].trim();
      }
    }

    // йҰ¬дё»+з”ҹз”Јзү§е ҙ: гӮҝгӮӨгғ гӮ’еҗ«гҒҝдәәж°—иЎҢгҒ§гҒӘгҒ„иЎҢ
    for (let i = sireLineIdx + 1; i < block.length; i++) {
      const line = block[i].replace(/\t/g, '  ');
      if (/\d:\d{2}\.\d/.test(line) && !/\d+дәә/.test(line)) {
        const p = line.trim().split(/\s{2,}/).filter(s => s.trim());
        if (p.length >= 2) {
          if (!/^\d/.test(p[0]) && !/\d:\d{2}/.test(p[0])) {
            horse.owner = p[0].trim();
            if (!/\d:\d{2}/.test(p[1])) horse.breeder = p[1].trim();
          }
        }
        break;
      }
    }

    // BMS(жҜҚзҲ¶): пјҲжӢ¬еј§еҗҚпјүгҒ§е§ӢгҒҫгӮӢиЎҢ
    for (let i = sireLineIdx + 1; i < block.length; i++) {
      const line = block[i].replace(/\t/g, '  ').trim();
      const bm = line.match(/^[пјҲ(]([^пјү)]+)[пјү)]\s+([\S]+)/);
      if (bm) {
        horse.bms = bm[1].trim();
        if (!/^\d/.test(bm[2])) horse.breeder = bm[2].trim();
        break;
      }
    }

    // иҝ‘иө°гҒ®иҝҪеҠ жғ…е ұгӮ’иЈңе®Ң
    enrichRecentRaces(block, horse.recentRaces, genderLineIdx);
  }

  function parseRecentRaces(block) {
    const recentRaces = [];

    // зқҖй Ҷ+ж—Ҙд»ҳиЎҢ: гҖҢ10 26.03.09гҖҖиүҜгҖҖ10й ӯгҖҚгҖҢдёӯжӯў 25.11.18гҖҖиүҜгҖҖ12й ӯгҖҚ
    const raceLineIndices = [];
    for (let i = 0; i < block.length; i++) {
      const line = block[i].replace(/\t/g, ' ').trim();
      if (/^(?:\d{1,2}|дёӯжӯў|еҸ–ж¶Ҳ|йҷӨеӨ–)\s+\d{2}\.\d{2}\.\d{2}/.test(line)) {
        raceLineIndices.push(i);
      }
    }

    for (let r = 0; r < Math.min(5, raceLineIndices.length); r++) {
      const lineIdx = raceLineIndices[r];
      const line = block[lineIdx].replace(/\t/g, ' ').trim();

      const m = line.match(/^(\d{1,2}|дёӯжӯў|еҸ–ж¶Ҳ|йҷӨеӨ–)\s+(\d{2})\.(\d{2})\.(\d{2})\s+(иүҜ|зЁҚйҮҚ|йҮҚ|дёҚиүҜ)\s+(\d{1,2})й ӯ/);
      if (!m) continue;

      const finishRaw = m[1];
      const raceData = {
        order: r + 1,
        finish: /^\d+$/.test(finishRaw) ? parseInt(finishRaw) : null,
        finishStatus: /^\d+$/.test(finishRaw) ? null : finishRaw,
        date: `20${m[2]}-${m[3]}-${m[4]}`,
        trackCondition: m[5], headCount: parseInt(m[6]),
        venue: '', direction: '', distance: null, postPosition: null,
        raceName: '', popularity: null, bodyWeight: '', jockey: '', weight: null,
        time: '', passingOrder: '', last3f: '', margin: '', opponentName: ''
      };

      // ж¬ЎгҒ®йқһз©әиЎҢ: з«¶йҰ¬е ҙгғ»и·қйӣўгғ»жһ з•Ә
      for (let j = lineIdx + 1; j < Math.min(lineIdx + 3, block.length); j++) {
        const venueLine = block[j].replace(/\t/g, ' ').trim();
        if (!venueLine) continue;
        const vm = venueLine.match(/^(.+?)\s+(е·Ұ|еҸі|зӣҙ)?(\d{3,4})\s+(\d{1,2})з•Ә/);
        if (vm) {
          raceData.venue = vm[1].replace(/[гғҠпјӘJ]$/, '').replace(/[\s\u3000]/g, '').trim();
          raceData.direction = vm[2] || '';
          raceData.distance = parseInt(vm[3]);
          raceData.postPosition = parseInt(vm[4]);
        }
        break;
      }

      recentRaces.push(raceData);
    }

    return recentRaces;
  }

  function enrichRecentRaces(block, recentRaces, genderLineIdx) {
    if (recentRaces.length === 0) return;

    // гғ¬гғјгӮ№еҗҚ: жҖ§йҪўиЎҢгҒ®еҫҢеҚҠгҖҢN-N-N-N \tгғ¬гғјгӮ№еҗҚ1 \tгғ¬гғјгӮ№еҗҚ2 ...гҖҚ
    if (genderLineIdx >= 0 && genderLineIdx < block.length) {
      const genderLine = block[genderLineIdx];
      const afterRecord = genderLine.replace(/^.*?\d+-\d+-\d+-\d+/, '');
      if (afterRecord && afterRecord !== genderLine) {
        const raceNames = afterRecord.split(/\t/).map(s => s.trim()).filter(s => s);
        for (let r = 0; r < Math.min(recentRaces.length, raceNames.length); r++) {
          recentRaces[r].raceName = raceNames[r];
        }
      }
    }

    // дёӢж®өиЎҢгӮ’иө°жҹ»
    const startIdx = genderLineIdx >= 0 ? genderLineIdx + 1 : 0;
    for (let i = startIdx; i < block.length; i++) {
      const line = block[i];
      const normalized = line.replace(/\t/g, '    ');

      // дәәж°—иЎҢ: гҖҢ\t10дәәгҖҖ406гҖҖе·қеі¶жӯЈ 54.0 \t12дәәгҖҖ395 ...гҖҚ
      const popMatches = [...normalized.matchAll(/(\d{1,2})дәә\s+(\d{3,4})\s+([^\d\s][^\s]*(?:\s[^\d\s][^\s]*)?)\s+(\d{2,3}\.\d)/g)];
      if (popMatches.length >= 2) {
        for (let r = 0; r < Math.min(recentRaces.length, popMatches.length); r++) {
          recentRaces[r].popularity = parseInt(popMatches[r][1]);
          recentRaces[r].bodyWeight = popMatches[r][2];
          recentRaces[r].jockey = popMatches[r][3].replace(/^[в–ів–ІвҳҶвҳ…]/, '').trim();
          recentRaces[r].weight = parseFloat(popMatches[r][4]);
        }
        continue;
      }

      // гӮҝгӮӨгғ иЎҢ: гҖҢйҰ¬дё» \tз”ҹз”Ј \t1:19.9гҖҖ10-10-10гҖҖ40.0 \t...гҖҚ
      const timeMatches = [...normalized.matchAll(/(\d:\d{2}\.\d)\s+([\d]+-[\d]+(?:-[\d]+)*)\s+(\d{2}\.\d)/g)];
      if (timeMatches.length >= 1) {
        for (let r = 0; r < Math.min(recentRaces.length, timeMatches.length); r++) {
          recentRaces[r].time = timeMatches[r][1];
          recentRaces[r].passingOrder = timeMatches[r][2];
          recentRaces[r].last3f = timeMatches[r][3];
        }
        continue;
      }

      // зқҖе·®иЎҢ: гҖҢпјҲBMSпјү \tгғ–гғӘгғјгғҖгғј \t\t3.1гҖҖзӣёжүӢйҰ¬ \t5.6гҖҖзӣёжүӢйҰ¬ ...гҖҚ
      if (/[пјҲ(]/.test(line)) {
        const marginMatches = [...normalized.matchAll(/(\d+\.\d+)\s+([гӮЎ-гғ¶гғјдёҖ-йҫҘa-zA-ZпҪҒ-пҪҡпјЎ-пјә][^\s]*)/g)];
        if (marginMatches.length >= 1) {
          for (let r = 0; r < Math.min(recentRaces.length, marginMatches.length); r++) {
            recentRaces[r].margin = marginMatches[r][1];
            recentRaces[r].opponentName = marginMatches[r][2];
          }
        }
      }
    }
  }

  // ========== гғ—гғ¬гғ“гғҘгғјжҸҸз”» ==========

  function renderPreview(races) {
    const section = document.getElementById('previewSection');
    const content = document.getElementById('previewContent');
    section.classList.add('visible');

    // жһ з•ӘгӮ«гғ©гғј
    const wakuColors = {
      1: '#f0f0f0', 2: '#1a1a1a', 3: '#e74c3c', 4: '#3498db',
      5: '#f1c40f', 6: '#27ae60', 7: '#e67e22', 8: '#e91e93'
    };
    const wakuTextColors = {
      1: '#333', 2: '#fff', 3: '#fff', 4: '#fff',
      5: '#333', 6: '#fff', 7: '#fff', 8: '#fff'
    };

    let html = '';
    for (const race of races) {
      const raceSub = [race.surface, race.distance ? race.distance + 'm' : '', race.direction, race.startTime ? race.startTime + 'зҷәиө°' : ''].filter(s => s).join(' ');
      html += `
        <div class="race-card">
          <div class="race-card-header" onclick="this.nextElementSibling.classList.toggle('open')">
            <h3>${race.raceNumber ? race.raceNumber + 'R' : '?R'} ${race.raceName || '(еҗҚз§°жңӘеҸ–еҫ—)'}<span class="race-sub">${raceSub}</span></h3>
            <span class="horse-count">${race.horses.length}й ӯ</span>
          </div>
          <div class="race-card-body open">`;

      for (const h of race.horses) {
        const rec = h.record.total;
        const wBg = wakuColors[h.postPosition] || '#475569';
        const wTxt = wakuTextColors[h.postPosition] || '#fff';

        // --- дёҠж®ө: жһ з•Ә йҰ¬з•Ә йҰ¬еҗҚ йЁҺжүӢ жҖ§йҪў ж–ӨйҮҸ ---
        html += `
            <div class="horse-card">
              <div class="horse-card-top">
                <div class="horse-waku" style="background:${wBg};color:${wTxt}">${h.postPosition}</div>
                <div class="horse-num">${h.number}</div>
                <div class="horse-main">
                  <span class="horse-name">${h.name}</span>
                  <span class="horse-jockey">${h.jockey}${h.jockeyAffiliation ? '(' + h.jockeyAffiliation + ')' : ''}</span>
                  <span class="horse-attr">${h.gender || ''}${h.age || ''} ${h.coat || ''} <strong>${h.weight || '-'}kg</strong></span>
                </div>
              </div>`;

        // --- дёӯж®ө: жҲҗзёҫ + и©ізҙ°жғ…е ұ ---
        html += `
              <div class="horse-card-mid">
                <div class="horse-record">
                  <div class="horse-record-row"><span class="lbl">е…Ё</span> <span class="val">${rec.wins}-${rec.seconds}-${rec.thirds}-${rec.unplaced}</span></div>
                  <div class="horse-record-row"><span class="lbl">е·Ұ</span> <span class="val">${h.record.left.wins}-${h.record.left.seconds}-${h.record.left.thirds}-${h.record.left.unplaced}</span></div>
                  <div class="horse-record-row"><span class="lbl">еҸі</span> <span class="val">${h.record.right.wins}-${h.record.right.seconds}-${h.record.right.thirds}-${h.record.right.unplaced}</span></div>
                  <div class="horse-record-row"><span class="lbl">е ҙ</span> <span class="val">${h.record.venue.wins}-${h.record.venue.seconds}-${h.record.venue.thirds}-${h.record.venue.unplaced}</span></div>
                  <div class="horse-record-row"><span class="lbl">и·қ</span> <span class="val">${h.record.distance.wins}-${h.record.distance.seconds}-${h.record.distance.thirds}-${h.record.distance.unplaced}</span></div>
                </div>
                <div class="horse-details">
                  <div><span class="dt">зҲ¶</span> <span class="dd">${h.sire || '-'}</span></div>
                  <div><span class="dt">BMS</span> <span class="dd">${h.bms || '-'}</span></div>
                  <div><span class="dt">иӘҝж•ҷеё«</span> <span class="dd">${h.trainer || '-'}${h.trainerAffiliation ? '(' + h.trainerAffiliation + ')' : ''}</span></div>
                  <div><span class="dt">йҰ¬дё»</span> <span class="dd">${h.owner || '-'}</span></div>
                  <div><span class="dt">з”ҹз”Ј</span> <span class="dd">${h.breeder || '-'}</span></div>
                  ${h.bestTime ? `<div><span class="dt">жңҖй«ҳ</span> <span class="dd">${h.bestTime}</span></div>` : ''}
                </div>
              </div>`;

        // --- дёӢж®ө: иҝ‘5иө°гғҶгғјгғ–гғ« ---
        if (h.recentRaces.length > 0) {
          html += `
              <div style="overflow-x:auto">
                <table class="recent-table">
                  <thead><tr>
                    <th>зқҖй Ҷ</th><th>ж—Ҙд»ҳ</th><th>йҰ¬е ҙ</th><th>й ӯж•°</th>
                    <th>з«¶йҰ¬е ҙ</th><th>и·қйӣў</th><th>жһ </th>
                    <th>гғ¬гғјгӮ№еҗҚ</th>
                    <th>дәәж°—</th><th>дҪ“йҮҚ</th><th>йЁҺжүӢ</th><th>ж–ӨйҮҸ</th>
                    <th>гӮҝгӮӨгғ </th><th>йҖҡйҒҺ</th><th>дёҠ3F</th>
                    <th>зқҖе·®</th><th>зӣёжүӢ</th>
                  </tr></thead>
                  <tbody>`;

          for (const r of h.recentRaces) {
            const finishText = r.finishStatus || (r.finish != null ? r.finish + 'зқҖ' : '-');
            const finishCls = r.finishStatus ? 'finish-status' : r.finish === 1 ? 'finish-1' : r.finish === 2 ? 'finish-2' : r.finish === 3 ? 'finish-3' : '';
            html += `
                    <tr>
                      <td class="${finishCls}">${finishText}</td>
                      <td>${r.date || '-'}</td>
                      <td>${r.trackCondition || '-'}</td>
                      <td>${r.headCount || '-'}</td>
                      <td>${r.venue || '-'}</td>
                      <td>${r.direction || ''}${r.distance || '-'}m</td>
                      <td>${r.postPosition || '-'}</td>
                      <td style="white-space:normal;max-width:180px;font-size:0.72rem">${r.raceName || '-'}</td>
                      <td>${r.popularity ? r.popularity + 'дәәж°—' : '-'}</td>
                      <td>${r.bodyWeight || '-'}</td>
                      <td>${r.jockey || '-'}</td>
                      <td>${r.weight || '-'}</td>
                      <td>${r.time || '-'}</td>
                      <td>${r.passingOrder || '-'}</td>
                      <td>${r.last3f || '-'}</td>
                      <td>${r.margin || '-'}</td>
                      <td>${r.opponentName || '-'}</td>
                    </tr>`;
          }

          html += `
                  </tbody>
                </table>
              </div>`;
        }

        html += `
            </div>`;
      }

      html += `
          </div>
        </div>`;
    }

    content.innerHTML = html;
  }

  function renderJson() {
    if (!parsedResult) return;
    const section = document.getElementById('saveSection');
    section.classList.add('visible');
    document.getElementById('jsonPreview').textContent = JSON.stringify(parsedResult, null, 2);
  }

  // ========== дҝқеӯҳ ==========

  async function saveToGit(forceOverwrite) {
    if (!parsedResult) {
      showStatus('е…ҲгҒ«и§ЈжһҗгӮ’е®ҹиЎҢгҒ—гҒҰгҒҸгҒ гҒ•гҒ„', 'error');
      return;
    }

    const date = document.getElementById('raceDate').value;
    const venue = document.getElementById('venue').value;

    if (!date || !venue) {
      showStatus('ж—Ҙд»ҳгҒЁз«¶йҰ¬е ҙгӮ’йҒёжҠһгҒ—гҒҰгҒҸгҒ гҒ•гҒ„', 'error');
      return;
    }

    const category = getCategoryByVenue(venue);
    const venueCode = getVenueCode(venue);

    if (forceOverwrite && !confirm('вҡ пёҸ е®Ңе…ЁдёҠжӣёгҒҚгҒ—гҒҫгҒҷгҖӮж—ўеӯҳгғҮгғјгӮҝгҒҜж¶ҲгҒҲгҒҫгҒҷгҖӮгӮҲгӮҚгҒ—гҒ„гҒ§гҒҷгҒӢпјҹ')) return;

    showStatus('дҝқеӯҳдёӯ...', 'info');

    try {
      const response = await fetch('/.netlify/functions/save-entries', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          raceDate: date,
          venue: venue,
          venueCode: venueCode,
          category: category,
          data: parsedResult,
          forceOverwrite: forceOverwrite
        })
      });

      const result = await response.json();

      if (response.ok && result.success) {
        showStatus(`вң… дҝқеӯҳжҲҗеҠҹ! ${result.path}`, 'success');
      } else {
        showStatus(`вқҢ дҝқеӯҳеӨұж•—: ${result.error || result.details || 'Unknown error'}`, 'error');
        console.error('[Save] гӮЁгғ©гғј:', result);
      }
    } catch (e) {
      showStatus('вқҢ дҝқеӯҳгӮЁгғ©гғј: ' + e.message, 'error');
      console.error('[Save] Exception:', e);
    }
  }

  function copyJson() {
    if (!parsedResult) return;
    navigator.clipboard.writeText(JSON.stringify(parsedResult, null, 2))
      .then(() => showStatus('рҹ“Ӣ JSONгӮ’гӮҜгғӘгғғгғ—гғңгғјгғүгҒ«гӮігғ”гғјгҒ—гҒҫгҒ—гҒҹ', 'success'))
      .catch(e => showStatus('гӮігғ”гғјеӨұж•—: ' + e.message, 'error'));
  }

  function clearForm() {
    document.getElementById('entryText').value = '';
    document.getElementById('previewSection').classList.remove('visible');
    document.getElementById('saveSection').classList.remove('visible');
    document.getElementById('statusBar').className = 'status-bar';
    parsedResult = null;
  }

  // ========== гӮӨгғҷгғігғҲ ==========

  document.getElementById('venue').addEventListener('change', updateCategoryPath);
  document.getElementById('raceDate').addEventListener('change', updateCategoryPath);

  // Scroll to top
  window.addEventListener('scroll', () => {
    document.getElementById('scrollTopBtn').classList.toggle('visible', window.scrollY > 300);
  });

  // гғҶгӮӯгӮ№гғҲиІјгӮҠд»ҳгҒ‘жҷӮгҒ«иҮӘеӢ•жӨңеҮә
  document.getElementById('entryText').addEventListener('paste', function() {
    setTimeout(() => {
      const text = this.value;
      const detectedDate = detectDateFromText(text);
      const detectedVenue = detectVenueFromText(text);
      if (detectedDate) document.getElementById('raceDate').value = detectedDate;
      if (detectedVenue) document.getElementById('venue').value = detectedVenue;
      updateCategoryPath();
    }, 100);
  });
</script>
