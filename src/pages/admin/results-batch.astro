          html += `<div>${c.order.join(', ')}</div>`;
          html += `</div>`;
        });

        html += '</div>';
        html += '</div>';
      }

      return html;
    }

    // エラーHTML生成
    function generateErrorHTML(result) {
      return `
        <div style="color: var(--error);">
          <h4>❌ エラー内容</h4>
          <ul style="margin-left: var(--spacing-lg);">
            ${result.errors.map(err => `<li>${err}</li>`).join('')}
          </ul>
        </div>
      `;
    }

    // JSON全コピー
    function copyAllJSON() {
      const successResults = batchResults.filter(r => r.success);
      if (successResults.length === 0) {
        alert('コピーできるデータがありません');
        return;
      }

      const date = successResults[0].date;
      const venue = successResults[0].venue;

      const jsonData = {
        raceDate: date,
        lastUpdated: new Date().toISOString(),
        track: venue,
        totalRaces: successResults.length,
        races: successResults.map(r => r.data),
      };

      navigator.clipboard.writeText(JSON.stringify(jsonData, null, 2)).then(() => {
        alert('JSONをコピーしました！');
      });
    }

    // 一括保存
    async function saveAllRacesToGit(forceOverwrite = false) {
      const successResults = batchResults.filter(r => r.success);
      if (successResults.length === 0) {
        alert('保存できるデータがありません');
        return;
      }

      const btn = document.getElementById('saveAllBtn');
      const statusDiv = document.getElementById('saveStatus');

      btn.disabled = true;
      btn.textContent = '⏳ 保存中...';

      statusDiv.style.display = 'block';
      statusDiv.className = 'save-status loading';
      statusDiv.textContent = forceOverwrite
        ? `🔥 ${successResults.length}レース分を完全上書き中...`
        : `🚀 ${successResults.length}レース分を保存中...`;

      try {
        const date = successResults[0].date;
        const venue = successResults[0].venue;

        // 競馬場コードマッピング
        const venueCodeMap = {
          '大井': 'OI',
          '川崎': 'KA',
          '船橋': 'FU',
          '浦和': 'UR'
        };

        const jsonData = {
          date: date,  // ✅ 正しいフィールド名
          venue: venue,  // ✅ 正しいフィールド名
          venueCode: venueCodeMap[venue] || 'OI',  // ✅ 競馬場コード追加
          races: successResults.map(r => r.data),
        };

        const response = await fetch('/.netlify/functions/save-results', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            raceDate: date,
            track: venue,
            data: jsonData,
            forceOverwrite: forceOverwrite
          })
        });

        const result = await response.json();

        if (response.ok && result.success) {
          statusDiv.className = 'save-status success';
          statusDiv.innerHTML = `
            ✅ ${successResults.length}レース分の保存成功！<br>
            <strong>ファイル:</strong> ${result.path}<br>
            <strong>コミット:</strong> ${result.sha?.substring(0, 7) || '-'}
          `;
          btn.textContent = '✅ 保存完了';
        } else {
          statusDiv.className = 'save-status error';
          statusDiv.innerHTML = `❌ エラー: ${result.error || '保存に失敗しました'}`;
          btn.disabled = false;
          btn.textContent = '🚀 12レース一括保存してGit Push';
        }
      } catch (error) {
        statusDiv.className = 'save-status error';
        statusDiv.innerHTML = `❌ ネットワークエラー: ${error.message}`;
        btn.disabled = false;
        btn.textContent = '🚀 12レース一括保存してGit Push';
      }
    }

    /**
     * テキストから日付を自動抽出
     * @param {string} text - レーステキスト
     * @returns {string} 日付（"2026年3月12日" 形式、または空文字列）
     */
    function extractDateFromText(text) {
      // 「2026年3月12日」のような日付を検出
      const dateMatch = text.match(/(\d{4})年(\d{1,2})月(\d{1,2})日/);
      if (dateMatch) {
        const date = `${dateMatch[1]}年${dateMatch[2]}月${dateMatch[3]}日`;
        console.log('[extractDateFromText] 検出:', date);
        return date;
      }
      console.warn('[extractDateFromText] 日付が検出できませんでした');
      return '';
    }

    /**
     * テキストから競馬場名を自動抽出
     * @param {string} text - レーステキスト
     * @returns {string} 競馬場名（"大井", "船橋", "川崎", "浦和" or ""）
     */
    function extractVenueFromText(text) {
      // テキストの最初の500文字から競馬場名を検出
      const sample = text.substring(0, 500);
      console.log('[extractVenueFromText] テキストサンプル:', sample);

      // 南関4場を検出（より柔軟なパターン）
      if (sample.includes('大井')) {
        console.log('[extractVenueFromText] 検出: 大井');
        return '大井';
      }
      if (sample.includes('船橋')) {
        console.log('[extractVenueFromText] 検出: 船橋');
        return '船橋';
      }
      if (sample.includes('川崎')) {
        console.log('[extractVenueFromText] 検出: 川崎');
        return '川崎';
      }
      if (sample.includes('浦和')) {
        console.log('[extractVenueFromText] 検出: 浦和');
        return '浦和';
      }

      console.warn('[extractVenueFromText] 競馬場が検出できませんでした');
      return '';
    }

    /**
     * 和暦日付をISO形式(YYYY-MM-DD)に変換
     * @param {string} japaneseDate - "2026年3月12日" 形式
     * @returns {string} "2026-03-12" 形式、または空文字列
     */
    function convertJapaneseDateToISO(japaneseDate) {
      if (!japaneseDate) return '';

      const match = japaneseDate.match(/(\d{4})年(\d{1,2})月(\d{1,2})日/);
      if (!match) return '';

      const year = match[1];
      const month = match[2].padStart(2, '0');
      const day = match[3].padStart(2, '0');

      return `${year}-${month}-${day}`;
    }
  </script>
</BaseLayout>
