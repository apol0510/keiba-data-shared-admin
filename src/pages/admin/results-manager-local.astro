---
// 地方競馬結果管理画面（一括入力）
// 地方競馬公式サイトの結果ページからコピペして自動パース→保存
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>地方競馬結果管理 | keiba-data-shared-admin</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: #0f172a;
      min-height: 100vh;
      padding: 20px;
    }

    .container {
      max-width: 1400px;
      margin: 0 auto;
      background: #1e293b;
      border-radius: 20px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.5);
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .header {
      background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
      color: white;
      padding: 30px;
      text-align: center;
    }

    .header h1 { font-size: 2.5rem; margin-bottom: 10px; text-shadow: 2px 2px 4px rgba(0,0,0,0.2); }
    .header p { font-size: 1.1rem; opacity: 0.95; }

    .content { padding: 30px; background: #1e293b; }

    .form-section {
      background: #334155;
      border-radius: 15px;
      padding: 25px;
      margin-bottom: 25px;
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .form-section h2 {
      color: #e2e8f0;
      margin-bottom: 20px;
      padding-bottom: 10px;
      border-bottom: 3px solid #f59e0b;
      font-size: 1.5rem;
    }

    .form-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 15px;
      margin-bottom: 20px;
    }

    .form-group { display: flex; flex-direction: column; }

    label { font-weight: 600; margin-bottom: 8px; color: #cbd5e1; font-size: 0.95rem; }

    input, select, textarea {
      padding: 12px;
      border: 1px solid #475569;
      border-radius: 8px;
      font-size: 1rem;
      transition: all 0.3s ease;
      background: #1e293b;
      color: #e2e8f0;
    }

    input:focus, select:focus, textarea:focus {
      outline: none;
      border-color: #f59e0b;
      box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.3);
    }

    option { background: #1e293b; color: #e2e8f0; }

    textarea { resize: vertical; font-family: monospace; line-height: 1.6; }

    .button-group { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 15px; }

    .btn {
      padding: 12px 24px;
      border: none;
      border-radius: 8px;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .btn:hover { transform: translateY(-2px); }
    .btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

    .btn-primary { background: linear-gradient(135deg, #f59e0b, #d97706); color: white; }
    .btn-primary:hover:not(:disabled) { box-shadow: 0 4px 15px rgba(245, 158, 11, 0.4); }
    .btn-save { background: linear-gradient(135deg, #f59e0b, #d97706); color: white; }
    .btn-save:hover:not(:disabled) { box-shadow: 0 4px 15px rgba(245, 158, 11, 0.4); }
    .btn-danger { background: linear-gradient(135deg, #ef4444, #dc2626); color: white; }
    .btn-danger:hover:not(:disabled) { box-shadow: 0 4px 15px rgba(239, 68, 68, 0.4); }
    .btn-secondary { background: #475569; color: #e2e8f0; }

    .path-display {
      background: #1e293b;
      padding: 10px 15px;
      border-radius: 8px;
      font-family: monospace;
      font-size: 0.9rem;
      color: #f59e0b;
      border: 1px solid #475569;
      margin-top: 10px;
    }

    .status-bar {
      padding: 15px;
      border-radius: 8px;
      margin-bottom: 20px;
      font-weight: 600;
      display: none;
    }

    .status-bar.success { display: block; background: rgba(16, 185, 129, 0.2); color: #34d399; border: 1px solid rgba(16, 185, 129, 0.3); }
    .status-bar.error { display: block; background: rgba(239, 68, 68, 0.2); color: #f87171; border: 1px solid rgba(239, 68, 68, 0.3); }
    .status-bar.info { display: block; background: rgba(59, 130, 246, 0.2); color: #60a5fa; border: 1px solid rgba(59, 130, 246, 0.3); }

    /* Preview styles */
    .preview-section { display: none; }
    .preview-section.visible { display: block; }

    .race-card {
      background: #334155;
      border-radius: 12px;
      margin-bottom: 15px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      overflow: hidden;
    }

    .race-card-header {
      background: #475569;
      padding: 12px 20px;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      user-select: none;
    }

    .race-card-header:hover { background: #4a5c73; }

    .race-card-header h3 { color: #ffffff; font-size: 1.15rem; font-weight: 700; }
    .race-card-header .race-sub { font-size: 0.85rem; color: rgba(255,255,255,0.7); margin-left: 12px; font-weight: 400; }

    .race-card-header .horse-count {
      background: #f59e0b;
      color: white;
      padding: 3px 12px;
      border-radius: 12px;
      font-size: 0.85rem;
      font-weight: 600;
    }

    .race-card-body { padding: 15px 20px; display: none; }
    .race-card-body.open { display: block; }

    /* テーブル */
    .results-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.82rem;
      margin-bottom: 15px;
    }

    .results-table th {
      background: #0f172a;
      color: #94a3b8;
      padding: 6px 8px;
      text-align: left;
      font-weight: 600;
      white-space: nowrap;
      font-size: 0.75rem;
    }

    .results-table td {
      padding: 5px 8px;
      color: #e2e8f0;
      border-bottom: 1px solid #1e293b;
      white-space: nowrap;
    }

    .results-table tr:hover td { background: rgba(245, 158, 11, 0.05); }

    .finish-1 { color: #fbbf24 !important; font-weight: 700; }
    .finish-2 { color: #60a5fa !important; font-weight: 700; }
    .finish-3 { color: #fb923c !important; font-weight: 700; }

    .sub-section {
      margin-top: 12px;
      padding: 10px;
      background: #1e293b;
      border-radius: 8px;
    }

    .sub-section h4 {
      color: #f59e0b;
      font-size: 0.9rem;
      margin-bottom: 8px;
    }

    .corner-info {
      font-size: 0.82rem;
      color: #cbd5e1;
      line-height: 1.6;
    }

    .payout-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.82rem;
    }

    .payout-table th {
      background: #0f172a;
      color: #94a3b8;
      padding: 4px 8px;
      text-align: left;
      font-weight: 600;
      font-size: 0.75rem;
    }

    .payout-table td {
      padding: 4px 8px;
      color: #e2e8f0;
      border-bottom: 1px solid #334155;
    }

    /* JSON preview */
    .json-preview {
      background: #0f172a;
      border: 1px solid #475569;
      border-radius: 8px;
      padding: 15px;
      max-height: 400px;
      overflow-y: auto;
      font-family: monospace;
      font-size: 0.8rem;
      color: #e2e8f0;
      white-space: pre-wrap;
      word-break: break-all;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      color: rgba(255, 255, 255, 0.8);
      text-decoration: none;
      font-size: 0.9rem;
      margin-bottom: 10px;
    }

    .back-link:hover { color: white; }

    /* Scroll to top */
    .scroll-top-btn {
      position: fixed;
      bottom: 30px;
      right: 30px;
      width: 50px;
      height: 50px;
      border-radius: 50%;
      background: linear-gradient(135deg, #f59e0b, #d97706);
      color: white;
      border: none;
      font-size: 1.5rem;
      cursor: pointer;
      display: none;
      align-items: center;
      justify-content: center;
      box-shadow: 0 4px 15px rgba(245, 158, 11, 0.4);
      z-index: 100;
    }

    .scroll-top-btn.visible { display: flex; }

    /* Responsive */
    @media (max-width: 768px) {
      body { padding: 10px; }
      .header h1 { font-size: 1.8rem; }
      .content { padding: 15px; }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <a href="/" class="back-link">← トップに戻る</a>
      <h1>🏇 地方競馬結果管理</h1>
      <p>地方競馬公式サイトの結果データを自動パース・保存 | 全地方競馬場対応</p>
    </div>

    <div class="content">
      <!-- Step 1: 基本情報 -->
      <div class="form-section">
        <h2>1. 基本情報</h2>
        <div class="form-row">
          <div class="form-group">
            <label for="raceDate">開催日</label>
            <input type="date" id="raceDate">
          </div>
          <div class="form-group">
            <label for="venue">競馬場</label>
            <select id="venue">
              <option value="">-- 選択 --</option>
              <optgroup label="南関競馬">
                <option value="大井">大井</option>
                <option value="川崎">川崎</option>
                <option value="船橋">船橋</option>
                <option value="浦和">浦和</option>
              </optgroup>
              <optgroup label="JRA（中央競馬）">
                <option value="東京">東京</option>
                <option value="中山">中山</option>
                <option value="阪神">阪神</option>
                <option value="京都">京都</option>
                <option value="中京">中京</option>
                <option value="新潟">新潟</option>
                <option value="小倉">小倉</option>
                <option value="札幌">札幌</option>
                <option value="函館">函館</option>
                <option value="福島">福島</option>
              </optgroup>
              <optgroup label="地方競馬">
                <option value="門別">門別</option>
                <option value="帯広">帯広</option>
                <option value="盛岡">盛岡</option>
                <option value="水沢">水沢</option>
                <option value="金沢">金沢</option>
                <option value="笠松">笠松</option>
                <option value="名古屋">名古屋</option>
                <option value="園田">園田</option>
                <option value="姫路">姫路</option>
                <option value="高知">高知</option>
                <option value="佐賀">佐賀</option>
              </optgroup>
            </select>
          </div>
          <div class="form-group">
            <label>カテゴリ / 保存先</label>
            <div class="path-display" id="pathDisplay">-- 日付と競馬場を選択してください --</div>
          </div>
        </div>
      </div>

      <!-- Step 2: テキスト入力 -->
      <div class="form-section">
        <h2>2. 結果テキスト貼り付け</h2>
        <p style="color: #94a3b8; margin-bottom: 15px;">地方競馬公式サイトの結果ページからコピーしたテキストを貼り付けてください（複数レース対応・区切り線自動除去）</p>
        <textarea id="resultText" rows="12" style="width:100%;white-space:nowrap;overflow-x:auto;" placeholder="結果テキストを貼り付け..."></textarea>
        <div class="button-group">
          <button class="btn btn-primary" onclick="parseResults()">🔍 自動解析</button>
          <button class="btn btn-secondary" onclick="clearForm()">🗑 クリア</button>
        </div>
      </div>

      <!-- ステータス & 保存ボタン -->
      <div id="statusBar" class="status-bar"></div>

      <div id="saveSection" class="form-section preview-section">
        <h2>3. 保存</h2>
        <div class="button-group">
          <button class="btn btn-save" onclick="saveToGit()">🚀 保存してGit Push</button>
          <button class="btn btn-secondary" onclick="copyJson()">📋 JSONコピー</button>
          <button class="btn btn-secondary" onclick="document.getElementById('jsonWrap').style.display = document.getElementById('jsonWrap').style.display === 'none' ? 'block' : 'none'">{ } JSON表示</button>
        </div>
        <div id="saveResult" style="margin-top:15px;padding:15px;border-radius:8px;font-weight:600;display:none;"></div>
        <div id="jsonWrap" style="display:none;margin-top:15px;">
          <div class="json-preview" id="jsonPreview"></div>
        </div>
      </div>

      <!-- プレビュー（折りたたみ可能） -->
      <div id="previewSection" class="form-section preview-section">
        <h2 style="cursor:pointer" onclick="document.getElementById('previewContent').style.display = document.getElementById('previewContent').style.display === 'none' ? 'block' : 'none'">4. プレビュー ▼</h2>
        <div id="previewContent"></div>
      </div>
    </div>
  </div>

  <button class="scroll-top-btn" id="scrollTopBtn" onclick="window.scrollTo({top:0,behavior:'smooth'})">↑</button>

<script is:inline>
  let parsedResult = null;

  // ========== ユーティリティ ==========

  function getVenueCode(venue) {
    const codes = {
      '東京': 'TOK', '中山': 'NAK', '阪神': 'HAN', '京都': 'KYO',
      '中京': 'CHU', '新潟': 'NII', '小倉': 'KOK', '札幌': 'SAP',
      '函館': 'HKD', '福島': 'FKS',
      '大井': 'OOI', '川崎': 'KAW', '船橋': 'FUN', '浦和': 'URA',
      '門別': 'MON', '帯広': 'OBI', '盛岡': 'MOR', '水沢': 'MIZ', '金沢': 'KNZ',
      '笠松': 'KSM', '名古屋': 'NGY', '園田': 'SON', '姫路': 'HIM',
      '高知': 'KOC', '佐賀': 'SAG'
    };
    return codes[venue] || 'XXX';
  }

  function removeSeparatorLines(text) {
    const lines = text.split('\n');
    const pattern = /^[\s\u3000]*={3,}.*={3,}[\s\u3000]*$/;
    const filtered = lines.filter(line => !pattern.test(line));
    const removed = lines.length - filtered.length;
    if (removed > 0) console.log(`[InputCleaner] 除去された区切り線: ${removed}行`);
    return filtered.join('\n');
  }

  function updateCategoryPath() {
    const date = document.getElementById('raceDate').value;
    const venue = document.getElementById('venue').value;
    const display = document.getElementById('pathDisplay');
    if (!date || !venue) {
      display.textContent = '-- 日付と競馬場を選択してください --';
      return;
    }
    const code = getVenueCode(venue);
    const year = date.substring(0, 4);
    const month = date.substring(5, 7);
    display.textContent = `local/results/${year}/${month}/${date}-${code}.json`;
  }

  function showStatus(msg, type) {
    const bar = document.getElementById('statusBar');
    bar.textContent = msg;
    bar.className = 'status-bar ' + type;
  }

  function showSaveResult(msg, type) {
    showStatus(msg, type);
    const el = document.getElementById('saveResult');
    if (!el) return;
    el.textContent = msg;
    el.style.display = 'block';
    const colors = {
      success: { bg: 'rgba(16,185,129,0.2)', color: '#34d399', border: 'rgba(16,185,129,0.3)' },
      error: { bg: 'rgba(239,68,68,0.2)', color: '#f87171', border: 'rgba(239,68,68,0.3)' },
      info: { bg: 'rgba(59,130,246,0.2)', color: '#60a5fa', border: 'rgba(59,130,246,0.3)' }
    };
    const c = colors[type] || colors.info;
    el.style.background = c.bg;
    el.style.color = c.color;
    el.style.border = '1px solid ' + c.border;
  }

  // ========== 自動検出 ==========

  function detectDateFromText(text) {
    const m = text.match(/(\d{4})年(\d{1,2})月(\d{1,2})日/);
    if (m) {
      return `${m[1]}-${m[2].padStart(2, '0')}-${m[3].padStart(2, '0')}`;
    }
    return null;
  }

  function detectVenueFromText(text) {
    // 「第N回 XX競馬」パターンから検出
    const venueMap = {
      '佐賀': '佐賀', '高知': '高知', '園田': '園田', '姫路': '姫路',
      '笠松': '笠松', '名古屋': '名古屋', '金沢': '金沢',
      '水沢': '水沢', '盛岡': '盛岡', '門別': '門別', '帯広': '帯広',
      '大井': '大井', '川崎': '川崎', '船橋': '船橋', '浦和': '浦和'
    };
    const lines = text.split('\n');
    for (const line of lines.slice(0, 30)) {
      // 「第21回 佐賀競馬」パターン
      const m = line.match(/第\d+回\s*(\S+?)競馬/);
      if (m) {
        const name = m[1];
        for (const [key, val] of Object.entries(venueMap)) {
          if (name.includes(key)) return val;
        }
      }
      // 「NR YYYY年...XX競馬」パターン
      const m2 = line.match(/\d{1,2}R\s+\d{4}年.*?(\S+?)競馬/);
      if (m2) {
        const name = m2[1];
        for (const [key, val] of Object.entries(venueMap)) {
          if (name.includes(key)) return val;
        }
      }
    }
    return null;
  }

  // ========== メインパーサー ==========

  function parseResults() {
    const rawText = document.getElementById('resultText').value;
    if (!rawText.trim()) {
      showStatus('テキストが入力されていません', 'error');
      return;
    }

    const text = removeSeparatorLines(rawText);
    console.log('[Parser] テキスト行数:', text.split('\n').length);

    // 自動検出
    const detectedDate = detectDateFromText(text);
    const detectedVenue = detectVenueFromText(text);

    if (detectedDate && !document.getElementById('raceDate').value) {
      document.getElementById('raceDate').value = detectedDate;
    }
    if (detectedVenue && !document.getElementById('venue').value) {
      document.getElementById('venue').value = detectedVenue;
      updateCategoryPath();
    }

    try {
      const races = splitAndParseRaces(text);
      if (races.length === 0) {
        showStatus('レースデータを抽出できませんでした', 'error');
        return;
      }

      const date = document.getElementById('raceDate').value;
      const venue = document.getElementById('venue').value;

      if (!date || !venue) {
        showStatus('日付と競馬場を選択してください', 'error');
        return;
      }

      const code = getVenueCode(venue);

      parsedResult = {
        version: '1.0.0',
        createdAt: new Date().toISOString(),
        lastUpdated: new Date().toISOString(),
        date: date,
        venue: venue,
        venueCode: code,
        category: 'local',
        totalRaces: races.length,
        races: races
      };

      const totalHorses = races.reduce((s, r) => s + (r.results ? r.results.length : 0), 0);
      showStatus(`✅ ${races.length}レース解析完了（合計${totalHorses}頭）`, 'success');
      console.log(`[Parser] 解析完了: ${races.length}R, ${totalHorses}頭`);

      renderJson();
      updateCategoryPath();

      try {
        renderPreview(races);
      } catch (e) {
        console.error('[Render] プレビュー描画エラー:', e);
      }

    } catch (e) {
      console.error('[Parser] エラー:', e);
      showStatus('解析エラー: ' + e.message, 'error');
    }
  }

  // ========== レース分割 ==========

  function splitAndParseRaces(text) {
    const lines = text.split('\n');
    const races = [];

    // 「NR YYYY年」パターンでレースの開始を検出
    const raceStartIndices = [];
    for (let i = 0; i < lines.length; i++) {
      if (/^(\d{1,2})R\s+\d{4}年/.test(lines[i].trim())) {
        raceStartIndices.push(i);
      }
    }

    console.log('[Parser] レース境界検出:', raceStartIndices.length, '箇所');

    if (raceStartIndices.length === 0) {
      // 単一レース試行
      const race = parseOneRace(lines);
      if (race && race.results && race.results.length > 0) races.push(race);
      return races;
    }

    for (let i = 0; i < raceStartIndices.length; i++) {
      const startIdx = raceStartIndices[i];
      const endIdx = i + 1 < raceStartIndices.length ? raceStartIndices[i + 1] : lines.length;
      try {
        const race = parseOneRace(lines.slice(startIdx, endIdx));
        if (race && race.results && race.results.length > 0) {
          races.push(race);
          console.log(`[Parser] R${race.raceNumber}: ${race.results.length}頭`);
        }
      } catch (e) {
        console.warn(`[Parser] レース解析エラー (index ${i}):`, e.message);
      }
    }
    return races;
  }

  // ========== 1レース解析 ==========

  function parseOneRace(lines) {
    const race = {
      raceNumber: null,
      raceName: '',
      startTime: '',
      distance: '',
      surface: 'ダート',
      trackCondition: '',
      weather: '',
      headCount: 0,
      conditions: '',
      results: [],
      corners: {},
      payouts: {
        win: [], place: [], quinella: [], exacta: [],
        quinellaPlace: [], trio: [], trifecta: [],
        bracketQuinella: [], bracketExacta: []
      }
    };

    // --- ヘッダー行解析 ---
    // 「1R 2026年3月14日 第21回 佐賀競馬 第4日 ダ1,300m （9頭） 発走時刻15:00」
    const headerLine = lines[0] ? lines[0].trim() : '';

    // レース番号
    const rnm = headerLine.match(/^(\d{1,2})R\s/);
    if (rnm) race.raceNumber = parseInt(rnm[1]);

    // 距離: 「ダ1,300m」or「芝1,800m」
    const distM = headerLine.match(/(ダ|芝)([\d,]+)m/);
    if (distM) {
      race.surface = distM[1] === 'ダ' ? 'ダート' : '芝';
      race.distance = distM[2].replace(/,/g, '');
    }

    // 頭数: 「（9頭）」
    const hcM = headerLine.match(/[（(](\d{1,2})頭[）)]/);
    if (hcM) race.headCount = parseInt(hcM[1]);

    // 発走時刻: 「発走時刻15:00」
    const stM = headerLine.match(/発走時刻\s*(\d{1,2}:\d{2})/);
    if (stM) race.startTime = stM[1];

    // --- レース名 (ヘッダーの次の非空行から1-2行) ---
    let raceNameLines = [];
    let raceNameEndIdx = 1;
    for (let i = 1; i < Math.min(10, lines.length); i++) {
      const t = lines[i].trim();
      if (!t) continue;
      // 条件行「サラブレッド系...」に到達したら終了
      if (/^サラブレッド|^アラブ|^アングロアラブ/.test(t)) {
        race.conditions = t.replace(/^(サラブレッド系|アラブ系|アングロアラブ系)\s*/, '').trim();
        raceNameEndIdx = i;
        break;
      }
      // 天候行に到達したら終了
      if (/^天候/.test(t)) {
        raceNameEndIdx = i;
        break;
      }
      // 着順ヘッダーに到達したら終了
      if (/^着\s/.test(t) || /着\s+枠\s+馬番/.test(t)) {
        raceNameEndIdx = i;
        break;
      }
      raceNameLines.push(t);
      raceNameEndIdx = i + 1;
    }

    // レース名: 最初の1-2行を結合（ただし条件・等級行は除外）
    if (raceNameLines.length > 0) {
      // 等級部分（ ３歳 (八) 等）は分離
      const filtered = raceNameLines.filter(l => {
        // 条件行を除外
        if (/^サラブレッド|^天候/.test(l)) return false;
        return true;
      });
      race.raceName = filtered.join(' ').trim();
      // レース名から末尾の等級情報を削除
      race.raceName = race.raceName.replace(/\s+[（(][^）)]+[）)]\s*$/, '').trim();
    }

    // --- 条件行 ---
    for (let i = 1; i < Math.min(15, lines.length); i++) {
      const t = lines[i].trim();
      if (/^サラブレッド|^アラブ/.test(t)) {
        race.conditions = t.replace(/^(サラブレッド系|アラブ系|アングロアラブ系)\s*/, '').trim();
        break;
      }
    }

    // --- 天候・馬場 ---
    for (let i = 0; i < Math.min(20, lines.length); i++) {
      const t = lines[i].trim();
      const wm = t.match(/天候:\s*(\S+)/);
      if (wm) race.weather = wm[1];
      const tm = t.match(/馬場:\s*(?:ダート|芝)\s*(\S+)/);
      if (tm) race.trackCondition = tm[1];
    }

    // --- 着順データ ---
    race.results = extractResults(lines);
    if (race.results.length > 0 && !race.headCount) {
      race.headCount = race.results.length;
    }

    // --- コーナー通過順 ---
    race.corners = extractCorners(lines);

    // --- 払戻金 ---
    race.payouts = extractPayouts(lines);

    return race;
  }

  // ========== 着順データ抽出 ==========

  function extractResults(lines) {
    const results = [];

    // ヘッダー行を検出: 「着 枠 馬番 馬名 ...」
    let headerIdx = -1;
    for (let i = 0; i < lines.length; i++) {
      const t = lines[i].trim();
      // タブ区切りまたはスペース区切りで「着」「枠」「馬番」を含む行
      if (/着\s+枠\s+馬番/.test(t.replace(/\t/g, ' ')) || /^着\s/.test(t)) {
        headerIdx = i;
        console.log(`[Parser] 着順ヘッダー検出: line ${i}`);
        break;
      }
    }

    if (headerIdx === -1) {
      console.warn('[Parser] 着順ヘッダーが見つかりません');
      return results;
    }

    // ヘッダーの次の行からデータ行を読み取る
    for (let i = headerIdx + 1; i < lines.length; i++) {
      const line = lines[i].trim();
      if (!line) continue;

      // 通過順セクションに到達したら終了
      if (/^コーナー通過順/.test(line) || /^[１２３４]角/.test(line)) break;
      // 払戻金セクションに到達したら終了
      if (/^単勝/.test(line) || /^払戻/.test(line)) break;

      // 着順行: 数字で始まる（1-18）、または「中」「取」「除」等
      const parts = line.split(/\t+|\s{2,}/);
      if (parts.length < 6) continue;

      // 先頭が着順（数字 or 中止/取消/除外）
      const finishStr = parts[0].trim();
      const finishNum = parseInt(finishStr);
      if (isNaN(finishNum) && !/^(中止|取消|除外|競走中止|失格)$/.test(finishStr)) continue;

      try {
        const result = parseResultRow(parts);
        if (result) {
          results.push(result);
          console.log(`[Parser] 着順: ${result.finish}着 ${result.number}番 ${result.name}`);
        }
      } catch (e) {
        console.warn(`[Parser] 着順行解析エラー:`, e.message, line);
      }
    }

    return results;
  }

  function parseResultRow(parts) {
    // parts: [着, 枠, 馬番, 馬名, 性齢, 負担, 馬体重, 増減, 騎手, 調教師, タイム, 着差, 上がり3F, コーナー通過順, 人気]
    // フィールド数は可変（コーナー通過順や人気がない場合がある）

    const finish = parseInt(parts[0]) || 0;
    const postPosition = parseInt(parts[1]) || 0;
    const number = parseInt(parts[2]) || 0;
    const name = (parts[3] || '').trim();
    const genderAge = (parts[4] || '').trim();
    const weight = parseFloat(parts[5]) || 0;

    // 馬体重: 「464kg」→「464」
    const bodyWeightRaw = (parts[6] || '').trim();
    const bwm = bodyWeightRaw.match(/(\d+)/);
    const bodyWeight = bwm ? bwm[1] : '';

    const bodyWeightChange = (parts[7] || '').trim();
    const jockey = (parts[8] || '').trim();
    const trainer = (parts[9] || '').trim();

    // 後方のフィールド: タイム以降は末尾から逆算
    // 最後のフィールドが人気（数字）
    // その前が通過順（ハイフンまたは数字コンマ等）
    // その前が上がり3F
    // その前が着差
    // その前がタイム

    const remaining = parts.slice(10);

    let time = '';
    let margin = '';
    let last3f = '';
    let cornerPosition = '';
    let popularity = 0;

    if (remaining.length >= 5) {
      time = (remaining[0] || '').trim();
      margin = (remaining[1] || '').trim();
      last3f = (remaining[2] || '').trim();
      cornerPosition = (remaining[3] || '').trim();
      popularity = parseInt(remaining[4]) || 0;
    } else if (remaining.length >= 4) {
      time = (remaining[0] || '').trim();
      margin = (remaining[1] || '').trim();
      last3f = (remaining[2] || '').trim();
      popularity = parseInt(remaining[3]) || 0;
    } else if (remaining.length >= 3) {
      time = (remaining[0] || '').trim();
      margin = (remaining[1] || '').trim();
      // 最後が数字のみ→人気、それ以外→上がり3F
      const lastVal = (remaining[2] || '').trim();
      if (/^\d{1,2}$/.test(lastVal)) {
        popularity = parseInt(lastVal);
      } else {
        last3f = lastVal;
      }
    } else if (remaining.length >= 2) {
      time = (remaining[0] || '').trim();
      margin = (remaining[1] || '').trim();
    } else if (remaining.length >= 1) {
      time = (remaining[0] || '').trim();
    }

    return {
      finish: finish,
      postPosition: postPosition,
      number: number,
      name: name,
      genderAge: genderAge,
      weight: weight,
      bodyWeight: bodyWeight,
      bodyWeightChange: bodyWeightChange,
      jockey: jockey,
      trainer: trainer,
      time: time,
      margin: margin,
      last3f: last3f,
      cornerPosition: cornerPosition,
      popularity: popularity
    };
  }

  // ========== コーナー通過順抽出 ==========

  function extractCorners(lines) {
    const corners = {};
    let inCornerSection = false;

    for (let i = 0; i < lines.length; i++) {
      const t = lines[i].trim();

      if (/^コーナー通過順/.test(t)) {
        inCornerSection = true;
        continue;
      }

      if (inCornerSection) {
        // 「N角 数字列」パターン
        const cm = t.match(/^([１２３４]|[1234])角\s+(.+)/);
        if (cm) {
          // 全角数字を半角に変換
          const cornerNum = cm[1].replace(/[１２３４]/g, c => '１２３４'.indexOf(c) + 1);
          corners[cornerNum] = cm[2].trim();
          continue;
        }
        // コーナーセクション終了
        if (t && !/^[１２３４1234]角/.test(t)) {
          inCornerSection = false;
        }
      }
    }

    return corners;
  }

  // ========== 払戻金抽出 ==========

  function extractPayouts(lines) {
    const payouts = {
      win: [],       // 単勝
      place: [],     // 複勝
      quinella: [],  // 普通馬複(馬連)
      exacta: [],    // 馬単
      quinellaPlace: [],  // ワイド
      trio: [],      // 三連複
      trifecta: [],  // 三連単
      bracketQuinella: [], // 枠複
      bracketExacta: []    // 枠単
    };

    // 払戻金ヘッダー行を検出
    // パターン1: 「単勝 複勝 枠複 普通馬複 枠単 馬単」
    // パターン2: 「ワイド 三連複 三連単 備考」

    let payoutSection1Start = -1;
    let payoutSection2Start = -1;

    for (let i = 0; i < lines.length; i++) {
      const t = lines[i].replace(/\t/g, ' ').trim();
      if (/単勝\s+複勝/.test(t) && payoutSection1Start === -1) {
        payoutSection1Start = i;
      }
      if (/ワイド\s+三連複/.test(t) && payoutSection2Start === -1) {
        payoutSection2Start = i;
      }
    }

    // セクション1のヘッダー行から券種の順序を判定
    if (payoutSection1Start >= 0) {
      const headerLine = lines[payoutSection1Start].replace(/\t/g, ' ').trim();
      console.log('[Parser] 払戻セクション1ヘッダー:', headerLine);

      // ヘッダーの次行: 「組番 金額 人気 組番 金額 人気 ...」
      // その次行: 実データ
      // セクション1の券種マッピング（ヘッダーの順序で決まる）
      const section1Types = [];
      if (/単勝/.test(headerLine)) section1Types.push('win');
      if (/複勝/.test(headerLine)) section1Types.push('place');
      if (/枠複/.test(headerLine)) section1Types.push('bracketQuinella');
      if (/普通馬複|馬連/.test(headerLine)) section1Types.push('quinella');
      if (/枠単/.test(headerLine)) section1Types.push('bracketExacta');
      if (/馬単/.test(headerLine)) section1Types.push('exacta');

      // ヘッダーの2行後からデータ行を読む（「組番 金額 人気」ヘッダーの次行）
      parsePayoutDataLines(lines, payoutSection1Start, section1Types, payouts);
    }

    if (payoutSection2Start >= 0) {
      const headerLine = lines[payoutSection2Start].replace(/\t/g, ' ').trim();
      console.log('[Parser] 払戻セクション2ヘッダー:', headerLine);

      const section2Types = [];
      if (/ワイド/.test(headerLine)) section2Types.push('quinellaPlace');
      if (/三連複/.test(headerLine)) section2Types.push('trio');
      if (/三連単/.test(headerLine)) section2Types.push('trifecta');

      parsePayoutDataLines(lines, payoutSection2Start, section2Types, payouts);
    }

    return payouts;
  }

  function parsePayoutDataLines(lines, headerIdx, types, payouts) {
    // headerIdx: 券種名ヘッダー行
    // headerIdx+1: 「組番 金額 人気 組番 金額 人気 ...」行
    // headerIdx+2以降: データ行

    for (let i = headerIdx + 2; i < Math.min(headerIdx + 10, lines.length); i++) {
      const line = lines[i].trim();
      if (!line) continue;
      // 次のセクションに到達したら終了
      if (/^ワイド|^単勝|^コーナー|^天候|^\d{1,2}R\s/.test(line)) break;

      // タブ区切りでパース
      const parts = line.split(/\t+/);
      if (parts.length < 3) continue;

      // 3フィールドずつ（組番、金額、人気）が各券種に対応
      let typeIdx = 0;
      let partIdx = 0;

      while (typeIdx < types.length && partIdx + 2 < parts.length) {
        const numStr = (parts[partIdx] || '').trim();
        const amountStr = (parts[partIdx + 1] || '').trim();
        const popStr = (parts[partIdx + 2] || '').trim();

        if (numStr && amountStr) {
          const amount = parseInt(amountStr.replace(/,/g, '')) || 0;
          const pop = parseInt(popStr) || 0;

          if (amount > 0) {
            const entry = {
              number: numStr,
              amount: amount,
              popularity: pop
            };

            const type = types[typeIdx];
            if (payouts[type]) {
              payouts[type].push(entry);
            }
          }
        }

        partIdx += 3;
        typeIdx++;
      }
    }

    // 複勝とワイドは複数行ある場合がある（2-3行）
    // 追加のデータ行を探す
    for (const multiType of ['place', 'quinellaPlace']) {
      const typeIndex = types.indexOf(multiType);
      if (typeIndex === -1) continue;

      // 既に1行目を処理済み。追加行を探す
      for (let i = headerIdx + 3; i < Math.min(headerIdx + 8, lines.length); i++) {
        const line = lines[i].trim();
        if (!line) continue;
        if (/^ワイド|^単勝|^コーナー|^天候|^\d{1,2}R\s|^備考/.test(line)) break;

        const parts = line.split(/\t+/);
        if (parts.length < 3) continue;

        // 対象の券種の位置のデータを取得
        const baseIdx = typeIndex * 3;
        if (baseIdx + 2 < parts.length) {
          const numStr = (parts[baseIdx] || '').trim();
          const amountStr = (parts[baseIdx + 1] || '').trim();
          const popStr = (parts[baseIdx + 2] || '').trim();

          if (numStr && amountStr) {
            const amount = parseInt(amountStr.replace(/,/g, '')) || 0;
            const pop = parseInt(popStr) || 0;
            if (amount > 0) {
              // 重複チェック
              const existing = payouts[multiType].find(e => e.number === numStr && e.amount === amount);
              if (!existing) {
                payouts[multiType].push({ number: numStr, amount: amount, popularity: pop });
              }
            }
          }
        }
      }
    }
  }

  // ========== プレビュー描画 ==========

  function renderPreview(races) {
    const section = document.getElementById('previewSection');
    const content = document.getElementById('previewContent');
    section.classList.add('visible');

    let html = '';
    for (const race of races) {
      const raceSub = [
        race.surface,
        race.distance ? race.distance + 'm' : '',
        race.trackCondition ? race.trackCondition : '',
        race.weather ? '天候:' + race.weather : '',
        race.startTime ? race.startTime + '発走' : ''
      ].filter(s => s).join(' / ');

      html += `
        <div class="race-card">
          <div class="race-card-header" onclick="this.nextElementSibling.classList.toggle('open')">
            <h3>${race.raceNumber ? race.raceNumber + 'R' : '?R'} ${race.raceName || '(名称未取得)'}<span class="race-sub">${raceSub}</span></h3>
            <span class="horse-count">${race.results ? race.results.length : 0}頭</span>
          </div>
          <div class="race-card-body open">`;

      // 着順テーブル
      if (race.results && race.results.length > 0) {
        html += `
            <div style="overflow-x:auto">
              <table class="results-table">
                <thead><tr>
                  <th>着</th><th>枠</th><th>馬番</th><th>馬名</th><th>性齢</th>
                  <th>斤量</th><th>体重</th><th>増減</th><th>騎手</th><th>調教師</th>
                  <th>タイム</th><th>着差</th><th>上3F</th><th>通過順</th><th>人気</th>
                </tr></thead>
                <tbody>`;

        for (const r of race.results) {
          const cls = r.finish === 1 ? 'finish-1' : r.finish === 2 ? 'finish-2' : r.finish === 3 ? 'finish-3' : '';
          html += `
                  <tr>
                    <td class="${cls}">${r.finish}</td>
                    <td>${r.postPosition}</td>
                    <td>${r.number}</td>
                    <td>${r.name}</td>
                    <td>${r.genderAge}</td>
                    <td>${r.weight}</td>
                    <td>${r.bodyWeight}kg</td>
                    <td>${r.bodyWeightChange}</td>
                    <td>${r.jockey}</td>
                    <td>${r.trainer}</td>
                    <td>${r.time}</td>
                    <td>${r.margin}</td>
                    <td>${r.last3f}</td>
                    <td>${r.cornerPosition || '-'}</td>
                    <td>${r.popularity || '-'}</td>
                  </tr>`;
        }

        html += `
                </tbody>
              </table>
            </div>`;
      }

      // コーナー通過順
      if (race.corners && Object.keys(race.corners).length > 0) {
        html += `
            <div class="sub-section">
              <h4>コーナー通過順</h4>
              <div class="corner-info">`;
        for (const [corner, order] of Object.entries(race.corners)) {
          html += `<div>${corner}角: ${order}</div>`;
        }
        html += `</div></div>`;
      }

      // 払戻金
      const payoutLabels = {
        win: '単勝', place: '複勝', bracketQuinella: '枠複',
        quinella: '馬連', bracketExacta: '枠単', exacta: '馬単',
        quinellaPlace: 'ワイド', trio: '三連複', trifecta: '三連単'
      };

      const hasPayouts = race.payouts && Object.values(race.payouts).some(arr => arr && arr.length > 0);
      if (hasPayouts) {
        html += `
            <div class="sub-section">
              <h4>払戻金</h4>
              <table class="payout-table">
                <thead><tr><th>券種</th><th>組番</th><th>金額</th><th>人気</th></tr></thead>
                <tbody>`;

        for (const [key, label] of Object.entries(payoutLabels)) {
          const items = race.payouts[key] || [];
          for (const item of items) {
            html += `
                  <tr>
                    <td>${label}</td>
                    <td>${item.number}</td>
                    <td>${item.amount.toLocaleString()}円</td>
                    <td>${item.popularity}番人気</td>
                  </tr>`;
          }
        }

        html += `
                </tbody>
              </table>
            </div>`;
      }

      html += `
          </div>
        </div>`;
    }

    content.innerHTML = html;
  }

  function renderJson() {
    if (!parsedResult) return;
    try {
      const section = document.getElementById('saveSection');
      section.classList.add('visible');
      const jsonStr = JSON.stringify(parsedResult, null, 2);
      if (jsonStr.length > 100000) {
        document.getElementById('jsonPreview').textContent = jsonStr.substring(0, 100000) + '\n\n... (以降省略: 全' + jsonStr.length.toLocaleString() + '文字)';
      } else {
        document.getElementById('jsonPreview').textContent = jsonStr;
      }
    } catch (e) {
      console.error('[Render] renderJson error:', e);
    }
  }

  // ========== 保存 ==========

  async function saveToGit() {
    if (!parsedResult) {
      showStatus('先に解析を実行してください', 'error');
      return;
    }

    const date = document.getElementById('raceDate').value;
    const venue = document.getElementById('venue').value;

    if (!date || !venue) {
      showStatus('日付と競馬場を選択してください', 'error');
      return;
    }

    const venueCode = getVenueCode(venue);

    showSaveResult('⏳ 保存中...', 'info');

    try {
      const response = await fetch('/.netlify/functions/save-results-local', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          raceDate: date,
          venue: venue,
          venueCode: venueCode,
          category: 'local',
          data: parsedResult,
          forceOverwrite: true
        })
      });

      const result = await response.json();

      if (response.ok && result.success) {
        const msg = `✅ 保存成功！ ${result.path}`;
        showSaveResult(msg, 'success');
        alert(msg);
        // 保存成功後にリセット
        setTimeout(() => {
          document.getElementById('resultText').value = '';
          document.getElementById('raceDate').value = '';
          document.getElementById('venue').value = '';
          updateCategoryPath();
          document.getElementById('previewSection').classList.remove('visible');
          document.getElementById('saveSection').classList.remove('visible');
          document.getElementById('jsonWrap').style.display = 'none';
          document.getElementById('saveResult').style.display = 'none';
          document.getElementById('statusBar').className = 'status-bar';
          parsedResult = null;
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }, 500);
      } else {
        const msg = `❌ 保存失敗: ${result.error || result.details || 'Unknown error'}`;
        showSaveResult(msg, 'error');
        alert(msg);
        console.error('[Save] エラー:', result);
      }
    } catch (e) {
      const msg = '❌ 保存エラー: ' + e.message;
      showSaveResult(msg, 'error');
      alert(msg);
      console.error('[Save] Exception:', e);
    }
  }

  function copyJson() {
    if (!parsedResult) return;
    navigator.clipboard.writeText(JSON.stringify(parsedResult, null, 2))
      .then(() => showStatus('📋 JSONをクリップボードにコピーしました', 'success'))
      .catch(e => showStatus('コピー失敗: ' + e.message, 'error'));
  }

  function clearForm() {
    document.getElementById('resultText').value = '';
    document.getElementById('previewSection').classList.remove('visible');
    document.getElementById('saveSection').classList.remove('visible');
    document.getElementById('statusBar').className = 'status-bar';
    parsedResult = null;
  }

  // ========== イベント ==========

  document.getElementById('venue').addEventListener('change', updateCategoryPath);
  document.getElementById('raceDate').addEventListener('change', updateCategoryPath);

  // Scroll to top
  window.addEventListener('scroll', () => {
    document.getElementById('scrollTopBtn').classList.toggle('visible', window.scrollY > 300);
  });

  // テキスト貼り付け時に自動検出
  document.getElementById('resultText').addEventListener('paste', function() {
    setTimeout(() => {
      const text = this.value;
      const detectedDate = detectDateFromText(text);
      const detectedVenue = detectVenueFromText(text);
      if (detectedDate) document.getElementById('raceDate').value = detectedDate;
      if (detectedVenue) document.getElementById('venue').value = detectedVenue;
      updateCategoryPath();
    }, 100);
  });
</script>
</body>
</html>
