    // 一括保存（常にマージモード）
    async function saveAllRacesToGit() {
      const successResults = batchResults.filter(r => r.success);
      if (successResults.length === 0) {
        alert('保存できるデータがありません');
        return;
      }

      // 【修正】保存前の最終確認（日付・競馬場を明示、マージモード固定）
      const date = successResults[0].date;
      const venue = successResults[0].venue;

      const confirmMsg = `以下の内容で保存します:\n\n📅 日付: ${date}\n🏇 競馬場: ${venue}\n📊 レース数: ${successResults.length}\n\n※ 既存の他会場データがある場合は自動的にマージされます\n\nよろしいですか？`;

      if (!confirm(confirmMsg)) {
        return;
      }

      const btn = document.getElementById('saveAllBtn');
      const statusDiv = document.getElementById('saveStatus');

      btn.disabled = true;
      btn.textContent = '⏳ 保存中...';

      statusDiv.style.display = 'block';
      statusDiv.className = 'save-status loading';
      statusDiv.textContent = `🚀 ${successResults.length}レース分を保存中...`;

      try {

        const jsonData = {
          raceDate: date,
          lastUpdated: new Date().toISOString(),
          track: venue,
          totalRaces: successResults.length,
          races: successResults.map(r => r.data),
        };

        const response = await fetch('/.netlify/functions/save-predictions', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            raceDate: date,
            track: venue,
            data: jsonData,
            forceOverwrite: false  // 常にマージモード
          })
        });

        const result = await response.json();

        if (response.ok && result.success) {
          statusDiv.className = 'save-status success';
          statusDiv.innerHTML = `
            ✅ ${successResults.length}レース分の保存成功！<br>
            <strong>ファイル:</strong> ${result.path}<br>
            <strong>コミット:</strong> ${result.sha?.substring(0, 7) || '-'}
          `;
          btn.textContent = '✅ 保存完了';
        } else {
          statusDiv.className = 'save-status error';
          statusDiv.innerHTML = `❌ エラー: ${result.error || '保存に失敗しました'}`;
          btn.disabled = false;
          btn.textContent = '🚀 12レース一括保存してGit Push';
        }
      } catch (error) {
        statusDiv.className = 'save-status error';
        statusDiv.innerHTML = `❌ ネットワークエラー: ${error.message}`;
        btn.disabled = false;
        btn.textContent = '🚀 12レース一括保存してGit Push';
      }
    }

    // ===== 抽出ロジック（predictions-managerから再利用） =====

    function extractPredictions(html) {
      const errors = [];
      try {
        const parser = new DOMParser();
        const doc = parser.parseFromString(html, 'text/html');

        // 複数のセレクタパターンを試す
        let table = doc.querySelector('table.default.syutuba');
        if (!table) {
          // フォールバック: クラス名を個別に指定
          table = doc.querySelector('table[class*="syutuba"]');
        }
        if (!table) {
          // さらにフォールバック: テーブルを全検索
          const tables = doc.querySelectorAll('table');
          console.log(`[extractPredictions] テーブル数: ${tables.length}`);
          if (tables.length > 0) {
            // 最初のテーブルを使用（通常は出馬表）
            table = tables[0];
            console.log(`[extractPredictions] フォールバック: 最初のテーブルを使用`);
          }
        }
        if (!table) {
          errors.push('出馬表テーブルが見つかりません');
          console.error('[extractPredictions] HTMLの最初の500文字:', html.substring(0, 500));
          return { success: false, horses: [], predictors: [], errors };
        }

        // ヘッダー行を複数パターンで検索
        let headerRow = table.querySelector('thead tr');
        if (!headerRow) {
          // フォールバック1: tbody内の最初のtr
          console.log('[extractPredictions] thead trが見つからない、tbody trを探します');
          headerRow = table.querySelector('tbody tr');
        }
        if (!headerRow) {
          // フォールバック2: テーブル内の最初のtr
          console.log('[extractPredictions] tbody trも見つからない、最初のtrを探します');
          headerRow = table.querySelector('tr');
        }
        if (!headerRow) {
          errors.push('ヘッダー行が見つかりません');
          console.error('[extractPredictions] テーブルのHTML:', table.outerHTML.substring(0, 500));
          return { success: false, horses: [], predictors: [], errors };
        }
        console.log('[extractPredictions] ヘッダー行を検出:', headerRow.textContent.substring(0, 100));

        const detectedPredictors = detectPredictors(headerRow);
        const predictors = detectedPredictors.map((_, index) => `印${detectedPredictors.length - index}`);

        // テーブル構造のデバッグ
        const allTrs = Array.from(table.querySelectorAll('tr'));
        const theadTrs = Array.from(table.querySelectorAll('thead tr'));
        const tbodyTrs = Array.from(table.querySelectorAll('tbody tr'));
        const tbodies = Array.from(table.querySelectorAll('tbody'));

        console.log(`[extractPredictions] テーブル構造:`);
        console.log(`  - 全 tr: ${allTrs.length}`);
        console.log(`  - thead tr: ${theadTrs.length}`);
        console.log(`  - tbody tr: ${tbodyTrs.length}`);
        console.log(`  - tbody 要素数: ${tbodies.length}`);
        console.log(`  - ヘッダー行の親: ${headerRow.parentElement?.tagName}`);

        // データ行を取得する新しいアプローチ
        // ヘッダー行がどこにあるかに関わらず、ヘッダー行以降の全trを取得
        const headerIndex = allTrs.indexOf(headerRow);
        let rows = allTrs.slice(headerIndex + 1);

        console.log(`  - ヘッダー行のインデックス: ${headerIndex}`);
        console.log(`  - データ行数: ${rows.length}`);

        const horses = [];
        rows.forEach((row, index) => {
          const horse = extractHorseFromRow(row, detectedPredictors, predictors);
          if (horse) {
            horses.push(horse);
          }
        });

        return {
          success: true,
          horses,
          predictors,
          errors,
        };
      } catch (error) {
        errors.push(`抽出エラー: ${error}`);
        return { success: false, horses: [], predictors: [], errors };
      }
    }

    function detectPredictors(headerRow) {
      const headers = [];
      const ths = headerRow.querySelectorAll('th');

      const excludeList = [
        '枠番', '馬番', '馬名', '選択', '性齢', '減量', '騎手', '斤量',
        '厩舎', '短評', '増減', '単勝', '人気', '着順', '馬体重',
        'オッズ', 'タイム', '着差', 'ペース', '上3F', '調教師', '馬主'
      ];

      ths.forEach((th) => {
        const text = th.textContent?.trim() || '';

        if (excludeList.includes(text)) {
          return;
        }

        if (text.includes('My')) {
          return;
        }

        if (
          text.includes('印') ||
          text === 'CPU' ||
          text === '本紙' ||
          (text.length >= 2 && text.length <= 3 && /^[ぁ-んァ-ヶー一-龠]+$/.test(text))
        ) {
          headers.push(text);
        }
      });

      return headers;
    }

    function extractMarkFromElement(element) {
      const text = element.textContent?.trim() || '';

      if (element.querySelector('svg')) {
        return 'svg';
      }

      const markMap = {
        '◎': '◎',
        '○': '○',
        '▲': '▲',
        '△': '△',
        '×': '×',
        '穴': '穴',
        '注': '注',
        '消': '消',
        '-': '-',
        '': '-',
      };

      return markMap[text] || text;
    }

    function extractHorseFromRow(row, detectedPredictors, anonymizedPredictors) {
      const tds = Array.from(row.querySelectorAll('td'));

      let number = 0;
      let name = '';
      let umacd = undefined;
      const marks = {};
      let seirei = '';
      let kisyu = '';
      let kinryo = '';
      let kyusya = '';

      const umabanTd = tds.find(td => td.classList.contains('umaban'));
      if (umabanTd) {
        number = parseInt(umabanTd.textContent?.trim() || '0', 10);
      } else if (tds.length >= 2) {
        const secondCol = tds[1].textContent?.trim() || '';
        const parsed = parseInt(secondCol, 10);
        if (!isNaN(parsed)) {
          number = parsed;
        }
      }

      const bameiTd = tds.find(td => td.classList.contains('bamei'));
      if (bameiTd) {
        const link = bameiTd.querySelector('a');
        if (link) {
          name = link.textContent?.trim() || '';
          const href = link.getAttribute('href') || '';
          const match = href.match(/\/uma\/(\d+)/);
          if (match) {
            umacd = match[1];
          }
        }
      }

      const markTds = tds.filter(td => td.classList.contains('tmyoso'));

      if (markTds.length === 0) {
        const headerRow = row.closest('table')?.querySelector('thead tr');
        if (headerRow) {
          const ths = Array.from(headerRow.querySelectorAll('th'));
          const markIndices = [];

          ths.forEach((th, idx) => {
            const text = th.textContent?.trim() || '';
            detectedPredictors.forEach(predictor => {
              if (text.includes(predictor)) {
                markIndices.push(idx);
              }
            });
          });

          markIndices.forEach((thIdx, predictorIdx) => {
            if (thIdx < tds.length && predictorIdx < anonymizedPredictors.length) {
              const td = tds[thIdx];
              const mark = extractMarkFromElement(td);
              marks[anonymizedPredictors[predictorIdx]] = mark;
            }
          });

          const fieldMap = {
            '性齢': 'seirei',
            '騎手': 'kisyu',
            '斤量': 'kinryo',
            '厩舎': 'kyusya',
            '調教師': 'kyusya',
          };

          ths.forEach((th, idx) => {
            const text = th.textContent?.trim() || '';
            Object.entries(fieldMap).forEach(([keyword, fieldName]) => {
              if (text.includes(keyword)) {
                if (idx < tds.length) {
                  const td = tds[idx];

                  if (fieldName === 'kyusya') {
                    const syozokuSpan = td.querySelector('.syozoku');
                    if (syozokuSpan) {
                      const syozoku = syozokuSpan.textContent?.trim() || '';
                      const trainerName = td.textContent?.trim().replace(syozoku, '') || '';
                      kyusya = `(${syozoku})${trainerName}`;
                    } else {
                      kyusya = td.textContent?.trim() || '';
                    }
                  } else {
                    const value = td.textContent?.trim() || '';
                    if (fieldName === 'seirei') seirei = value;
                    else if (fieldName === 'kisyu') kisyu = value;
                    else if (fieldName === 'kinryo') kinryo = value;
                  }
                }
              }
            });
          });
        }
      } else {
        markTds.forEach((td, index) => {
          if (index < anonymizedPredictors.length) {
            const mark = extractMarkFromElement(td);
            marks[anonymizedPredictors[index]] = mark;
          }
        });

        const seireiTd = tds.find(td => td.classList.contains('seirei'));
        if (seireiTd) {
          seirei = seireiTd.textContent?.trim() || '';
        }

        const kisyuTd = tds.find(td => td.classList.contains('kisyu'));
        if (kisyuTd) {
          kisyu = kisyuTd.textContent?.trim() || '';
        }

        const kinryoTd = tds.find(td => td.classList.contains('kinryo'));
        if (kinryoTd) {
          kinryo = kinryoTd.textContent?.trim() || '';
        }

        const kyusyaTd = tds.find(td => td.classList.contains('kyusya'));
        if (kyusyaTd) {
          const syozokuSpan = kyusyaTd.querySelector('.syozoku');
          if (syozokuSpan) {
            const syozoku = syozokuSpan.textContent?.trim() || '';
            const trainerName = kyusyaTd.textContent?.trim().replace(syozoku, '') || '';
            kyusya = `(${syozoku})${trainerName}`;
          } else {
            kyusya = kyusyaTd.textContent?.trim() || '';
          }
        }
      }

      if (number === 0 || !name) {
        return null;
      }

      return {
        number,
        name,
        umacd,
        marks,
        seirei,
        kisyu,
        kinryo,
        kyusya,
      };
    }

    /**
     * HTMLから競馬場名を自動抽出
     * @param {string} html - レースHTML
     * @returns {string} 競馬場名（"大井", "船橋", "川崎", "浦和" or ""）
     */
    function extractVenueFromHTML(html) {
      const parser = new DOMParser();
      const doc = parser.parseFromString(html, 'text/html');
      const racenameDiv = doc.querySelector('div.racename') || doc.querySelector('div[class*="racename"]');

      if (!racenameDiv) return '';

      const text = racenameDiv.textContent || '';

      // 南関4場を検出
      if (text.includes('大井競馬') || text.includes('大井 ')) return '大井';
      if (text.includes('船橋競馬') || text.includes('船橋 ')) return '船橋';
      if (text.includes('川崎競馬') || text.includes('川崎 ')) return '川崎';
      if (text.includes('浦和競馬') || text.includes('浦和 ')) return '浦和';

      return '';
    }

    /**
     * 和暦日付をISO形式(YYYY-MM-DD)に変換
     * @param {string} japaneseDate - "2026年3月12日" 形式
     * @returns {string} "2026-03-12" 形式、または空文字列
     */
    function convertJapaneseDateToISO(japaneseDate) {
      if (!japaneseDate) return '';

      const match = japaneseDate.match(/(\d{4})年(\d{1,2})月(\d{1,2})日/);
      if (!match) return '';

      const year = match[1];
      const month = match[2].padStart(2, '0');
      const day = match[3].padStart(2, '0');

      return `${year}-${month}-${day}`;
    }

    function extractRaceInfo(html) {
      const parser = new DOMParser();
      const doc = parser.parseFromString(html, 'text/html');

      // div.racenameを複数パターンで検索
      let racenameDiv = doc.querySelector('div.racename');
      if (!racenameDiv) {
        racenameDiv = doc.querySelector('div[class*="racename"]');
      }

      let date = '';
      let raceName = '';
      let raceSubtitle = '';
      let raceType = '';
      let distance = '';
      let surface = '';
      let startTime = '';

      if (racenameDiv) {
        const text = racenameDiv.textContent || '';
        const lines = text.split('\n').map(l => l.trim()).filter(l => l);

        console.log('[extractRaceInfo] racenameDiv テキスト:', text.substring(0, 300));

        // 日付抽出
        const dateMatch = text.match(/(\d{4})年(\d{1,2})月(\d{1,2})日/);
        if (dateMatch) {
          date = `${dateMatch[1]}年${dateMatch[2]}月${dateMatch[3]}日`;
        }

        // 発走時刻抽出
        const timeMatch = text.match(/発走[\s\u3000]*(\d{1,2}:\d{2})/);
        if (timeMatch) {
          startTime = timeMatch[1];
        }

        // h1タグの内容を優先的にraceNameとして抽出
        const h1Element = racenameDiv.querySelector('h1');
        if (h1Element) {
          raceName = h1Element.textContent.trim();
          console.log('[extractRaceInfo] h1からレース名抽出:', raceName);
        }

        // h1が無い場合、または「サラ○歳」のみの場合は、特別レース名を探す
        if (!raceName || raceName.match(/^サラ[\d歳以上]+$/)) {
          for (let line of lines) {
            if (line.match(/特別|賞|杯|盃/) && !line.match(/\d{4}年|\d{1,2}月|発走|ダ|芝|選定馬/)) {
              raceName = line;
              console.log('[extractRaceInfo] 特別レース名抽出:', raceName);
              break;
            }
          }
        }

        // サブタイトル抽出（Ｃ２－２組・３組など）
        for (let line of lines) {
          if (line.match(/[ＡＢＣ][１２３０][\-－]|特選|選定馬|シリーズ/) && line !== raceName) {
            raceSubtitle = line;
            console.log('[extractRaceInfo] サブタイトル抽出:', raceSubtitle);
            break;
          }
        }

        // 条件抽出（サラ、Ａ２、Ｂ１など）
        for (let line of lines) {
          if (line.match(/サラ|[ＡＢＣ][１２３０]/) && line !== raceName && line !== raceSubtitle) {
            raceType = line;
            break;
          }
        }

        // 距離抽出
        let distanceMatch = text.match(/(\d{3,4})m[\s\u3000]*\(/);
        if (distanceMatch) {
          distance = distanceMatch[1];
        } else {
          distanceMatch = text.match(/[ダ芝][\s\u3000]*(\d{1}),?(\d{3})m/);
          if (distanceMatch) {
            distance = `${distanceMatch[1]}${distanceMatch[2]}`;
          } else {
            distanceMatch = text.match(/[ダ芝][\s\u3000]*(\d{3,4})m/);
            if (distanceMatch) {
              distance = distanceMatch[1];
            }
          }
        }

        // 馬場抽出
        if (text.includes('ダート') || text.includes('ダ')) {
          surface = 'ダート';
        } else if (text.includes('芝')) {
          surface = '芝';
        }
      }

      return { date, raceName, raceSubtitle, raceType, distance, surface, startTime };
    }

    function scoreAndAssign(result) {
      const markScores = {
        '◎': 5,
        '○': 4,
        '▲': 3,
        'svg': 2,
        '△': 1,
        '-': 0,
      };

      const horses = result.horses.map(horse => {
        let totalScore = 0;
        Object.values(horse.marks).forEach(mark => {
          totalScore += markScores[mark] || 0;
        });

        return {
          ...horse,
          totalScore,
        };
      });

      horses.sort((a, b) => b.totalScore - a.totalScore);

      const assignments = {
        main: null,
        sub: null,
        hole: null,
        connectTop: null,
        connect: [],
        reserve: [],
        none: [],
      };

      horses.forEach((horse, index) => {
        if (index === 0) {
          assignments.main = horse;
          horse.assignment = '本命';
        } else if (index === 1) {
          assignments.sub = horse;
          horse.assignment = '対抗';
        } else if (index === 2) {
          assignments.hole = horse;
          horse.assignment = '単穴';
        } else if (index === 3) {
          assignments.connectTop = horse;
          horse.assignment = '連下最上位';
        } else if (index >= 4 && index <= 6 && horse.totalScore >= 2) {
          // 🔧 FIX: 連下は5～7位（index=4,5,6で最大3頭、2点以上のみ）
          // index=3: 連下最上位（4位）
          // index=4,5,6: 連下（5～7位）
          assignments.connect.push(horse);
          horse.assignment = '連下';
        } else if (horse.totalScore > 0) {
          // index=7以降または1点以下は補欠に回す
          assignments.reserve.push(horse);
          horse.assignment = '補欠';
        } else {
          assignments.none.push(horse);
          horse.assignment = '無';
        }
      });

      return {
        ...result,
        horses,
        assignments,
      };
    }
  </script>
</BaseLayout>
