  function renderJson() {
    if (!parsedResult) return;
    try {
      const section = document.getElementById('saveSection');
      section.classList.add('visible');
      const jsonStr = JSON.stringify(parsedResult, null, 2);
      // 大きすぎる場合は先頭のみ表示
      if (jsonStr.length > 100000) {
        document.getElementById('jsonPreview').textContent = jsonStr.substring(0, 100000) + '\n\n... (以降省略: 全' + jsonStr.length.toLocaleString() + '文字)';
      } else {
        document.getElementById('jsonPreview').textContent = jsonStr;
      }
      console.log(`[Render] JSON preview: ${jsonStr.length.toLocaleString()}文字, saveSection visible`);
    } catch (e) {
      console.error('[Render] renderJson error:', e);
    }
  }

  // ========== 保存 ==========

  async function saveToGit(forceOverwrite) {
    if (!parsedResult) {
      showStatus('先に解析を実行してください', 'error');
      return;
    }

    const date = document.getElementById('raceDate').value;
    const venue = document.getElementById('venue').value;

    if (!date || !venue) {
      showStatus('日付と競馬場を選択してください', 'error');
      return;
    }

    const category = getCategoryByVenue(venue);
    const venueCode = getVenueCode(venue);

    if (forceOverwrite && !confirm('⚠️ 完全上書きします。既存データは消えます。よろしいですか？')) return;

    showSaveResult('⏳ 保存中...', 'info');

    try {
      const response = await fetch('/.netlify/functions/save-entries', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          raceDate: date,
          venue: venue,
          venueCode: venueCode,
          category: category,
          data: parsedResult,
          forceOverwrite: forceOverwrite
        })
      });

      const result = await response.json();

      if (response.ok && result.success) {
        const msg = `✅ 保存成功！ ${result.path}`;
        showSaveResult(msg, 'success');
        alert(msg);
      } else {
        const msg = `❌ 保存失敗: ${result.error || result.details || 'Unknown error'}`;
        showSaveResult(msg, 'error');
        alert(msg);
        console.error('[Save] エラー:', result);
      }
    } catch (e) {
      const msg = '❌ 保存エラー: ' + e.message;
      showSaveResult(msg, 'error');
      alert(msg);
      console.error('[Save] Exception:', e);
    }
  }

  function copyJson() {
    if (!parsedResult) return;
    navigator.clipboard.writeText(JSON.stringify(parsedResult, null, 2))
      .then(() => showStatus('📋 JSONをクリップボードにコピーしました', 'success'))
      .catch(e => showStatus('コピー失敗: ' + e.message, 'error'));
  }

  function clearForm() {
    document.getElementById('entryText').value = '';
    document.getElementById('previewSection').classList.remove('visible');
    document.getElementById('saveSection').classList.remove('visible');
    document.getElementById('statusBar').className = 'status-bar';
    parsedResult = null;
  }

  // ========== イベント ==========

  document.getElementById('venue').addEventListener('change', updateCategoryPath);
  document.getElementById('raceDate').addEventListener('change', updateCategoryPath);

  // Scroll to top
  window.addEventListener('scroll', () => {
    document.getElementById('scrollTopBtn').classList.toggle('visible', window.scrollY > 300);
  });

  // テキスト貼り付け時に自動検出
  document.getElementById('entryText').addEventListener('paste', function() {
    setTimeout(() => {
      const text = this.value;
      const detectedDate = detectDateFromText(text);
      const detectedVenue = detectVenueFromText(text);
      if (detectedDate) document.getElementById('raceDate').value = detectedDate;
      if (detectedVenue) document.getElementById('venue').value = detectedVenue;
      updateCategoryPath();
    }, 100);
  });
</script>
</body>
</html>
